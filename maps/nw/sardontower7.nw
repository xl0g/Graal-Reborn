//#CLIENTSIDE

function onPlayerenters(){
  if(clientr.gotmagic == NULL){
    this.veladd = 0.02;
}
    else{
      this.veladd = 0.01;
    }
  onTimeout();
}

function onTimeout(){
  if (player.x in |x,x+9| && player.y in |y,y+18|) {
    player.y += this.vel;
    this.lolvar+=1;
    tilelayers[0].x = 0+random(-.7,.7);
    tilelayers[0].y = 0+random(-.7,.7);
    tilelayers[0].blue=random(.2,.7);
    tilelayers[0].green=random(.2,.7);
    this.vel += this.veladd;
  } else {
    tilelayers[0].x=0;
    tilelayers[0].y=0;
    tilelayers[0].blue=1;
    tilelayers[0].green=1;
    this.vel = 0;
  }

  if(this.lolvar>10){
    client.playsnd = "windspell.wav";
    this.lolvar=0;}
  setTimer(0.05);
}
