function onCreated(){
  setshape(1,32,32);
  this.kicktime = -1;
  settimer(.05);
}

function onPlayerEnters(){
  settimer(.05);
}

function onPlayerChats(){
  if (player.chat == "start") {
    if (this.kicktime > 0) {
      this.kicktime += 10;
      if (this.kicktime > 70)
        this.kicktime = 70;
    }
  }
}

function onTimeout(){
  showtext(1,x,y-.5,"Tempus Sans ITC","bc",this.attr[2]);
  showtext(2,x,y+1.3,"Tempus Sans ITC","bc",this.attr[1]);
  showtext(5,x+.1,y-.4,"Tempus Sans ITC","bc",this.attr[2]);
  showtext(6,x+.1,y+1.4,"Tempus Sans ITC","bc",this.attr[1]);
  showtext(3,x,y+2.3,"Tempus Sans ITC","bc","Your Spar Points:" @ int(clientr.stat_rankpts_spar));
  showtext(4,x+.1,y+2.4,"Tempus Sans ITC","bc","Your Spar Points:" @ int(clientr.stat_rankpts_spar));
  changeimgzoom(2,.7);
  changeimgzoom(3,.7);
  changeimgzoom(4,.7);
  changeimgzoom(6,.7);
  changeimgvis(1,3);
  changeimgvis(2,3);
  changeimgvis(3,3);
  changeimgvis(4,2);
  changeimgvis(5,2);
  changeimgvis(6,2);
  changeimgcolors(4,0,0,0,1);
  changeimgcolors(5,0,0,0,1);
  changeimgcolors(6,0,0,0,1);


  if (client.exoduskick > 0){
    this.kicktime = client.exoduskick;
    client.exoduskick = "";
  }
  else if (client.exoduskick == -1){
    this.kicktime = -1;
    client.exoduskick = "";
    hideimgs(200,201);
  }
  temp.xcheck = this.XCheck();
  temp.ycheck = this.YCheck();
  if (this.kicktime > 0){
    if (temp.xcheck || !(temp.ycheck)){
      if (this.kicktime <= 30) {
        showimg(200,"classic_sparring.png",16,115);
        changeimgvis(200,4);
        showtext(201,34,115,"tempus sans itc","",int(this.kicktime + 1) @ " second(s) left to start!");
        changeimgzoom(201,.7);
        changeimgvis(201,4);
      }
      this.kicktime -= .05;
      if (this.kicktime == 0){
        this.kicktime = -1;
        hideimgs(200,201);
        triggeraction(x+1,y+1,"remove",player.communityname);
      }
    }
    else {
      this.kicktime = -1;
      hideimgs(200,201);
    }
  }
  if(temp.xcheck && temp.ycheck){
    if(this.attr[5] == 0){
      disableweapons();
    }
    else{
      enableweapons();
    }
  }
  else{
    disableweapons();
  }
  setTimer(.05);
}

function YCheck(){
  if(player.y in |28,44|){
    return(true);
  }
  return(false);
}

function XCheck(){
  if(player.x in |18.5,42.5|){
    return(true);
  }
  return(false);
}

function onPlayerdies(){
  if(player.hearts > 0){
    return;
  }
  triggeraction(x+1,y+1,"dead",player.communityname);
  freezeplayer(1);
  player.x = 30.5;
  player.y = 52;
  player.hearts = player.fullhearts;
}
