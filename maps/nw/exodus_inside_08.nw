function onTimeout(){
  if (this.focus == 1) {
    this.xdis = (30.5 - this.currfocus[0]) / 10;
    this.ydis = (36.5 - this.currfocus[1]) / 10;

    if (abs(this.xdis) + abs(this.ydis) > .01){
      this.currfocus = {this.currfocus[0] + this.xdis, this.currfocus[1] + this.ydis};
      setfocus(this.currfocus[0],this.currfocus[1]);
    }
    else
      setfocus(30.5, 36.5);
    settimer(.05);
  }
  else {
    this.xdis = (player.x - this.currfocus[0]) / 10;
    this.ydis = (player.y - this.currfocus[1]) / 10;

    if (abs(this.xdis) + abs(this.ydis) > .01){
      this.currfocus = {this.currfocus[0] + this.xdis, this.currfocus[1] + this.ydis};
      setfocus(this.currfocus[0],this.currfocus[1]);
      settimer(.05);
    }
    else
      resetfocus();
  }
}
