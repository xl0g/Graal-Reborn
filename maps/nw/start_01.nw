    for (this.i = 0; this.i < 20; this.i ++) {
      showani 200,13 + this.i*0.6,22 + 7*this.selection,3,classic_walk,;
      sleep 0.05;
    }
    showani 200,25,22 + 7*this.selection,3,classic_sword;
    sleep 0.6;
  }
  showani 200,25 + 12 * min(selected,0),22 + 7*this.selection,3,classic_idle,;
  timeout = 0.05;
}
NPCEND
