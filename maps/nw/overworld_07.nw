  vangle=(vangle+(pi/50))%(6.28);
  this.z=1+sin(vangle);

  showimg2(200,"classic_angel.png",this.x,this.y+5,0);
  changeimgcolors(200,0,0,0,.25);
  changeimgmode(200,1);
  changeimgzoom(200,.5-sin(vangle)*.05);
  changeimgvis(200,0);
  setTimer(0.05);
}
