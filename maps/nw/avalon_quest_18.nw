NPC classic_axeball.png 39 35
// NPC made by Tajia (LAT)
//#CLIENTSIDE


//needs to damage on hp system


function onPlayertouchsme(){
//hurt(1);
}

function onCreated(){
y = 30;
settimer(.05);
}

function onTimeout(){
if (this.mode == 2){
y = this.y - .5;
}
if (this.mode == 1){
y = this.y + .5;
}
settimer(.05);
}

if (y == 30){
this.mode = 1;
}
if (y == 48){
this.mode = 2;
}
NPCEND
