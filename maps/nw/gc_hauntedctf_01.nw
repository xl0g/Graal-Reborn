//#CLIENTSIDE
function resetAmbienceCounter(){
 this.ambienceCounter = int(random(70,280));
}
if (created){
 this.playerScare = 0;
 resetAmbienceCounter();
 timeout = 0.05;
}
if (timeout){
 seteffect 0,0,0,0.5+random(-0.02,0.02);
 if (this.ambienceCounter == 0){
  this.ambienceEffect = int(random(0,4));
  if (this.ambienceEffect == 0){
   seteffect 0.4,0.4,0,0.4;
   play thunder.wav;
  }else if (this.ambienceEffect == 1) play2 crush.wav,x,y,1;
   else if (this.ambienceEffect == 2) play2 horse.wav,x,y,1;
   else if (this.ambienceEffect == 3) this.playerScare = 120;
  resetAmbienceCounter();
 }else this.ambienceCounter--;
 if (this.playerScare != 0){
  this.scareIntensity = this.playerScare / 120;
  for (i=0;i<40;i++){
   if (int(random(0,200)) in |100,102|) movement_handlekeys = 0.05;
   showimg i,light4.png,playerx-2+random(-6,6),playery-2+random(-6,6);
   changeimgcolors i,random(0,1)*this.scareIntensity,0,0,random(0.7,0.99)*this.scareIntensity;
   changeimgzoom i,random(0.5,0.9)*this.scareIntensity;
  }
  this.playerScare--;
 }else hideimgs 0,119;
 message KEEPIN' 'CHA POSTED OK #v(this.ambienceCounter) LAST EFFECT WUZ #v(this.ambienceEffect);
 timeout = 0.05;
}
