    player.chat = "*Word Saved*";
    this.word = params[0];
  }
}

function onPlayerchats() {
  if (player.chat == this.word && !this.word == "") {
    player.x = 31.5;
    player.y = 38;
    player.chat = "I got it! --> " @ this.word;
    clink=findnpc("gc_rankings");
    (clink.("gc_" @ player.account @ "_pictionaryg"))++;
    this.word = "";
  }
}



