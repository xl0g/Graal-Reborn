function onPlayerenters(){
  onTimeout();
  this.autorespawn = 10;
}

function onTimeout(){
  setTimer(0.05);

  if(clientr.hd_isdead == true){

if(this.autorespawn > 0){
    this.autorespawn -= 0.05;
}

    if(this.autorespawn in <0.1,5>){
      player.chat = "Disqualified in "@int(this.autorespawn)@" Seconds";
    }

    if(this.autorespawn == 0){
      player.x = 30;
      player.y = 57;
      player.chat = "Disqualified";
    }

  }

  else{

      this.autorespawn = 10;


  }

}
