NPC - 20 3
clink=findNPC("gc_rankings");
if (created) {
  setshape 1,32,32;
  level.respawn = 1;
  level.respawntime = 3;
}
if (playerchats) {
  if (strequals(#g,Game Coordinator) || control == 1) {
    if (strequals(#c,reset deaths)) {
      setplayerprop #c,Deaths Reset!;
      setstring this.accounts,;
      setstring this.deaths,;
      for (i=0;i<playerscount;i++) {
        addstring this.accounts,#a(i);
        addstring this.deaths,0;
      }
      setAttributes();
    }
    elseif (strequals(#c,start)) {
      setplayerprop #c,Weapons Enabled!;
      save[0] = 1;
    }
    elseif (strequals(#c,start heal)) {
      setplayerprop #c,Weapons Enabled!;
      save[0] = 2;
    }
    elseif (strequals(#c,stop)) {
      setplayerprop #c,Weapons Disabled!;
      save[0] = 0;
    }
    tokenize #c;
    if (strequals(#t(0),deaths)) this.deathscount = strtofloat(#t(1));
  }
}
if (playerenters) {
  if (lindexof(#a,this.accounts) == -1) {
    addstring this.accounts,#a;
    addstring this.deaths,0;
    setAttributes();
  }
}
if (actionfellintopit) {
  if (save[0] == 2) setstring clientr.stat_hp,#s(clientr.stat_maxhp);
  increaseDeaths();
(clink.("gc_" @ player.account @ "_pitfalls"))++;
  checkElimination();
}
if (actionplayerdied) {
  increaseDeaths();
  checkElimination();
}
function increaseDeaths() {
  if (save[0] != 0) {
    index = lindexof(#a,this.accounts);
    deaths = strtofloat(#I(this.deaths,index));
    replacestring this.deaths,index,#v(deaths+1);
    setAttributes();
  }
}
function checkElimination() {
  if (save[0] != 0) {
    index = lindexof(#a,this.accounts);
    deaths = strtofloat(#I(this.deaths,index));
    // check if eliminated
    if (deaths >= this.deathscount && this.deathscount != 0) {
      playerx = 30.5;
      playery = 57;
      playerdir = 2;
      setani classic_idle,;
      setplayerprop #c,Eliminated!;
    }
  }
}
function setAttributes() {
  setcharprop #P1(-1),#s(this.accounts);
  setcharprop #P2(-1),#s(this.deaths);
}
//#CLIENTSIDE
if (playerenters || timeout)  {

  if (this.slp > 0 && playery > 54) {
    this.slp = 0;
  }
  if (this.dead == 1 && playery > 54) {
    this.dead = 0;
  }

  // you fell into the pit
// if ((tiles[playerx + 0.8125,playery + 3.0625] in {0x927,0x568,0x569} || tiles[playerx + 1.4375,playery + 3.0625] in {0x927,0x568,0x569} || tiles[playerx + 2.125,playery + 3.0625] in {0x927,0x568,0x569}) && movement_handlekeys == 0 && !strequals(#g,Game Coordinator) && this.slp == 0 && this.dead == 0 && playery <= 54) {
  if (movement_handlekeys == 0 && !strequals(#g,Game Coordinator) && this.slp == 0 && this.dead == 0 && playery in |51,54|) {
    setani classic_hurt,;
    triggeraction x,y,fellintopit,;
    movement_handleganis = 0.45;
    movement_handlekeys = 0.45;
    movement_handlesword = 0.45;
    movement_handleitems = 0.45;
    this.slp = 0.05;
  }
  if (this.slp > 0) {
    this.slp += 0.05;
    if (this.slp == 0.55) {
      this.slp = 0;
      setani classic_idle,;
      this.xa = {1,26.5,60,23,43};
      this.ya = {20,27,20,7,12};
      this.r = int(random(0,5));
      playerx = this.xa[this.r];
      playery = this.ya[this.r];
    }
  }

  // you died
  if (strequals(#m,classic_dead) && this.slp == 0 && this.dead == 0 && playery <= 54) {
    this.dead = 1;
    triggeraction x,y,playerdied,;
  }
  if (this.dead == 1 && !strequals(#m,classic_dead)) {
    this.dead = 0;
    setani classic_idle,;
    this.xa = {1,26.5,60,23,43};
    this.ya = {20,27,20,7,12};
    this.r = random(0,5);
    playerx = this.xa[this.r];
    playery = this.ya[this.r];
  }

  // display deaths for GCs
  if (strequals(#g,Game Coordinator)) {
    for (i = 1;i < playerscount;i++) {
      if (mousex in |players[i].x,players[i].x + 3| && mousey in |players[i].y,players[i].y + 3|) {
        this.accounts,#P1(-1);
        this.deaths,#P2(-1);
        index = lindexof(#a(i),this.accounts);
        if (index > -1) {
            showtext 1,screenwidth / 2,screenheight - 20,,bc,#a(i): #I(this.deaths,index);
            changeimgzoom 1,0.8;
            changeimgvis 1,4;
            break;
        }
      }
    }
  }

  // show your own deaths
  if (playery <= 54) {
    setstring this.accounts,#P1(-1);
    setstring this.deaths,#P2(-1);
    index = lindexof(#a,this.accounts);
    if (index > -1) {
      showtext 0,14,7,,b,Deaths: #I(this.deaths,index);
      changeimgzoom 0,0.7;
      changeimgvis 0,4;
    }
    else hideimg 0;
  }
  else hideimg 0;

  // enable and disable weapons
  if (!strequals(#g,Game Coordinator)) {
    if (playery <= 54) {
      if (save[0] == 0) {
        movement_handlesword = 0.1;
        movement_handleitems = 0.1;
      }
   }  else {
       movement_handlesword = 0.1;
      movement_handleitems = 0.1;
    }
    movement_handlepause = 0.1;
  }

  timeout = 0.05;
}
NPCEND
