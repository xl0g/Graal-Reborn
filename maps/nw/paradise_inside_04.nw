  this.shield = strtofloat(#s(clientr.stat_shield));
}
if (playerenters || timeout) {
  if (playery <= 54 && !strequals(#m,classic_dead)) {
    if (this.lastpd in {0,2}) this.lastpd = 3;
    if (keydown(0)) {
      if (movement_handlekeys == 0) {
        if (this.des == -1 || (this.jumpn < 2 && this.key == 0)) {
          this.uvel = 0.7;
          this.unum = 0;
          this.des = 1;
          this.dvel = 0;
          this.jumpn++;
          this.key = 1;
        }
        else {
          if (this.shield != 3) playery += 0.5;
          else playery += 0.615;
        }
      }
    }
    else this.key = 0;
    if (this.des == 1) {
      this.unum++;
      if (!onwall(playerx + 0.8125,playery - 0.0625) && !onwall(playerx + 1.4375,playery - 0.0625) && !onwall(playerx + 2.125,playery - 0.0625)) playery -= this.uvel;
      else this.uvel = 0.1;
      if (this.unum >= 5) {
        this.uvel -= 0.1;
        if (this.uvel == 0) {
          this.unum = 0;
          this.des = 0;
        }
      }
    }
    for (this.a = 0;this.a <= this.dvel;this.a += 0.0625) {
      if (onwall(playerx + 0.8125,playery + 3.0625 + this.a) || onwall(playerx + 1.4375,playery + 3.0625 + this.a) || onwall(playerx + 2.125,playery + 3.0625 + this.a) && this.des == 0) {
        playery += this.a;
        this.onwall = 1;
        this.dvel = 0;
        this.des = -1;
        this.jumpn = 0;
        break;
      }
    }
    if (this.des < 1 && this.onwall == 0) {
      this.des = 0;
      playery += this.dvel;
      this.dvel += 0.125;
    }
    this.onwall = 0;

    if (movement_handlekeys == 0) {
      if (playerdir == 0) playerdir = this.lastpd;
      if (playerdir == 2) playerdir = this.lastpd;
      this.lastpd = playerdir;
    }
  }
  timeout = 0.05;
}
NPCEND
