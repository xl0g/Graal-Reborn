  }
  for (this.bh_trainerwalk = 1;this.bh_trainerwalk < 9;this.bh_trainerwalk ++){
    sprite = this.bh_trainerwalk;
    if (!onwall(x + 1.5 + vecx(dir)*1.5,y + 2)){
      x += vecx(dir)*0.4;
    }
    else{
