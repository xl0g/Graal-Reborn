function onCreated() {
  // Initialize the attributes
  showcharacter();
  head = "head836.png";
  body = "body2.png";
  colors[0] = "black";
  colors[1] = "black";
  colors[2] = "darkred";
  colors[3] = "black";
  colors[4] = "darkred";
  nick = "Chancellor Timemutt (LOG)";
  ap=100;
  shield = "no-shield.png";
  shieldpower = 1;
  dir = 2;
}

function onPlayerEnters() {
  level.md_timemutt = npcs.index(this);
  // Initialize the this. variables
  this.dirgo = {0,-1,-1,0,0,1,1,0};
  this.walkmode = 1;
  if (this.walkmode>1)
    this.walkmode = 1;
  this.x1 = x-20;
  this.x2 = x+20;
  this.y1 = x-20;
  this.y2 = x+20;
  this.speed = 0.3;
  this.mode = 0;
  setcharani("idle",NULL);
  this.runcounter = int(random(10,40));
  onTimeOut();
}

// Walking stuff
function onTimeOut() {
  if (this.mode==0) { // WALKING
    setcharani("walk",NULL);
    this.newx = x + this.dirgo[dir*2] * this.speed;
    this.newy = y + this.dirgo[dir*2+1] * this.speed;
    this.runcounter--;
    if (this.walkmode==1) { // RANDOM
      if (this.runcounter>0) {
        this.testx = this.newx + 1.5 + this.dirgo[dir*2];
        this.testy = this.newy + 2+ this.dirgo[dir*2+1];
        if (onwall(this.testx,this.testy)) {
          dir = (dir+2)%4;
          this.runcounter = int(random(0,60));
        } else {
          x = this.newx;
          y = this.newy;
        }
      } else {
        this.runcounter = int(random(10,40));
        dir = (dir+1+int(random(0,2))*2)%4;
      }
    } else if (this.walkmode==2) { // LEFTRIGHT
      if (dir!=1 && dir!=3) dir = 3;
      else {
        x = this.newx;
        y = this.newy;
        if ((dir==1 && x<=this.x1) || (dir==3 && x>=this.x2))
          dir = (dir+2)%4;
      }
    } else if (this.walkmode==3) { // UPDOWN
      if (dir!=0 && dir!=2) dir = 2;
      else {
        x = this.newx;
        y = this.newy;
        if ((dir==0 && y<=this.y1) || (dir==2 && y>=this.y2))
          dir = (dir+2)%4;
      }
    } else if (this.walkmode==4) { // RECTANGLE
      x = this.newx;
      y = this.newy;
      if ((dir==0 && y<=this.y1) || (dir==1 && x<=this.x1) ||
        (dir==2 && y>=this.y2) || (dir==3 && x>=this.x2))
          dir = (dir+3)%4;
    }
    if (this.walkmode>1 && this.runcounter<=0)
      this.runcounter = 20;
    setTimer(0.05);
  }
}
