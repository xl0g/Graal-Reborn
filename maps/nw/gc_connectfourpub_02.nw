function onCreated() {
  setshape(1,32,16);
  level.gc_control = -1;
  save[0] = 0;
}

function onPlayertouchsme() {
  if (level.gc_control == "noaccount") {
    level.gc_control = player.id;
    save[0] = player.id + 1;
  } else if (player.id != level.gc_control) {
    for (this.i = 0; this.i < playerscount; this.i++) {
      if (players[this.i].id == level.gc_control && players[this.i].level == level) {
        this.online = 1;
        break;
      }
    }
    if (this.online != 1) {
      level.gc_control = player.id;
      save[0] = player.id + 1;
    }
  }
}

function onActiondisable() {
  level.gc_control = -1;
  save[0] = 0;
}

//#CLIENTSIDE

if (created || timeout) {
  this.sit_x = 54.5;
  this.sit_y = 23;
  if (playerid == save[0] - 1) {
    if (playerx == this.sit_x && playery == this.sit_y) {
      if (level.gc_control == -1) {
        setplayerprop #c,Control Enabled;
        level.gc_control = save[0] - 1;
      }
    } else {
      if (playerid == save[0] - 1) {
        setplayerprop #c,Control Disabled;
        level.gc_control = -1;
        triggeraction x,y,disable,;
      }
    }
  }
  timeout = 0.05;
}
