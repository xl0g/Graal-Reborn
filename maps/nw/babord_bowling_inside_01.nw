function onCreated() {
  setshape(1,32,32);
  this.itemname = "VIP Single Pass Card";
  this.price = 80;
}

function onActionPurchase(){
  if (clientr.stat_gelat >= this.price) {
    if(findweapon("*Bowling VIP Single Card") == NULL){
      if(findweapon("*Bowling VIP Lifetime Card") == NULL){
        addweapon("*Bowling VIP Single Card");
        clientr.stat_gelat -= this.price;
        bowling.AddGelat(this.price);
        say2("Come Again!");
      }
      else{
        say2("You have a lifetime card already.");
      }
    }
    else{
      say2("You have this already.");
    }
  }
  else {
    say2("Not enough gelat.");
  }
}

