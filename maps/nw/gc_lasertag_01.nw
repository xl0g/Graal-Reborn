function onCreated() {
  setshape(1,32,32);
  save[0] = 0;
  if (this.accounts.index(player.account) == -1) {
    this.accounts.add(player.account);
    this.deaths.add("0");
    setAttributes();
  }
}
function onPlayerChats() {
  if (player.guild == "Game Coordinator") {
    if (player.chat == "reset deaths") {
      player.chat = "Deaths Reset!";
      this.accounts = "";
      this.deaths = "";
      for (i=0;i < players.size();i++) {
        this.accounts.add(players[i].account);
        this.deaths.add("0");
      }
      setAttributes();
    }
    if (player.chat.starts("deaths")) {
      tokens = player.chat.tokenize();
      if (tokens[0] == "deaths") {
        this.deathscount = tokens[1];
        player.chat = this.deathscount @ " deaths!";
      }
    }
    if (player.chat == "/start") save[0] = 1;
    if (player.chat == "/stop")  save[0] = 0;
  }
}

function onActionPlayerdied() {
  increaseDeaths();
  checkElimination();
}

function increaseDeaths() {
  if (save[0] != 0) {
    index = this.accounts.index(player.account);
    deaths = this.deaths[index];
    this.deaths.replace(index,deaths+1);
    setAttributes();
  }
}

function checkElimination() {
  if (save[0] != 0) {
    index = this.accounts.index(player.account);
    deaths = this.deaths[index];
    // check if eliminated
    if (deaths >= this.deathscount && this.deathscount != 0) {
      player.x = 30.5;
      player.y = 57;
      player.dir = 2;
      setani("classic_idle","");
      player.chat = "Eliminated!";
      setlevel2(30.5,44.5,"gc_studios_01.nw");
    }
  }
}
function setAttributes() {
  attr[1] = this.accounts;
  attr[2] = this.deaths;
}
