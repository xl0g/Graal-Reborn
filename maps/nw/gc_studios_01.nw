function onCreated() {
  this.allowed = {"Nightmareangel","Ibonic"};
}

function onPlayerEnters() {
  player.client.gc_teleport = "";
}

function onPlayerTouchsMe() {
  chat = "I am the great and mighty Bandolf, where would you like to go?";
  setTimer(2);
}

function onPlayerChats() {
  if (player.account in this.allowed) {
    if (player.chat = "teleport") {
      player.client.gc_teleport = 1;
      setcharani("classic_gc_teleporter","");
      chat = "Time to send you to Banland!";
      setTimer(2);
      this.scheduleEvent(0.75,"onGCWarp",NULL);
    }
  }
}

function onGCWarp() {
  if (player.account in this.allowed) {
    switch (player.client.gc_teleport) {
      case 1:
        setani("classic_gc_warp","");
        this.scheduleEvent(3,"onGCWarp",NULL);
      break;
      case 2:
        setlevel2("gc_studioffice_01.nw",28,24);
      break;
    }
    player.client.gc_teleport++;
  }
}

function onTimeout() {
  chat = "";
}

