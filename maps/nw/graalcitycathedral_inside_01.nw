onTimeout();
}

function onTimeout(){
if(this.lolvar <= 7){
dir = getdir(player.x-x,player.y-y);
message(this.messages[this.lolvar]);
setTimer(this.times[this.lolvar]);
this.lolvar ++;

}
else{
dir = 2;
message("");
}
}
