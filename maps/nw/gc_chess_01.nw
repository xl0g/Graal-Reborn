function onCreated() {
  showcharacter();
  headimg   = "head13.png";
  bodyimg   = "bodyc-sage2.mng";
  shieldimg = "staff-shield.gif";
  attr[1]   = "hat79.png";
  nick      = "White King";
  colors[0] = "orange";
  for (this.i = 1; this.i < 5; this.i++) colors[this.i] = "white";
  shieldpower = 1;
  dir         = 2;
}

function onActionslash() {
  if (player.account == nick) x = 42 + 5.5 * attdir(42,x);
}

function onPlayerchats() {
  tokens = player.chat.tokenize();
  if (tokens[0] == "setwhite") nick = tokens[1];
}
