NPC sharkright.mng 21 33
if(created){
setshape 1,32,32;
dontblock;
}

clink=findNPC("gc_rankings");
if (playerchats) {
  if (strequals(#g,Game Coordinator) || control == 1)  {
    if (strequals(#e(0,5,#c),start)) {
      if (strequals(#e(6,4,#c),NPCs)) save[0] = 2;
      elseif (strequals(#e(6,2,#c),PK)) save[0] = 3;
      elseif (strequals(#e(6,9,#c),noweapons)) save[0] = 4;
      elseif (strequals(#e(7,1,#c),)) save[0] = 1;
      else break;
      message Start!;
      timeout = 2;
    } elseif (strequals(#c,stop)) {
      save[0] = 0;
      level.nodamage = 1;
      message Stop, HAMMERTIME!;
      timeout = 2;
    }
    if (save[0] == 3) level.nodamage = 0;
    else level.nodamage = 1;
  }
  if (strequals(#c,Commands)) say2 Commands:#bstart - Starts a non-pk match#bstart pk - starts a pk match#bstart noweapons - starts a#b   match with no swords#bstop - Stops a match;
}
if (timeout) {
  message;
}
if (playerenters && strequals(#g,Game Coordinator)) say2 Say 'Commands' for commands;
if (actionfullheal) {
  if (save[0] in |1,2|) {
    setstring clientr.stat_hp,#s(clientr.stat_maxhp);
  }
}
function onActionstats(){
  (clink.("gc_" @ player.account @ "_sumo_lost"))++;
}
//#CLIENTSIDE
if(created){
dontblock;
setimg sharkright.mng;
}

if(playerenters || timeout){
  if (!strequals(#g,Game Coordinator)) movement_handlepause = 0.1;
  if (playery <= 46) {
    if (save[0] >= 1) {
      if (save[0] == 2) { }
      if (save[0] == 4) {
        movement_handlesword = 0.1;
        movement_handleitems = 0.1;
      }
      if (save[0] in |1,2| && strtofloat(#s(clientr.stat_hp)) < strtofloat(#s(clientr.stat_maxhp))) {

        if (this.triggered < 1) {
          triggeraction x,y,fullheal,;

          this.triggered = 1;
        }
      }
      if (playery >= 12 && onwater(playerx + 1.5,playery + 2) && !strequals(#g,Game Coordinator)) {
        playerx = 30.5;
        playery = 51;
        playerdir = 2;
        triggeraction(x,y,"stats",NULL);
      }
    }
    else {
      if (!strequals(#g,Game Coordinator)) {
        movement_handlesword = 0.1;
        movement_handleitems = 0.1;
      }
      else {
        //
      }
    }
  }
  else {
    if (!strequals(#g,Game Coordinator)) {
      movement_handlesword = 0.1;
      movement_handleitems = 0.1;
    }
    else {
      //
    }
  }

  // lower delay for triggering next full health
  if (this.triggered > 0) this.triggered -= 0.05;

