NPC classic_target1.png 14 20
// NPC made by Schoko
join(motion_functions);

function onCreated() {
  setshape(1,32,32);
}

//#CLIENTSIDE

function onCreated(){
  hide();
  setTimer(0.05);
  this.inPlay = 1;
  this.movedir = random(0,6.28);
  this.dircounter = 0.15;
  this.startx=x;
  this.starty=y;
}
function onTimeout(){
  //player.chat = "" @ client.rafton @ "," @ this.inPlay;
  if (client.rafton && this.inPlay){
    show();
    if (this.dircounter == 0) {
      this.dircounter = 0.35;
      this.movedir = random(0,6.28);
    }
    this.dircounter -= .05;
    dx = 0.5*cos(this.movedir);
    dy = 0.5*sin(this.movedir);
    moveXY(dx,dy,this);
  }
  settimer(.07);

  if (!client.rafton){
    hide();
    if (!this.inPlay) {
      this.inPlay = 1;
      x=this.startx;
      y=this.starty;
    }
  }
}

function onWasShot() {

  hide();

  if (client.avalonquest_targets == NULL)
    client.avalonquest_targets = 1;
  else
    client.avalonquest_targets += 1;
  this.inPlay = 0;

}
NPCEND
