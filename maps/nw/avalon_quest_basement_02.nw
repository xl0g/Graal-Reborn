NPC classic_leafimg.png 9 11
//#CLIENTSIDE
function onPlayerenters(){
  init();
}

function onPlayertouchsme(){
  client.rafton = true;
  client.avalonquest_targets = 0;
  myarrows = 10;
  onTimeout();
}

function onTimeout(){
  if (client.rafton){
    if(this.mode % 2) {
      y += this.movement[this.mode];
      if(y==this.checkpoints[this.mode])
        this.mode++;
    } else {
      x += this.movement[this.mode];
      if(x==this.checkpoints[this.mode])
        this.mode++;
    }

    player.y = this.y - 2;
    player.x = this.x + 1.25;

    movement_handlekeys = .1;
    freezeplayer(.1);
    setani("idle",null);

    for(i : {0,1,2,3})
      if(keydown(i))
        player.dir = i;

    if (!keydown(4)) {
      arrowing = false;
    }

    if(keydown(4) && !arrowing && myarrows>0) {
      shootarrow(player.dir);
      arrowing = true;
      myarrows--;
    }

    if(this.mode==7) {
      init();
      checkWin();
    }

  }
  setTimer(.05);
}

function checkWin() {
  if (client.avalonquest_targets == 5) {
    if (myarrows == 5) {
      player.chat = "PERFECT!";
    }
    else {
      player.chat = "I win!";
    }
    raftkey.fallDown();
    keylight.fallDown();
  }
  else {
    player.chat = "I lose...";
    player.x = 3;
    player.y = 10;
  }
}

function init() {
  setimg("classic_leafimg.png");
  this.movement = {.25,.25,-.25,.25,-.25,.25,.25};
  this.checkpoints = {54,23,27,52,12,56,51.5};
  x = 6;
  y = 10;
  this.mode = 0;
  drawunderplayer();
  arrowing = false;
  client.rafton = false;
}
NPCEND
