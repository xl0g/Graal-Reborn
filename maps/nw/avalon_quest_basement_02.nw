NPC classic_key6.png 4 53
// NPC made by Schoko Raven (LAT)
//#CLIENTSIDE
function onCreated() {
  raftkey = this;
  this.gravity = .15;
  hide();

  this.isFalling = 0;
  onTimeout();
}

public function fallDown() {
  z = y/2;
  this.bounce = 0;
  this.addvar = 0;
  show();

  this.isFalling = 1;
}

function onTimeout() {
  setTimer(.05);
  if (this.isFalling) {
    z -= this.addvar;
    this.addvar += this.gravity;
    if (z <= 0) {
      if (this.bounce == 2) {
        this.isFalling = 0;
      }
      z = 0;
      this.bounce++;
      this.addvar = -1.5/this.bounce;
    }
  }
}

function onPlayerTouchsMe(){
  hide();
  keylight.keyTaken();
  setstring("client.quest_avalon_orangekey",1);
  player.chat = "I found the Amber key!";
}
NPCEND
