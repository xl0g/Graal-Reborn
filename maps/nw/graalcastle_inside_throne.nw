//#CLIENTSIDE
function onPlayerEnters() {
  if (clientr.quest_knight_complete == NULL && clientr.quest_dungeon_complete != NULL) {
    player.x = 30.5;
    player.y = 51;
    this.walky = 30;
    this.playerscamera = system_camera.cameraMode;
    system_camera.cameraFocus = player;
    system_camera.cameraMode = system_camera.DEFAULT;
    this.phases = {"initwalk","walkup","cameratoking","kingapproach","initwalk","walkup","setdone"};
    this.phase = this.phases[0];
    this.phasenum = 0;
    freezeplayer(9999999);
    movement_handlekeys = 9999999;
    movement_handlecamera = 999999;
    movement_handlepause = 999999;
    setTimer(.05);
  }
}

function onTimeout() {

if(this.triggervar == 1){
if(!(playerreading)){
triggeraction(x+1,y+1,"Complete",NULL);
this.triggervar = 2;
}
}
if(this.triggervar != 2){
 setTimer(.05);
}
 player.chat = "";
if(this.phasenum < 7){
 (this.phase[0])();
}
}

function initwalk() {
  player.dir = 0;
  setani(gani_walk,null);
  this.phase = this.phases[++this.phasenum];
}

function walkup() {
  player.y -= .2;
  if (player.y <= this.walky) {
    this.phase = this.phases[++this.phasenum];
    setani(gani_idle,null);
    player.sprite = 15;
  }
}

function cameratoking() {
  system_camera.cameraMode = system_camera.CHASE;
  system_camera.cameraFocus = npcs[testnpc(32,6)];
  this.phase = this.phases[++this.phasenum];
  this.camerawait = 0;
}

function kingapproach() {
  this.camerawait++;
  if(this.camerawait == 20)
    npcs[testnpc(28,9)].chat = "You may approach the king.";
  if (this.camerawait > 60) {
    this.walky = 12;
    this.phase = this.phases[++this.phasenum];
    npcs[testnpc(28,9)].chat = "";
  }
}

function setdone() {
  say2("So the prophecy is true... One has"
    NL "finally come to relieve us of the"
    NL "wicked sorcerer Sardon's puppet."
    NL "Knight " @ player.account @ ","
    NL "I see why you've come here."
    NL "You seek the four Graals."
    NL "I shall help you in that journey."
    NL "But for now you'll have to wait."
    NL "There are bigger problems that"
    NL "need to be dealt with swiftly."
    NL "Here, take this"
    NL "token of gratitude.");
this.phasenum = 7;
  system_camera.cameraMode = this.playerscamera;
  system_camera.cameraFocus = player;
this.triggervar = 1;
  freezeplayer(0);
  movement_handlekeys = 0;
  movement_handlecamera = 0;
  movement_handlepause = 0;
}
