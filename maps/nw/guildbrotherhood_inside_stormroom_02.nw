// NPC by Master Storm

//#CLIENTSIDE

if (playerenters) {
  this.flames_maximumx = 2;
  this.flames_minimumx = -2;
  this.flames_maximumy = 0;
  this.flames_minimumy = -8;
  this.flames_maincolor_red = 1;
  this.flames_maincolor_green = 0.3;
  this.flames_maincolor_blue = 0;
  this.flames_tintcolor_red = 1;
  this.flames_tintcolor_green = 0;
  this.flames_tintcolor_blue = 0;
  this.flames_glowcolor_red = 1;
  this.flames_glowcolor_green = 0.5;
  this.flames_glowcolor_blue = 0;
  this.flames_zoom =0.5;
  setarray this.flames_randomx,12;
  setarray this.flames_randomy,12;
  setarray this.flames_changevar,12;
  this.flames_setupvar = 0;
  for (this.flames_setup = 0;this.flames_setup < 12;this.flames_setup ++){
    this.flames_randomx[this.flames_setup] = random(this.flames_minimumx,this.flames_maximumx);
    this.flames_randomy[this.flames_setup] = random(this.flames_minimumy,this.flames_maximumy);
    this.flames_changevar[this.flames_setup] = this.flames_setupvar;
    this.flames_setupvar +=5;
    if (this.flames_setupvar > 10){
       this.flames_setupvar = 0;
    }
  }
  showimg 205,light4.png,x - 4,y - 4;
  changeimgcolors 205,this.flames_glowcolor_red,this.flames_glowcolor_green,this.flames_glowcolor_blue,0.99;
  changeimgvis 205,3;
  timeout = 0.05;
}
if (timeout){
  for (this.flames_drawtime = 0;this.flames_drawtime < 12;this.flames_drawtime ++){
    showimg 210 + this.flames_drawtime,light4.png,x - 4 + (this.flames_randomx[this.flames_drawtime] / 9)*this.flames_changevar[this.flames_drawtime],y - 4 + (this.flames_randomy[this.flames_drawtime] / 9)*this.flames_changevar[this.flames_drawtime];
    if (this.flames_drawtime > 7){
      changeimgcolors 210 + this.flames_drawtime,this.flames_tintcolor_red,this.flames_tintcolor_green,this.flames_tintcolor_blue,0.5;
    }
    else {
      changeimgcolors 210 + this.flames_drawtime,this.flames_maincolor_red,this.flames_maincolor_green,this.flames_maincolor_blue,0.5;
    }
    changeimgvis 210 + this.flames_drawtime,3;
    changeimgzoom 210 + this.flames_drawtime,this.flames_zoom;
    this.flames_changevar[this.flames_drawtime] ++;
    if (this.flames_changevar[this.flames_drawtime] > 9;){
      this.flames_changevar[this.flames_drawtime] = 0;
      this.flames_randomx[this.flames_drawtime] = random(this.flames_minimumx,this.flames_maximumx);
      this.flames_randomy[this.flames_drawtime] = random(this.flames_minimumy,this.flames_maximumy);
    }
  }
  timeout = 0.05;
}
NPCEND
