//#CLIENTSIDE
if (created) {
  dir = 0;
  this.speed  = 0.05;
  this.initx  = x;
  this.rangex = 3.5;
  this.inity  = y;
  this.wave   = 0;
  setimg fishiel.png;
  timeout = 0.05;
}
if(timeout){
  if (dir == 0) {
    setimg fishier.png;
    x += this.speed;
  } else {
    setimg fishiel.png;
    x -= this.speed;
  }
  if (x < this.initx) {
    dir = 0;
  } else if (x > this.initx+this.rangex) {
    dir = 1;
  }
  this.wave += 0.1;
  this.wave = this.wave % 314;
  y = sin(this.wave)/2 + 10.5;
  if(int(random(0,100)) == 99){
    dir++;
    dir = dir % 2;
  }
  timeout = 0.05;
}
