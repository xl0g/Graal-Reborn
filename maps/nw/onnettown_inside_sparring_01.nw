NPC teletile.mng 25 41
function onCreated() {
  level.spar_players = {"",""};
  level.spar_queue   = {"","","",""};
  setshape(1,32,32);
}

function onPlayerEnters() {
  player.x = 30.5;
  player.y = 54;
}

function onPlayerTouchsMe() {
  if (level.spar_players[level.spar_players.size()-1].length() == 0) {
    addPlayer(player);
  } else if (level.spar_queue[level.spar_queue.size()-1].length() == 0) {
    queuePlayer(player);
  } else {
    player.chat = "The queue is full.";
  }
}

function addPlayer(object) {
  for (i=0; i < level.spar_players.size(); i++) {
    if (level.spar_players[i] == 0 || level.spar_players[i] == object.account) {
      level.spar_players[i] = object.account;
      object.x = 19 + i*23;
      object.y = 25.5;
      if (i == level.spar_players.size()-1) {
        initializeSpar();
      }
      break;
    }
  }
}

function queuePlayer(object) {
  for (i=0; i < level.spar_queue.size(); i++) {
    if (level.spar_queue[i] == 0 || level.spar_queue[i] == object.account) {
      level.spar_queue[i] = object.account;
      object.x = 18.5 + (i >= 2) * 24;
      object.y = 4;
      break;
    }
  }
}

function initializeSpar() {
  obj = putnpc2(30.5,11,"join bomb;");
  obj.bomb = {"bomb1.png","bomb.wav",1};
  obj.timer = 3;
}

