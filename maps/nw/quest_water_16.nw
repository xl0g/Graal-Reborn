join("control_movement");
//#CLIENTSIDE
if (created) {
  this.offx = .5;
  this.offy = 1;
  this.w=2;
  this.h=2;
  this.min_proximity = 0.5;
}
if (playerenters) {
  say2 Mwahahaha!!!#b#b#bThis water is MINE!!!#b#b#bALL!!!#b#bALL of it is MINE!!!;
  this.angle     = 0;
  drawoverplayer;
  dontblock;
  setcoloreffect .4,.4,.4,1;
  this.ideal_s   = pi/40;
  this.ideal_d   = 8;
  this.player_dx = this.real_x - playerx;
  this.player_dy = this.real_y - playery;
  this.real_d    = ((this.player_dx ^ 2) + (this.player_dy ^ 2)) ^ (1 / 2);
  this.real_x = 32.5;
  this.real_y = 31.5;
  this.real_w = 3;
  this.real_h = 3;
  this.real_a = pi/4;
  this.mask_h = 0;
  this.mask_x = this.real_x;
  this.mask_y = this.real_y + this.mask_h;
  this.shad_x = this.real_x + .75;
  this.shad_y = this.real_y + 3;
  showimg 200,classic_quest_water_boss.png,this.mask_x,this.mask_y;
  changeimgcolors 200,1,1,1,.5;
  showimg 201,sprites.png,this.shad_x,this.shad_y;
  changeimgpart 201,0,0,24,12;
  timeout = .05;
}

if (timeout) {
  this.tiles = findweapon("-system_moving").tiles;
  real();
  mask();
  shad();
  img_disp();
  this.movey = -0.8 * cos(getangle(this.player_dx,this.player_dy));
  this.movex =  0.8 * sin(getangle(this.player_dx,this.player_dy));
  moveObj(this.tiles,this.movex,this.movey,player);
  this.angle += pi/5;
  y           = 28 - cos(this.angle);
  if (strtofloat(#I(quest_massokre,0)) => 4) hideimgs 200,201;
  else timeout = .05;
}

function real() {
  this.player_dx = this.real_x - playerx;
  this.player_dy = this.real_y - playery;
  this.real_d  = ((this.player_dx ^ 2) + (this.player_dy ^ 2)) ^ (.5);
  if (this.real_d < this.ideal_d) this.real_d += .25 + .5 * (this.ideal_d - this.real_d);
  if (this.real_d > this.ideal_d) this.real_d -= .25 + .5 * (this.real_d - this.ideal_d);
  this.real_a   += this.ideal_s;
  this.real_x    = playerx + this.real_d * cos(this.real_a);
  this.real_y    = playery - this.real_d * sin(this.real_a);
}

function mask() {
  this.mask_h = cos(20/8 * this.real_a);
  this.mask_x = this.real_x;
  this.mask_y = this.real_y - this.mask_h - this.real_h;
}

function shad() {
  this.shad_x = this.real_x + 1.25;
  this.shad_y = this.real_y + 3;
}

function img_disp() {
  showimg 200,classic_quest_water_boss.png,this.mask_x,this.mask_y;
  showimg 201,sprites.png,this.shad_x,this.shad_y;
  changeimgpart 201,0,0,24,12;
}
NPCEND
