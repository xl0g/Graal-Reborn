function movehandling() {
  if ((onwall2(playerx + 7/16,playery + 0,1/16,3) && velox < 0) || (onwall2(playerx + 40/16,playery + 0,1/16,3)&& velox > 0)) {
    velox = 0;
  }
  if ((onwall2(playerx + 8/16,playery - 1/16,2,1/16) && veloy < 0)) {
    veloy = 0;
  }
  if (velox > 1/32) this.edgex = 39/16;
  else if (velox < -1/32) this.edgex = 8/16;
  else {
    this.edgex = 24/16;
    velox = 0;
  }
  if (veloy > 1/32) this.edgey = 47/16;
  else if (veloy < -1/32) this.edgey = 0;
  else {
    this.edgey = 24/16;
    veloy = 0;
  }

  maxdist = (velox^2 + veloy^2)^0.5;
  angle = getangle(velox,veloy);
  dx = cos(angle);
  dy = -sin(angle);
  dist = 1;

  while ((dist < maxdist) && !onwall2(playerx + 0.5 + dx*dist,playery + dy*dist + this.edgey,2,1/16) && !onwall2(playerx + dx*dist + this.edgex,playery + dy*dist,1/16,3)) {
    dist ++;
  }
  while (((dist > maxdist) || onwall2(playerx + 0.5 + dx*dist,playery + dy*dist + this.edgey,2,1/16) || onwall2(playerx + dx*dist + this.edgex,playery + dy*dist,1/16,3)) && (dist > 0)) {
    dist -= 1/16;
  }

  /*if (abs(dist - maxdist) > 1/16) {
    velox = 0;
  }*/

  if (dist < 1/16) {
    dist = 0;
  }
  playerx += dx*dist;
  playery += dy*dist;
  if (abs(dist - maxdist) > 1/16) {
    maxdist -= dist;
    dist = 0;
    if (onwall2(playerx + 0.5,playery - 1/16,2,1/16) || onwall2(playerx + 0.5,playery + 48/16,2,1/16)) {
      veloy = 0;
      while ((dist < maxdist) && !onwall2(playerx + 0.5 + dx*dist,playery,2,3)) {
        dist ++;
      }
      while (((dist > maxdist) || onwall2(playerx + 0.5 + dx*dist,playery,2,3)) && (dist > 0)) {
        dist -= 1/16;
      }
      playerx += dx*dist;
    }
    else if (onwall2(playerx + 7/16,playery + 0,1/16,3) || onwall2(playerx + 40/16,playery + 0,1/16,3)) {
      velox = 0;
      while ((dist < maxdist) && !onwall2(playerx + 0.5,playery + dy*dist,2,3)) {
        dist ++;
      }
      while (((dist > maxdist) || onwall2(playerx + 0.5,playery + dy*dist,2,3)) && (dist > 0)) {
        dist -= 1/16;
      }
      playery += dy*dist;
    }
  }
}

