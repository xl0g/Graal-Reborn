function keyhandling() {

  if (keydown(1) && !keydown(3)) {
    if (platformer_handleeffectivekeys == 0){
      if (velox > -1) velox -= 2/16;
    }
    this.lastdir = 1;
  }
  if (keydown(3) && !keydown(1)) {
    if (platformer_handleeffectivekeys == 0){
      if (velox <  1) velox += 2/16;
    }
    this.lastdir = 3;
  }
  if (!(platformer_handleeffectivekeys == 0) || (!keydown(1) && !keydown(3)) || (keydown(1) && keydown(3))) {
    if (velox > 0) velox -= 0.05;
    if (velox < 0) velox += 0.05;
    if (abs(velox) < 1/16) velox = 0;
  }

  if (keydown(0) && (canjump == 1) && (allowjump > 0)) {
    if (this.midair == 1) temp.jumppower = 1.2;
    else temp.jumppower = 1 + 0.2*abs(velox);
    veloy = max(-temp.jumppower,veloy - temp.jumppower);
    allowjump --;
    canjump = 0;
  }
  if (!keydown(0)) {
    canjump = 1;
  }

  if (platformer_allowdirchanges == 0) {
    playerdir = this.lastdir;
  }

  if (platformer_allowdirchanges > 0) {
    platformer_allowdirchanges -= 0.05;
  }
}

