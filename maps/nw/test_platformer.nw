    this.veloy = 0;
    setani classic_dead,;
    platformer_handlekeys = 0.1;
    platformer_handlesword = 0.1;
    platformer_handleganis = 0.1;
    platformer_handlerecoil = 0.1;
    this.keyfield = 0;
    for (this.i = 0; this.i < 10; this.i ++) {
      if (keydown(this.i)) this.keyfield += 2^(this.i);
    }
    if (this.isdead == 0) {
      this.isdead = 1;
      this.keyset = this.keyfield;
      this.timetorespawn = 1.9;
      for (this.i = 0; this.i < weaponscount; this.i ++) {
        callweapon this.i,waskilled,;
      }
    }
    else {
      if (this.keyfield < this.keyset) this.keyset = this.keyfield;
      else {
        if (this.keyfield > this.keyset) {
          if (this.timetorespawn <= 0) {
            platformer_handlekeys = 0;
            platformer_handlesword = 0;
            platformer_handleganis = 0;
            platformer_handlerecoil = 0;
            setstring client.hd_isdead,false;
            this.isdead = 0;
          }
          else this.keyset = this.keyfield;
        }
      }
      if (this.timetorespawn > 0) this.timetorespawn -= 0.05;
    }
  }
}
NPCEND
