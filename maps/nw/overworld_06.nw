//#CLIENTSIDE

function onCreated(){
  x+=0.5;
  onPlayerenters();
}

function onPlayerenters(){
  if(clientr.quest_knight_complete == 1){
    hide();
  }
  else{
    showcharacter();
    head = "head16.png";
    colors[0] = "orange";
    colors[1] = "gray";
    colors[2] = "darkblue";
    colors[3] = "darkblue";
    colors[4] = "darkblue";
    shield = "shield1.png";
    body = "body.png";
    dir = 2;
  }
}

function onPlayertouchsme(){
  if(clientr.quest_knight_complete == 1){
    say2("Oh, it's you.#bYou may pass.");
    hide();
  }
  else{
    if(player.dir == 0){
      say2("Only the Kings soldiers may enter#bor leave Graal City.");
    }
    else{
      if(player.y < y){
        say2("Eh, you didn't come past me,#bit's not my problem.");
      }
    }
  }
}
