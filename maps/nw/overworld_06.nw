//#CLIENTSIDE
function onCreated(){
  setshape(1,32,128);
}

function onPlayerTouchsMe(){
  if ((player.dir == 0 && system_moving.tiles.index(11) < 0) || (player.dir == 2 && system_moving.tiles.index(0) < 0)) {
    player.x = x - 0.5;
    onTimeout();
  }
}

function onTimeout(){
  if (player.y in <y-3.5,y+height+1.5>) {
    setani("classic_invisibility",NULL);
    system_freeze.weapon_freeze(0.1,0.1,0.1);
    if (player.dir == 0)
      player.y -= 0.5;
    else if (player.dir == 2)
      player.y += 0.5;
    setTimer(0.05);
  } else {
    system_gani.updateAni();
  }
}
