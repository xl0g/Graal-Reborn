// NPC made by Master Storm (Brotherhood)
//#CLIENTSIDE
if (created) {
  seteffect 0,0,0,0;
  this.spiral_maxradius = 8;                   //Maximum radius of the spiral
  this.spiral_minradius = 4;                   //Minimum radius of the spiral
  this.spiral_radius = 4;                      //Starting radius
  this.spiral_radiusdir = 1;                   //Starting radius direction (1:Increasing, 0:No Change -1:Decreasing)
  this.spiral_radiusspeed = 0.1;               //Rate at which the radius expands/compresses
  this.spiral_maxred = 0.5;                    //Maximum red blend
  this.spiral_minred = 0;                      //Minimum red blend
  this.spiral_red = 0;                         //Initial red blend value
  this.spiral_reddir = 1;                      //Starting red direction (1:Increasing, 0:No Change -1:Decreasing)
  this.spiral_redspeed = 0.05;                 //Rate at which the red blend changes
  this.spiral_maxgreen = 1;                    //Maximum green blend
  this.spiral_mingreen = 0;                    //Minimum green blend
  this.spiral_green = 1;                       //Initial green blend value
  this.spiral_greendir = 1;                    //Starting green direction (1:Increasing, 0:No Change -1:Decreasing)
  this.spiral_greenspeed = 0.05;               //Rate at which the green blend changes
  this.spiral_maxblue = 1;                     //Maximum blue blend
  this.spiral_minblue = 0;                     //Minimum blue blend
  this.spiral_blue = 0.5;                      //Initial blue blend value
  this.spiral_bluedir = -1;                    //Starting blue direction (1:Increasing, 0:No Change -1:Decreasing)
  this.spiral_bluespeed = 0.025;               //Rate at which the blue blend changes
  this.spiral_alpha = 0.5;                     //Particle transparency
  this.spiral_zoom = 0.1;                     //Particle density
  this.spiral_maxrotate = 20;                  //Maximum rotary speed
  this.spiral_minrotate = -20;                 //Minimum rotary speed
  this.spiral_rotate = -20;                    //Initial rotary speed
  this.spiral_rotatedir = 1;                   //Initial rotary direction (1:Clockwise, 0:No Rotation -1:Anti-Clockwise)
  this.spiral_rotatespeed = 0.05;              //Rate at which the rotation speed accelerates/decelerates
  this.spiral_centrifugalforce = 1.02;         //The effect of centrifuge
  this.spiral_tentaclesnum = 4;                //The number of tentacles on the spiral
  this.spiral_tentacleslength = 50;            //The number of particles per tentacle
  this.spiral_startangle = 0;                  //The initial amount of rotation

  setarray this.spiral_tentacleangle,this.spiral_tentacleslength;
  for (this.spiral_setup = 0;this.spiral_setup < this.spiral_tentacleslength;this.spiral_setup ++){
    this.spiral_tentacleangle[this.spiral_setup] = this.spiral_startangle + this.spiral_rotate*(this.spiral_centrifugalforce^this.spiral_setup);
  }
  timeout = 0.05;
}
if (timeout){
  for (this.spiral_draw = 0;this.spiral_draw < this.spiral_tentacleslength;this.spiral_draw ++){
    for (this.spiral_draw2 = 0;this.spiral_draw2 < this.spiral_tentaclesnum;this.spiral_draw2 ++){
      showimg 200 + this.spiral_draw*this.spiral_tentaclesnum + this.spiral_draw2,light4.png,x - 4 + sin((this.spiral_tentacleangle[this.spiral_draw] + (360/this.spiral_tentaclesnum*2)*this.spiral_draw2) / 360 * 3.141592654) * this.spiral_radius / this.spiral_tentacleslength * (this.spiral_draw + 1),y - 4 + cos((this.spiral_tentacleangle[this.spiral_draw] + (360/this.spiral_tentaclesnum*2)*this.spiral_draw2) / 360 * 3.141592654) * this.spiral_radius / this.spiral_tentacleslength * (this.spiral_draw + 1);
      changeimgcolors 200 + this.spiral_draw*this.spiral_tentaclesnum + this.spiral_draw2,this.spiral_red,this.spiral_green,this.spiral_blue,this.spiral_alpha;
      changeimgzoom 200 + this.spiral_draw*this.spiral_tentaclesnum + this.spiral_draw2,this.spiral_zoom;
      changeimgvis 200 + this.spiral_draw*this.spiral_tentaclesnum + this.spiral_draw2,3;
    }
    this.spiral_tentacleangle[this.spiral_draw] += this.spiral_rotate*(this.spiral_centrifugalforce^this.spiral_draw);
  }
  this.spiral_radius += (this.spiral_radiusspeed*this.spiral_radiusdir);
  if (this.spiral_radius <= this.spiral_minradius && this.spiral_radiusdir = -1){
    this.spiral_radiusdir = 0 - this.spiral_radiusdir;
  }
  if (this.spiral_radius >= this.spiral_maxradius && this.spiral_radiusdir = 1){
    this.spiral_radiusdir = 0 - this.spiral_radiusdir;
  }
  this.spiral_red += (this.spiral_redspeed*this.spiral_reddir);
  if (this.spiral_red <= this.spiral_minred && this.spiral_reddir = -1){
    this.spiral_reddir = 0 - this.spiral_reddir;
  }
  if (this.spiral_red >= this.spiral_maxred && this.spiral_reddir = 1){
    this.spiral_reddir = 0 - this.spiral_reddir;
  }
  this.spiral_green += (this.spiral_greenspeed*this.spiral_greendir);
  if (this.spiral_green <= this.spiral_mingreen && this.spiral_greendir = -1){
    this.spiral_greendir = 0 - this.spiral_greendir;
  }
  if (this.spiral_green >= this.spiral_maxgreen && this.spiral_greendir = 1){
    this.spiral_greendir = 0 - this.spiral_greendir;
  }
  this.spiral_blue += (this.spiral_bluespeed*this.spiral_bluedir);
  if (this.spiral_blue <= this.spiral_minblue && this.spiral_bluedir = -1){
    this.spiral_bluedir = 0 - this.spiral_bluedir;
  }
  if (this.spiral_blue >= this.spiral_maxblue && this.spiral_bluedir = 1){
    this.spiral_bluedir = 0 - this.spiral_bluedir;
  }
  this.spiral_rotate += (this.spiral_rotatespeed*this.spiral_rotatedir);
  if (this.spiral_rotate <= this.spiral_minrotate && this.spiral_rotatedir = -1){
    this.spiral_rotatedir = 0 - this.spiral_rotatedir;
  }
  if (this.spiral_rotate >= this.spiral_maxrotate && this.spiral_rotatedir = 1){
    this.spiral_rotatedir = 0 - this.spiral_rotatedir;
  }
  timeout = 0.05;
  showimg 199,light4.png,x - 4,y - 4;
  changeimgcolors 199,this.spiral_red,this.spiral_green,this.spiral_blue,0.99;
  changeimgzoom 199,this.spiral_radius/4;
  changeimgvis 199,3;
}
