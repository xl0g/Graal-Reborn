// Graal Tennis created by Master Storm, based on an idea by Vangel.
// Dedicated to Jesus, just because. :)

//Modified/Finished by Kevin


join("motion_functions_serverside");

function onCreated() {
  noplayeronwall();
}

function onSlash() {
  this.dx = 10*(this.x - player.x - 0.5 + 1/16);
  this.dy = 10*(this.y - player.y - 1 + 1/16);
  doPropulsion();
}

function doPropulsion() {
  x=x;
  temp.force = (this.dx^2 + this.dy^2)^0.5;
  if (temp.force > 0.5) {
    temp.proportion = FindOptimum(this.dx,this.dy,this,0,0,2,2)/temp.force;
    move(this.dx*temp.proportion,this.dy*temp.proportion,temp.proportion * 1.5,2);
    cancelevents("modify");
    scheduleEvent(temp.proportion * 1.5,"modify","");
  }
  this.chat ++;
}

function onmodify() {
  if (onwall2(this.x - 1/16,this.y + 0.5,2 + 1/8,1)) {
    if(this.dx < 0)
      this.left++;
    else
      this.right++;
    resetPos();
    with(n:npcs)
      if("updateScore" in n.getfunctions())
        n.updateScore(this.left,this.right);
  }
  if (onwall2(this.x + 0.5,this.y - 1/16,1,2 + 1/8)) {
    this.dy *= -0.9;
  }
  this.dx *= 0.7;
  this.dy *= 0.7;
  doPropulsion();
}

function resetPos()
  {
  this.x = 31;
  this.y = 35;
  this.dx = 0;
  this.dy = 0;
}
