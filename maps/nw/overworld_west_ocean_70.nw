function onCreated(){
  showcharacter();
  this.head = "head10.png";
  this.colors[0] = "cynober";
  this.colors[1] = "cynober";
  this.colors[2] = "cynober";
  this.colors[3] = "cynober";
  this.colors[4] = "white";
