  this.ap=20;
  this.dir = 3;
this.port = 1;
}

function onPlayertouchsme(){
  if(clientr.stat_boattickets == 0){
    say2("Would you believe it?#bThere's a Port here in Nimda but#bno Ticket Office.#bI decided to start touting#btickets, i don't earn much profit#bbut atleast i provide people#bwith help.#bOtherwise they'd be stranded!");
  }
  else{
    say2("How's it going?, i see you have a#bticket. Just go to one of our#bmany ports all over Graal#b& give it to a ticket taker to#bride one of our many boats.#bYou currently have "@int(clientr.stat_boattickets)@" ticket(s).");
  }
}
NPCEND
