  setTimer(5);
  x += vecx(2);
  y += vecy(2);
  for (a = 0;a < npcs.size();a++) {
    if (npcs[a].pushTarget) {
      npcs[a].trigger("PushMove",0);
      break;
    }
  }
}
function onTimeOut(){
  y -=1;
}
