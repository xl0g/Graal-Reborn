function onCreated() setshape(1,32,16);

function onPlayerChats(){
  if (player.account in {"Rufus","Ibonic","Crimson2005","BlackSolider"} && player.chat.starts("/setmonth")){
    serverr.us_base_statue_month=player.chat.tokenize()[1];}
}

function onPlayerTouchsMe()
  {
  if (player.dir != 0) return;

  temp.text = "\n ~ US " @ serverr.us_base_statue_month @ " Spar Champion ~";
  if (player.account in {"Rufus","Ibonic","Crimson2005","BlackSolider"})
    {
    temp.text @= "\n #bCommands:" @
      "\n /setmonth [month]#b(Sets the sign month)" @
        "\n /setnpcprops [account]#b(Sets the statue attributes)";
  }
  say2(temp.text);
}
