function onCreated() {
   setshape(1,32,32);
   this.allowed = {"Rufus"};
}

function warpUSbase() {
   player.setlevel2("us_guildhouse_01.nw",30.5,46.5);
}

function onPlayertouchsme() {
   if (serverr.us_base_locked != "true" || player.guild == "US" || player.account in this.allowed) warpUSbase();
}

function onPlayerChats() {
   if (player.guild == "US" || player.account in this.allowed) {
     if (player.chat == "lock") serverr.us_base_locked = "true";
     else if (player.chat == "unlock") serverr.us_base_locked = "false";
   }
}
