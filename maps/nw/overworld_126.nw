function onPlayerchats() {
  if (player.chat=="Yes") {
    if (level.getMapPartFile(player.x,player.y) == level.getMapPartFile(x,y)) {
      if (player.clientr.stat_gelat<10){
        say2("Ach, ya bum!  You don't have the#bmoney.  Take a hike.");
      }
      else{
        if (player.clientr.stat_ammo_bombs>98){
          say2("Hey, you already got too#bmany bombs.#bBug off kid, you're bad for#bbusiness.");
        }
        else {
          player.clientr.stat_gelat-=10;
          say2("Pleasure doing business with you.");

          if(player.clientr.stat_ammo_bombs>89){
            player.clientr.stat_ammo_bombs=99;
          }
          else{ player.clientr.stat_ammo_bombs+=10;
          }
        }
