//#CLIENTSIDE
if (playerchats && strequals(#c,watch)) {
  this.focus = 1;
  this.focusx = playerx * 16;
  this.focusy = playery * 16;
  if (this.focusx < screenwidth / 2) this.focusx = screenwidth / 2;
  if (this.focusx > 1024 - screenwidth / 2) this.focusx = 1024 - screenwidth / 2 - 16;
  if (this.focusy < screenheight / 2) this.focusy = screenheight / 2;
  if (this.focusy > 1024 - screenheight / 2) this.focusy = 1024 - screenheight / 2 - 16;

  movement_handlekeys = 0.1;
  movement_handlesword = 0.1;
  movement_handleitems = 0.1;
  timeout = 0.05;
}
if (timeout) {
  if (keydown2(keycode(s),true)) {
    this.focus = 0;
    resetfocus;
  }
  elseif (this.focus == 1) {
    if (keydown(0) && this.focusy >= screenheight / 2 + 16) this.focusy -= 16;
    if (keydown(1) && this.focusx >= screenwidth / 2 + 16) this.focusx -= 16;
    if (keydown(2) && this.focusy <= 1024 - screenheight / 2 - 32) this.focusy += 16;
    if (keydown(3) && this.focusx <= 1024 - screenwidth / 2 - 32) this.focusx += 16;
    setfocus this.focusx / 16,this.focusy / 16;

    movement_handlekeys = 0.1;
    movement_handlesword = 0.1;
    movement_handleitems = 0.1;
    timeout = 0.05;
  }
}
