function loadDefaultSettings() {
  level.bombsallowed = 0;
  level.arrowsallowed = 0;
  level.swordsallowed = 1;
  level.blockhearts = 5;
  level.respawn = 1;
  level.respawntime = 1;
}

function onCreated() {
  loadDefaultSettings();
}

function onPlayerchats() {
  if (player.guild == "Game Coordinator" || control == 1) {
    if (player.chat == "bombs on") {
      level.bombsallowed  = 1;
    } else if (player.chat == "bombs off") {
      level.bombsallowed  = 0;
    } else if (player.chat == "swords on") {
      level.swordsallowed = 1;
    } else if (player.chat == "swords off") {
      level.swordsallowed = 0;
    } else if (player.chat == "darts on" || player.chat == "arrows on") {
      level.arrowsallowed = 1;
    } else if (player.chat == "darts off" || player.chat == "arrows off") {
      level.arrowsallowed = 0;
    } else if (player.chat == "all on") {
      level.bombsallowed  = 1;
      level.arrowsallowed = 1;
      level.swordsallowed = 1;
    } else if (player.chat == "all off") {
      level.bombsallowed  = 0;
      level.arrowsallowed = 0;
      level.swordsallowed = 0;
    } else if (player.chat == "start") {
      save[0] = 1;
    } else if (player.chat == "stop") {
      save[0] = 0;
    } else if (player.chat == "reset") {
      loadDefaultSettings();
    } else if (player.chat == "respawn off") {
      level.respawn = 0;
    } else if (player.chat == "commands") {
      say2 Commands:
      #bbombs on/off
      #bswords on/off
      #bdarts on/off
      #ball on/off
      #bblockhearts (hearts)
      #brespawn (time)/off
      #bstart/stop
      #breset
      #bopen/close
      #bleft click   : hearts = 0
      #bmiddle click : invincibility
      #b(Red Team) are guards
      #bCan use warps to platforms;
    } else {
      tokens = player.chat.tokenize();
      if (tokens[0] == "blockhearts") {
        level.blockhearts = tokens[1];
      } else if (tokens[0] == "respawn") {
        level.respawn     = 1;
        level.respawntime = tokens[1];
      }
    }
  }
  if (player.chat == "done") {
    playery = 59;
  }
}

//#CLIENTSIDE
if (playerenters) {
  weapons_check();
}

if (timeout) {
  weapons_check();
}

function weapons_check() {
  timeout = 0.05;
  if (!strequals(#g,Game Coordinator)) {
    if (save[0] == 0 || playery > 54) {
      movement_handlepause = 0.1;
      movement_handleitems = 0.1;
      movement_handlesword = 0.1;
    }
  }
}
NPCEND
NPC - 1 54

//#CLIENTSIDE
if (playerchats) {
  if (strequals(#c,watch)) {
    this.focus = 1;
    this.focusx = playerx * 16;
    this.focusy = playery * 16;
    if (this.focusx <sscreenwidth  / 2 - 24)   this.focusx = screenwidth  / 2 - 24;
    if (this.focusx > 1024 - screenwidth  / 2) this.focusx = 1008 - screenwidth  / 2;
    if (this.focusy <sscreenheight / 2 - 24)   this.focusy = screenheight / 2 - 24;
    if (this.focusy > 1024 - screenheight / 2) this.focusy = 1008 - screenheight / 2;
    movement_handlemoving = -1;
    movement_handlekeys   = -1;
  }
}

if (playerenters || timeout) {
  if (this.focus == 1) {
    if (keydown(0) && this.focusy >= screenheight / 2 - 24)        this.focusy -= 16;
    if (keydown(1) && this.focusx >= screenwidth  / 2 - 24)        this.focusx -= 16;
    if (keydown(2) && this.focusy <= 1024 - screenheight / 2 - 16) this.focusy += 16;
    if (keydown(3) && this.focusx <= 1024 - screenwidth  / 2 - 32) this.focusx += 16;
    setfocus this.focusx / 16,this.focusy / 16;
    if (keydown(5)) this.focus = 2;
  } else if (this.focus == 2) {
    this.dx      = this.focusx / 16 - playerx;
    this.dy      = this.focusy / 16 - playery;
    this.pull    = (this.dx ^ 2 + this.dy ^ 2)^ .5 / 10;
    this.pangle  = getangle(this.dx,this.dy);
    this.focusx -= cos(this.pangle) * this.pull * 16;
    this.focusy += sin(this.pangle) * this.pull * 16;
    setfocus this.focusx / 16,this.focusy / 16;
    if (this.focusx / 16 in <pplayerx - .5,playerx + .5> && this.focusy / 16 in <playery - .5,playery + .5>){
      this.focus = 0;
      resetfocus;
      movement_handlemoving = 0;
      movement_handlekeys   = 0;
    }
  }
  timeout = 0.05;
}
NPCEND
