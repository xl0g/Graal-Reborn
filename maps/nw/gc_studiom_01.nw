function onCreated() {
  this.deathscount = 1;
  setshape(1,32,32);
}
function onPlayerChats() {
  if (player.guild == "Game Coordinator") {
    if (player.chat == "reset deaths") {
      player.chat = "Deaths Reset!";
      this.accounts = "";
      this.deaths = "";
      for (i=0;i < players.size();i++) {
        this.accounts.add(players[i].account);
        this.deaths.add("0");
      }
      setAttributes();
    }
    if (player.chat.starts("deaths")) {
      tokens = player.chat.tokenize();
      if (tokens[0] == "deaths") {
        this.deathscount = tokens[1];
        player.chat = this.deathscount @ " deaths!";
      }
    }
  }
}
function onPlayerEnters() {
  if (this.accounts.index(player.account) == -1) {
    this.accounts.add(player.account);
    this.deaths.add("0");
    setAttributes();
  }
}

function onActionPlayerdied() {
  increaseDeaths();
  checkElimination();
}
function increaseDeaths() {
  index = this.accounts.index(player.account);
  deaths = this.deaths[index];
  this.deaths.replace(index,deaths+1);
  setAttributes();
}
function checkElimination() {
  index = this.accounts.index(player.account);
  deaths = this.deaths[index];
  // check if eliminated
  if (deaths >= this.deathscount && this.deathscount != 0) {
    player.y = 59;
    player.dir = 2;
    setani("classic_idle","");
    player.chat = "Eliminated!";
  }
}
function setAttributes() {
  attr[1] = this.accounts;
  attr[2] = this.deaths;
}
//#CLIENTSIDE
if (playerenters || timeout)  {

  if (this.slp > 0 && playery >= 54) {
    this.slp = 0;
  }
  if (this.dead == 1 && playery >= 54) {
    this.dead = 0;
    if (strequals(#m,classic_dead)) {
      setani classic_idle,;
    }
  }

  if (this.slp > 0) {
    this.slp += 0.05;
    if (this.slp == 0.55) {
      this.slp = 0;
      setani classic_idle,;
      this.xa = {18.5,42.5,18.5,42.5};
      this.ya = {35,29,11,5};
      this.r = int(random(0,4));
      playerx = this.xa[this.r];
      playery = this.ya[this.r];
    }
  }

  // you died
  if (strequals(#m,classic_dead) && this.slp == 0 && this.dead == 0 && playery < 54) {
    this.dead = 1;
    triggeraction x,y,playerdied,;
  }
  if (this.dead == 1 && !strequals(#m,classic_dead)) {
    this.dead = 0;
    setani classic_idle,;
    this.xa = {18.5,42.5,18.5,42.5};
    this.ya = {35,29,11,5};
    this.r = int(random(0,4));
    playerx = this.xa[this.r];
    playery = this.ya[this.r];
  }

  // display deaths for GCs
  if (strequals(#g,Game Coordinator)) {
    for (i = 1;i < playerscount;i++) {
      if (mousex in |players[i].x,players[i].x + 3| && mousey in |players[i].y,players[i].y + 3|) {
        this.accounts,#P1(-1);
        this.deaths,#P2(-1);
        index = lindexof(#a(i),this.accounts);
        if (index > -1) {
            showtext 1,screenwidth / 2,screenheight - 20,,bc,#a(i): #I(this.deaths,index);
            changeimgzoom 1,0.8;
            changeimgvis 1,4;
            break;
        }
      }
    }
  }

  // show your own deaths
  if (playery < 54) {
    setstring this.accounts,#P1(-1);
    setstring this.deaths,#P2(-1);
    index = lindexof(#a,this.accounts);
    if (index > -1) {
      showtext 0,14,7,,b,Deaths: #I(this.deaths,index);
      changeimgzoom 0,0.7;
      changeimgvis 0,4;
    }
    else hideimg 0;
  }
  else hideimg 0;
  timeout = 0.05;
}
