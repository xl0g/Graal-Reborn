//#CLIENTSIDE
function onCreated() {
  setshape(1,32,32);
  chat = "say test and you'll touch me without touching me!";
}
function onPlayerChats() {
  if (player.chat == "test") {
    temp.oldx = player.x;
    temp.oldy = player.y;
    //player.x = x-0.5;
    //player.y = y-1;
    player.x  = x-0.5 - vecx(player.dir);
    player.y  = y-1 - vecy(player.dir);
    //player.chat = "Your coords before they are set back are: ("@player.x@","@player.y@")";
    //player.x  = temp.oldx;
    //player.y  = temp.oldy;
  }
}
function onPlayerTouchsMe() {
  player.chat = "I magically touched the pullblock NPC";
}
NPCEND
NPC - 0 0
//#CLIENTSIDE
function onCreated() {
  onTimeOut();
}
function onTimeOut() {
  setTimer(0.05);
  temp.tx = player.x+1.5 + 0.9375*vecx(player.dir)-1;
  temp.ty = player.y+2   + 0.9375*vecy(player.dir)-1;
  temp.timg = showimg(1,"classic_pushblock.png",temp.tx,temp.ty);
  temp.timg.alpha = 0.9;
}
