function onPlayertouchsme() {
  if (findweapon("*Boomerang") != NULL) {
    if (client.spoketomorgan<2) {
      say2(this.boommessage);
      client.spoketomorgan = 2;
    } else say2(this.finalmessage);
  } else {
    if (client.spoketomorgan==1) {
      say2(this.locmessage);
    } else {
      say2(this.intromessage);
      client.spoketomorgan=1;
    }
  }
}
