NPC slayers_statuelight.png -1 0

function onPlayerchats()  {
if (player.chat == "/on") {
setcoloreffect(0,0,0,0);
}
if (player.chat == "/off") {
seteffect(0,0,0,0.6);
}
if (player.chat == "/here") {
x = player.x;
x -= 3;
y  = player.y;
y -= 7;
}
if (player.chat == "/up") {
y -= 0.25;
}
if (player.chat == "/down") {
y += 0.25;
}
if (player.chat == "/right") {
x += 0.25;
}
if (player.chat == "/left") {
x -= 0.25;
}
}

