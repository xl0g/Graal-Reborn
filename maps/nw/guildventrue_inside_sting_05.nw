//
//
//
if (playerenters) {
 hearts=0;			//the number of hearts the chicken starts with (-1 = infinate)
 this.immort=1;		//1=immortal
 timeout=.1;		//the delay before it "wakes up"
 this.stepspeed=.1;   	//the speed the it takes steps at
 this.stepdist=.5;	//the distance covered by each step
 this.power=0;		//number of half hearts it drains when it touches the player
 this.movdel=.3;		//the delay between movements
 this.moves=.5;		//the time moving btwn delays
}
//do not edit anything below this
//                            line!!
//-----------------------------------

if (playerenters) {this.del=0;this.mov=0;this.attacked=0; canbecarried;}

if (playertouchsme) {this.msg+=5;}
  if (this.msg>=15) this.msg=0;
{
    if (this.msg==5)message SQUEAK;
    if (this.msg==10)message SQUEAK!!!;
  }
  if (this.msg==15) message ;
  timeout=.4;
if (playertouchme) {this.attacked=1;
}
if (exploded || washit || wasshooted || waspelt) if (this.active>0){
 if (exploded) hearts-=playerbombpower;
 if (washit) hearts-=playerswordpower;
 if (wasshooted) hearts-=playershootpower;
 if (peltwithbush) hearts-=1;
 if (peltwithsign || peltwithvase || peltwithstone) hearts-=2;
 if (peltwithblackstone) hearts -=3;
 if (hearts>0 || this.immort=1) {
  if (x>playerx) {if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;if (!onwall(x+.5,y)) x=x+.5;};
  if (x<playerx) {if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;if (!onwall(x-.5,y)) x=x-.5;};
  if (y>playery) {if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;if (!onwall(x,y+.5)) y=y+.5;};
  if (y<playery) {if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;if (!onwall(x,y-.5)) y=y-.5;};
 }
 this.attacked=1;
}

if (timeout && this.active>0) {
 if (hearts<1 && !this.immort=1) {this.active=0;
  this.gift=0; //random(0,10);
  if (this.gift<=3) lay greenrupee;
  if (this.gift>3 && this.gift<=4) lay bluerupee;
  if (this.gift>4 && this.gift<=5) lay heart;
  if (this.gift>5 && this.gift<=6) lay heart;
  if (this.gift>6 && this.gift<=7) lay bombs;
  if (this.gift>7 && this.gift<=8) lay darts;
  hide;
 }
 if (hearts>0 || this.immort=1) {
  if (this.attacked=0) {
   if (this.del<=0){
    if (this.xmag>0) {setgif bat_flying.mng} else {setgif bat_flying.mng};
    if (!onwall(x+this.xmag+this.xmod,y+this.ymag+this.ymod)) {x=x+this.xmag; y=y+this.ymag};
    if (this.mov>=this.moves) {this.mov=0; this.del=this.movdel} else this.mov+=this.stepspeed;
   }else{
    this.del-=this.stepspeed;
    this.xmag=random(-1,1);
    this.ymag=random(-.6,.6);
    this.xmod=0; this.ymod=0;
    if (this.xmag>0) this.xmod=1.5;
    if (this.xmag<0) this.xmod=0;
    if (this.ymag>0) this.ymod=1.5;
    if (this.ymag<0) this.ymod=-.5;
   }
  }else{
   if (x>playerx && !onwall(x+this.stepdist+1.5,y)) {x=x+this.stepdist; setgif bat_flying.mng};
   if (x<playerx && !onwall(x-this.stepdist,y)) {x=x-this.stepdist; setgif bat_flying.mng};
   if (y>playery && !onwall(x,y+this.stepdist+1.5)) {y=y+this.stepdist};
   if (y<playery && !onwall(x,y-this.stepdist-.5)) {y=y-this.stepdist};
  }
 }
 timeout=this.stepspeed;
}

if (timeout && this.active<1) {
 if (hearts>0 || this.immort=1) {
  this.active=1;
  timeout=0.1;
  show;
 }
}
