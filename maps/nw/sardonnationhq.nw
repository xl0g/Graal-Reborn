NPC sardonprotect.png 22 31
// NPC made by <yourname>
if (playertouchsme) {
  say 4;
  toweapons Magic Deflect;
}
if(isweapon&&(playerenters||playerendsreading||timeout)){
  if(!strequals(#s(Nation),Sardon)){
    off();
    destroy;
  }
  if(magicshield){
    showimg 52,nukeblastring.png,playerx-2.5,playery-2;
    changeimgcolors 52,0.25,0,0.75,0.999999;
    changeimgvis 52,3;
    changeimgzoom 52,random(0.95,1.05);
    timeout=0.05;
  }else if(this.mshield>0){
    off();
  }
}

if(weaponfired){
  if(magicshield) off();
  else if(playermp>10){
    playermp-=10;
    set magicshield;
    this.mshield=1;
    timeout=0.05;
  }
}

function off(){
  unset magicshield;
  this.mshield=0;
  hideimg 52;
}
NPCEND
