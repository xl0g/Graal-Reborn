function onTimeOut() {
  setTimer(0.05);
  drawChain(35,x+1.5,y+2,playerx+1.5,playery+2);
}

function drawChain(links,x1,y1,x2,y2) {
  temp.angle = getangle(x2-x1,y2-y1);
  temp.dist  = getDistance(x2-x1,y2-y1);
  for (i=0; i < links; i++) {
    temp.showx = x1 + i/links * temp.dist*cos(temp.angle);
    temp.showy = y1 - i/links * temp.dist*sin(temp.angle);
    showimg(i,"wmace0.png",temp.showx,temp.showy);
  }
}
function getDistance(dx,dy) {
  return (dx^2+dy^2)^0.5;
}
NPCEND
