this.join("importantdates");

function onCreated(){
  this.setshape(1,32,32);
  this.dontblock();
}

function onActionBuyBalloon(temp.colour){
  player.client.bbd = false;
  if(player.clientr.stat_gelat < 50){
    say2("You don't have enough Gelat.");
    return;
  }
  if(player.clientr.stat_ballooncolour.size() >= 10){
    say2("You can't carry#bany more Balloons.");
    return;
  }
  player.clientr.stat_ballooncolour.add(temp.colour);
  player.clientr.stat_gelat -= 50;
  player.addweapon("Balloon");
  say2("Pleasure doing business with you.");
}

//#CLIENTSIDE
function onCreated(){
  this.showcharacter();
  this.head = "classichead-mrcarpainter.png";
  this.body = "bodyc-suit.png";
  this.shield = "no-shield.png";
  this.colors[0] = "orange";
  this.colors[1] = "lightblue";
  this.colors[2] = "white";
  this.colors[3] = "white";
  this.colors[4] = "black";
  this.dir = 2;
  this.colorlist = {"red","orange","yellow","green","blue","purple","magenta","indigo","black","white","cyan"};
  this.datelist = {
    {"Christmas","all"},
    {"the New Year","all"},
    {"Valentines Day", {"red", "magenta"}}
  };
}

function onPlayerenters(){
  this.currentdate = this.CheckDate();
  if(this.currentdate != NULL){
    for(temp.i = 0; temp.i < this.datelist.size(); temp.i ++){
      if(this.currentdate == this.datelist[temp.i][0]){
        if(!(this.canbuy)){
          this.Activate(this.datelist[temp.i][1]);
        }
        return;
      }
    }
  }
  if(this.visible){
    this.deActivate();
  }
}

function Activate(temp.colours){
  if(temp.colours == "all"){
    this.buyable = this.colorlist;
  }
  else{
    this.buyable = temp.colours;
  }
  this.canbuy = true;
  client.bbd = false;
  this.show();
  this.blockagain();
  this.attr[9] = "classic_playerballoon.gani";
  this.attr[8] = this.buyable[int(random(0, this.buyable.size()))];
}

function deActivate(){
  this.canbuy = false;
  this.buyable = false;
  this.dontblock();
  this.attr[9] = "";
  this.attr[8] = "";
  this.hide();
}

function onPlayertouchsme(){
  if(this.canbuy){
    this.dir = getdir(player.x - this.x, player.y - this.y);
    say2("Good day to you.#bAs a scientist I have been trying#bto master the power of flight.#bIt is an ambition of mine to circle#bthe world via a flying balloon,#beven greater, reach this planets#bmoon Lunaris.#bI'm rather short-funded,#bthe bank has refused me a loan.#bSo, with " @ this.currentdate @ "#bbeing a time of celebration I would#blike to offer you some balloons.#bI have plenty surplus to#brequirements, they're going cheap,#bi'm selling at 50 Gelat a piece.#bSay View List to see the colours#bI have available.#bSay Buy -Colour- Balloon#bin order to purchase.");
    this.onTimeout();
  }
}

function onTimeout(){
  if(player.reading){
    this.setTimer(0.05);
  }
  else{
    this.dir = 2;
  }
}

function onPlayerchats(){
  if(player.chat == "View List"){
    player.chat = "";
    temp.message = "The colours available are:";
    for(temp.i = 0; temp.i < this.buyable.size(); temp.i ++){
      temp.message @= "#b" @ this.buyable[temp.i];
    }
    say2(temp.message);
    return;
  }
  temp.tokens = player.chat.tokenize();
  if(temp.tokens[0] == "Buy" && temp.tokens[2] == "Balloon" && !(client.bbd)){
    player.chat = "";
    temp.colour = temp.tokens[1].lower();
    if(temp.colour in this.buyable){
      this.BuyBalloon(temp.colour);
    }
    else{
      say2("Sorry, i'm not selling balloons#bof that colour.");
    }
    return;
  }
}

function BuyBalloon(temp.colour){
  if(player.clientr.stat_gelat < 50){
    say2("You don't have enough Gelat.");
    return;
  }
  if(player.clientr.stat_ballooncolour.size() >= 10){
    say2("You can't carry#bany more Balloons.");
    return;
  }
  triggeraction(this.x + 1, this.y + 1, "BuyBalloon", temp.colour);
  player.client.bbd = true;
}
NPCEND
