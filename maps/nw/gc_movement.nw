function moveplayer() {
  wallcheck();
  playerx += this.dx + this.sx;
  playery += this.dy + this.sy;
}

function wallcheck() {
  if (player.dir % 2 == 1) {
    this.s_playerx = playerx + .5;
    this.s_playery = playery + 1;
    if (onwall2(this.s_playerx + (player.dir - 2) + (player.dir - 1) / 2,this.s_playery,1,1)) {
      this.sy += this.slide;
