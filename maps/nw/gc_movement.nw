      this.dx  = abs(int(this.s_playerx + this.dx) - (this.s_playerx + int(this.dx))) * (player.dir - 2);
    }
  } else if (player.dir % 2 == 0) {
    this.s_playerx = playerx + .5;
    this.s_playery = playery + 1;
    if (onwall2(this.s_playerx,this.s_playery + (player.dir - 1) + (player.dir) / 2,1,1)) {
      this.sx += this.slide;
    }
    if (onwall2(this.s_playerx + 1,this.s_playery + (player.dir - 1) + (player.dir) / 2,1,1)) {
      this.sx -= this.slide;
    }
    if (onwall2((this.slide + 2) * (abs(this.sx) / this.sx + 1) / 2 + this.s_playerx - this.slide,this.s_playery,abs(this.sx),2)) {
      this.sx  = int(this.s_playerx + this.sx) - (this.s_playerx + int(this.sx));
    }
    if (onwall2(this.s_playerx,(clientr.movement_speed + 2) * (player.dir) / 2 + this.s_playery - clientr.movement_speed,2,abs(this.dy))) {
      this.dy = abs(int(this.s_playery + this.dy) - (this.s_playery + int(this.dy))) * (player.dir - 1);
    }
  }
}

function move_diaganol() {
  if (this.dx + this.sx == 0 && this.dy + this.sy == 0) {
