if(playerenters) {
  drawaslight;
  dontblock;
  if(lighteffectsenabled) {
    this.numdots = 10;
    setcoloreffect 0.9,0,0,.28;
    setarray this.dots,this.numdots*6;
    showimg 5,wateranilava.mng,x,y;
    changeimgvis 0,3;
    changeimgcolors 10,0,0,0,.88;
  }
}
if(lighteffectsenabled) {
  if(playerenters || timeout) {
    timeout = 0.05;
    for(i=0;i<this.numdots;i++;) {
      if(this.dots[i*6+2] <= 0) {
        int();
      }
      showimg i,light2.png,x-3+this.dots[i*6]+sin(3.14/8*this.dots[i*6+2] + (3.14/2))*(this.dots[i*6+3]),y+cos(3.14/8*this.dots[i*6+2] + (3.14/2))*this.dots[i*6+5];
      changeimgzoom i,.25;
      changeimgcolors i,1,0,0,.99;
      changeimgvis i,3;

      this.dots[i*6+2] -= this.dots[i*6+4];
    }
    for(i=0;i<3;i++;) {
      showimg this.numdots+i,light2.png,x-4+(2*i),y+1;
      changeimgvis this.numdots+i,3;
      changeimgcolors this.numdots+i,1,1,1,.27;
      changeimgzoom this.numdots+i,random(1,1.2);
    }
  }
}
function int() {
  this.dots[i*6] = random(-.2,2.5);
  this.dots[i*6+1] = 0;
  this.dots[i*6+2] = 8;
  this.dots[i*6+3] = (int(random(-.4,1.4)) == 0? -1 : 1);
  this.dots[i*6+4] = random(.5,1);
  this.dots[i*6+5] = random(1,4);
}
if (created) {
  dontblock;
}
