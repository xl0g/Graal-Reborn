function onActionDig(tx,ty,tiles,dropitem){
  temp.tnpcs = findareanpcs(tx,ty,w,h);
  temp.placehole = true;
  for (temp.i=0;temp.i<temp.tnpcs.size();temp.i++) {
    temp.tnpcs.trigger("Dig",NULL);
    if ("dirthole" in temp.tnpcs[temp.i].joinedclasses)
      temp.placehole = false;
  }
  if (temp.placehole) {
    temp.obj = putnpc2(tx,ty,"join dirthole;");
    temp.obj.terrain = tiles;
    temp.obj.trigger("Activate",NULL);

    if(tx == x && ty == y && save[2] == 1){
      clientr.stat_gctickets += 1;
      pnpc.("gc_" @ this.hoster @ "_tick") -= 1;
      player.chat = "You got one ticket";
      this.winner = player.account;
      savelog2("gctix.txt",player.account @ " picked up ticket at " @ player.level @ " (" @ tx @ "," @ ty @ ")"@char(13));

      with(findplayer(this.hoster)){
        sendPM("Treasure Hunt was won by "@this.winner);
      }

        setimg("classic_gc_tikchest.png");
        blockagain();
        save[2] = 2;

      for (i=0;i<playerscount;i++) {
        players[i].client.playsnd = "chest.wav";
      }
      setTimer(5);
    }

    else{

      if(dropitem in <1,15>){
        putnpc2(tx,ty,"join gc_tool_mine;");
      }

      if(dropitem in <16,41>){
        temp.bomb = putnpc2(tx-0.5,ty-0.5,"join gc_horseitem_5;");
        temp.bomb.trigger("Activate",NULL);
      }

      if(dropitem in <42,47>){
        putnpc2(tx,ty,"join gc_tool_spring;");
      }

      if(dropitem in <48,58>){
        putnpc2(tx-1,ty-1,"join dropitem_smallheart;");
      }

      if(dropitem in <59,79>){
        putnpc2(tx-1,ty-1,"join dropitem_smallantiheart;");
      }

    }
  }
}
