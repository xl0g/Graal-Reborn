function onCreated(){
  setshape(1,32,32);
  dontblock();
  save[0] = x;
  save[1] = y;

}

function onPlayerchats(){


  if(player.guild == "Game Coordinator"){
    if(player.chat == "start"){
      pnpc = findnpc("Control-NPC");
      if(pnpc.("gc_" @ player.account @ "_tick") > 0){
        save[2] = 1;
        player.chat = "Chest Activated";
        this.hoster = player.account;
      }
      else{
        player.chat = "You do not have any tickets remaining!";
      }
    }
    if(player.chat == "stop"){
      save[2] = 0;
      player.chat = "Chest Deactivated";
    }
    if(player.chat == "start pk"){
      save[3] = 1;
      player.chat = "PKing Enabled";
    }
    if(player.chat == "stop pk"){
      save[3] = 0;
      player.chat = "PKing Disabled";
    }
  }
}


