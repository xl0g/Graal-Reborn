  colors[1] = "darkblue";
  colors[2] = "black";
  colors[3] = "blue";
  colors[4] = "blue";
  swordpower  = 1;
  shieldpower = 1;
  dir    = 2;
  ap     = 65;
  hearts = 0;
}
function onActionProgress() {
  flagsof = findplayer(params[0]);
  if (flagsof.clientr.quest_water[0] == 1) {
    flagsof.clientr.quest_water[0] = 2;
  }
}
//#CLIENTSIDE
function onCreated() {
  this.compIDs      = {0,0,0,0,0,0,0,0};
  this.compOrder    = {"SAM22","SAM16","SAM80","SAM13","SAM44","SAM32","SAM40","SAM11"};
  this.text_numbers = {"first","second","third","fourth","fifth","sixth","seventh","eighth"};
}

function onPlayerEnters() {
  if (clientr.quest_water[0] => 2) {
    this.compIDs = this.compOrder;
  }
}

function onPlayerTouchsMe() {
  if (clientr.quest_water[0] < 2) {
    say2("huh?!?#b#b#b.....Hello?#b#b#bWould you be willing to help?#b#b#bYou can help by telling me#bthe names of the SAMs.#b(Strangely Ancient Machines)#bI just need to know the order#bfrom which is blinking fastest#bto which is blinking slowest.#bThe Demon cast an evil spell on#bthem, and we can't open the#bwhirlpool portal until it's fixed!");
  } else say2("Wow! It's working!");
}

function onPlayerChats() {
  if (player.y < 19 && player.x in |21.5,39.5| && clientr.quest_water[0] < 2) {
    if (player.chat.starts("SAM") && player.chat.length() <= 6) {
      for (i=0; i<8; i++) {
        if (this.compIDs[i] == 0) {
          this.compIDs[i] = player.chat;
          say2("So you say " @ player.chat @ " is the" @ "#b" @
                this.text_numbers[i] @ " one?");
          break;
        }
      }
    }
    if (this.compIDs[7] != 0) checkForRightAnswer();
  }
}

function checkForRightAnswer() {
  say2("Okay, let's see if this is right");
  this.checking = 1;
}

//if (this.compIDs == this.compOrder) returned false for unknown reasons.
//SO, I made this function
function arrequals(arr1,arr2) {
  for (i=0;i<arr1.size();i++) {
    if (arr1[i]!=arr2[i]) {
      return 0;
    }
  }
  return 1;
}

function onPlayerEndsReading() {
  if (this.checking == 1) {
    if (arrequals(this.compIDs,this.compOrder)) {
      say2("Wow! It's working!");
      if (clientr.quest_water[0] < 2) {
        triggeraction(x+1,y+1,"progress",player.account);
      }
    } else {
      say2("Nope!! So let's try again!");
      this.compIDs = {0,0,0,0,0,0,0,0};
    }
  }
  this.checking = 0;
}

