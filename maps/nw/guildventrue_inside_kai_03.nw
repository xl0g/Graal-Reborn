  hurtdy = 0;
  hearts = 3;
}
if (playerenters || wasthrown) {
  // Initialize the this. variables
  timeout = 0.05;
  if (hearts<=0) {
    this.mode = 5; // RESPAWN
    this.runcounter = 0;
    timeout = 5;
  } else {
    this.mode = 0;
    setcharani idle,;
    this.runcounter = int(random(10,40));
  }
}

// Hurting stuff
if (washit && this.mode!=1 && hearts>0) {
  dx = x-playerx;
  dy = y-playery;
  len = (dx*dx+dy*dy)^0.5;
  hurtdx = dx/len;
  hurtdy = dy/len;
  setcharani hurt,;
  hideimg 1;
  hearts -= playerswordpower/2;
}
if ((hurtdx!=0 || hurtdy!=0) && isleader && this.mode!=4) {
  this.hurtdx = hurtdx;
  this.hurtdy = hurtdy;
  hurtdx = 0;
  hurtdy = 0;
  if (hearts<=0) {
    this.mode = 4; // DYING
    message;
    setcharani dead,;
    timeout = 1.2;
  } else {
    this.mode = 1; // HURTED
    this.runcounter = 20;
    setcharani hurt,;
    timeout = 0.05;
  }
}
