//this.color = int(random(1,4));
if (this.color = 1){
setcoloreffect(1,0,0,.9);
}
if (this.color = 2){
setcoloreffect(0,1,0,.9);
}
if (this.color = 3){
setcoloreffect(0,0,1,.9);
}
drawoverplayer();
settimer(.05);
}



function onTimeout(){
this.a = random(1,10050);
this.b = random(1,1100);
x = x + cos(this.y);
if (this.x > 63){
this.x = 1;
}
if (this.x < 1){
this.x = 50;
}
if (this.y < 1){
this.y = 50;
}
if (this.y > 63){
this.y = 1;
}
settimer(.05);
}

function onPlayertouchsme(){
player.y = 41;
}
NPCEND
