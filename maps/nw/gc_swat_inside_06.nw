function DisplayTime() {
  this.mins = int(this.bombtime / 60);
  this.secs = int(this.bombtime % 60);
  if (this.secs < 10){
    chat = this.mins @ ":0" @ this.secs;
    serverr.gc_swat_stats.replace(0,this.mins @ ":0" @ this.secs);
  }
  else {
    chat = this.mins @ ":" @ this.secs;
    serverr.gc_swat_stats.replace(0,this.mins @ ":" @ this.secs);
  }
}

function onCreated() {
  setimg("classic_gc_swatbomb.mng");
}

function onPlayerTouchsMe() {
  if (player.guild != "Game Coordinator") return(0);
  say2("Commands:
  #bset password <num>
    #bstart <time>
      #bstop
        #bpause
          #bresume
            #bTo remove, right click me");
}

function onPlayerChats() {
  if (this.active == true && serverr.gc_swatbalanced == "true" && this.password.length() > 0 && player.chat == this.password && player.x in |x-5,x+7| && player.y in |y-5,y+6| && !(client.hd_isdead)) {
    chat = "Bomb disarmed by " @ player.nick @ ", SWAT team wins!";
    this.password = "";
    this.paused = true;
    this.active = false;
    for (pobj: allplayers) {
      if (pobj.level.starts("gc_swat_")) {
        player.fullheal();
        if (pobj.guild == "Game Coordinator") {
          pobj.chat := "SWAT Win!";
          pobj.setlevel2("gc_swat_entrance.nw",34,30.5);
        }
        elseif (pobj.guild == "SWAT") {
          pobj.chat := "SWAT Win!";
          pobj.setlevel2("gc_swat_entrance.nw",34,30.5);
        }
        else {
          pobj.chat := "SWAT Win!";
          pobj.setlevel2("gc_swat_entrance.nw",24,30.5);
        }
      }
    }
  }

  if (player.guild != "Game Coordinator") return(0);

  chatparams = player.chat.tokenize();

  if (player.chat.starts("set password")) {
    if (chatparams[2] in |1,500|) {
      this.password = chatparams[2];
      player.chat = "";
      say2("Password set to: " @ chatparams[2]);
    }
    else say2("Invalid password.#bPasswords must be from 1 to 500.");
  }
  elseif (player.chat.starts("start")) {
    if (this.password.length() == 0) {
      say2("Please set password first!");
      return(0);
    }
    if (chatparams[2].length() == 0) this.bombtime = chatparams[1];
    else this.bombtime = chatparams[1] * 60 + chatparams[2];
    if (this.bombtime == 0)
      this.bombtime = 300;
    DisplayTime();
    this.explosions = 61;
    this.paused = false;
    this.active = true;
    setTimer(1);
  }
  elseif (player.chat == "stop") {
    chat = "";
    this.active = false;
    this.password = "";
  }
  elseif (player.chat == "pause") this.paused = true;
  elseif (player.chat == "resume" && this.password.length() > 0) this.paused = false;
}

function onTimeout() {
  if (this.active == true && this.paused != true && serverr.gc_swatbalanced == "true") {
    if (this.bombtime > 0) {
      this.bombtime--;
      DisplayTime();
      setTimer(1);
      return(0);
    }
    for (pobj: allplayers) {
      if (pobj.level.starts("gc_swat_")) {
        player.fullheal();
        pobj.chat := "Noone Wins!";
        pobj.setlevel2("gc_gc_01.nw",31.5,32);
      }
    }
    if (this.explosions > 0) {
      this.explosions--;
      putexplosion2(random(1,4),7,random(x-15,x+16),random(y-15,y+16));
    }
    else this.active == false;
    setTimer(0.05);
  }
  elseif (this.paused == true || serverr.gc_swatbalanced == "false") setTimer(1);
}
function clearteam(plrobj){
  plrobj.guild="";
  this.tempc=plrobj.attr[15];
  plrobj.colors[0] = this.tempc[0];
  plrobj.colors[1] = this.tempc[1];
  plrobj.colors[2] = this.tempc[2];
  plrobj.colors[3] = this.tempc[3];
  plrobj.colors[4] = this.tempc[4];
  plrobj.head = this.tempc[5];
  plrobj.shield = this.tempc[6];
  plrobj.body = this.tempc[7];
  this.tempc=0;
  plrobj.attr[15]=0;
}
