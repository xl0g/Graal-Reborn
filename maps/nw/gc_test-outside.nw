}
if (timeout){
  if (this.scroll_timer < 0){
    showtext 200,x + (this.scroll_width - (this.scroll_width + this.scroll_timer))/16,y,tempus sans itc,bi,GC Studios;
    changeimgpart 200,0,0,this.scroll_width + this.scroll_timer,this.scroll_height;
  }
  else {
    showtext 200,x,y,#s(setarray this.scroll_font),bi,GC Studios;
    changeimgpart 200,this.scroll_timer,0,this.scroll_width,this.scroll_height;
  }
  changeimgvis 200,3;
  changeimgcolors 200,this.scroll_red,this.scroll_green,this.scroll_blue,this.scroll_alpha;
  changeimgzoom 200,this.scroll_zoom;
  this.scroll_timer += this.scroll_speed;
  if (this.scroll_timer > (this.scroll_maxlength + this.scroll_width)){
    this.scroll_timer = 0 - this.scroll_width + 1;
  }
  timeout = 0.05;
}
