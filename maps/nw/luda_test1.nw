//#CLIENTSIDE
function onPlayerEnters() {
  this.sx = this.x;
  this.sy = this.y;
  this.ex = this.x+4;
  this.ey = this.y+4;
  this.moved = 0;
}

function onPlayerChats() {
  if(!this.moved && player.chat == "password") {
     this.moved = 1;
     onTimeout();
  }
}

function onTimeout() {
  this.x += .2;
  if(this.x < this.ex)
    setTimer(.05);
}
