//#CLIENTSIDE
function onPlayerEnters(){
  this.focus = 0;
}
if (playerdies) {
  this.focus = 0;
  resetfocus;
}

function onPlayerChats(){
  if (player.chat == "focus on" || player.chat == "focus") {
    if (this.focus == 0) {
      this.focus = 1;
      this.currfocus = {player.x, player.y};
      settimer(.05);
    }
  }
  else if (player.chat == "focus off" || player.chat == "done") {
    if (this.focus == 1) {
      this.focus = 0;
      this.currfocus = {30.5, 26.5};
      settimer(.05);
    }
  }
}
function onTimeout(){
  if (this.focus == 1) {
    this.xdis = (30.5 - this.currfocus[0]) / 10;
    this.ydis = (26.5 - this.currfocus[1]) / 10;

    if (abs(this.xdis) + abs(this.ydis) > .01){
      this.currfocus = {this.currfocus[0] + this.xdis, this.currfocus[1] + this.ydis};
      setfocus(this.currfocus[0],this.currfocus[1]);
    }
    else
      setfocus(30.5,26.5);

    if (clientr.hd_isdead == true  || client.hd_isdead == 1) {
      resetfocus;
      this.focus = 0;
    }
    settimer(.05);
  }
  else {
    this.xdis = (player.x - this.currfocus[0]) / 10;
    this.ydis = (player.y - this.currfocus[1]) / 10;

    if (abs(this.xdis) + abs(this.ydis) > .01){
      this.currfocus = {this.currfocus[0] + this.xdis, this.currfocus[1] + this.ydis};
      setfocus(this.currfocus[0],this.currfocus[1]);
      settimer(.05);
    }
    else
      resetfocus;
  }
}
