// NPC made by CheeToS
function onCreated(){
  setshape(1,32,32);
  this.queue = "";
  this.playerone = "";
  this.playertwo = "";
  this.started = false;
  this.kicktime = 60;
  this.adddelay = -1;
  this.streaker = "";
  this.streak = 0;
  setTimer(.1);
}

function onPlayerEnters(){
  if (players.size() == 1)
    setTimer(.1);
}

function onActionremove(params){
  if (!this.started){
    if (params[0] == this.playerone || params[0] == this.playertwo){
      with (findplayerbycommunityname(this.playerone))
        client.exoduskick = -1;
      with (findplayerbycommunityname(this.playertwo))
        client.exoduskick = -1;
      with (findplayerbycommunityname(params[0])){
        player.x = 30.5;
        player.y = 44;
      }
    }
  }
}

function onActiondead(params){
  if (params[0] != this.playerone){
    if (this.streaker != this.playerone){
      this.streaker = this.playerone;
      this.streak = 0;
      with (findplayerbycommunityname(this.playerone))
        player.fullheal2();
    }
  }
  else if (this.streaker != this.playertwo) {
    this.streaker = this.playertwo;
    this.streak = 0;
      with (findplayerbycommunityname(this.playertwo))
        player.fullheal2();
  }

  this.streak++;
}

function onPlayerChats(){
  if (player.chat == "join spar" || player.chat == "/join spar"
    || player.chat == "join queue" || player.chat == "I call winner") {
    if (this.playerone.length() == 0 && this.queue.size() == 0){
      if (player.communityname != this.playertwo) {
        this.playerone = player.communityname;
        addSparPlayer(player.communityname);
        if (this.playertwo.length() != 0){
          client.exoduskick = this.kicktime;
          with (findplayerbycommunityname(this.playertwo))
            client.exoduskick = this.kicktime + 10;
        }
      }
    }
    else if (this.playertwo.length() == 0  && this.queue.size() == 0){
      if (player.communityname != this.playerone) {
        this.playertwo = player.communityname;
        addSparPlayer(player.communityname);
        if (this.playerone.length() != 0){
          client.exoduskick = this.kicktime;
          with (findplayerbycommunityname(this.playerone))
            client.exoduskick = this.kicktime + 10;
        }
      }
    }
    else if (player.communityname != this.playerone && player.communityname != this.playertwo){
      if (this.queue.index(player.communityname) < 0) {
         this.queue.add(player.communityname);
         player.chat = "(Added you to the queue!)";
      }
      else
        player.chat = "(You're already in the queue!)";
    }
  }
  else if (player.chat == "done" || player.chat == "leave spar"
    || player.chat == "/leave spar" || player.chat == "exit spar") {
    if (!this.started){
      if (player.communityname == this.playerone || player.communityname == this.playertwo){
        player.x = 30.5;
        player.y = 44;
      }
    }
  }
  else if (player.chat == "leave queue" || player.chat == "/leave queue") {
    this.queue.remove(player.communityname);
    player.chat = "(Removed you from the queue!)";
  }
  else if (player.chat == "heal") {
    if (!this.started)
      healPlayer(player.communityname);
  }
  else if (player.chat == "show queue" || player.chat == "view spar queue"
    || player.chat == "view line" || player.chat == "/view spar queue"
    || player.chat == "/view line" || player.chat == "view queue") {
    displayQueue();
  }
  else if (player.chat == "start"){
    if (!this.started) {
      temp.yescount = 0;
      if (this.playerone.length() > 0 && this.playertwo.length() > 0){
        with (findplayerbycommunityname(this.playerone)){
          if (player.chat == "start"){
            temp.yescount++;
            player.fullheal2();
          }
        }

        with (findplayerbycommunityname(this.playertwo)){
          if (player.chat == "start"){
            temp.yescount++;
            player.fullheal2();
          }
        }

        if (temp.yescount == 2){
          this.started = true;

          health_p1 = findplayerbycommunityname(this.playerone).clientr.stat_hp;
          health_p2 = findplayerbycommunityname(this.playertwo).clientr.stat_hp;
          health_optimal = min(health_p1, health_p2);

          with (findplayerbycommunityname(this.playerone)){
            client._handlesword = 3;
            client.exoduskick = -1;
            player.SetHealth(health_optimal);
          }
          with (findplayerbycommunityname(this.playertwo)){
            client._handlesword = 3;
            client.exoduskick = -1;
            player.SetHealth(health_optimal);
          }
          //WHAT putexplosion(1,31,28);
          temp.bomb = putnpc2(30.5,26.5,"join spar_bomb;");
    temp.bomb.trigger("Activate",NULL);
        }
      }
    }
  }
  else if (player.chat == "stop"){
    if (this.playerone.length() > 0 && this.playertwo.length() > 0){
        with (findplayerbycommunityname(this.playerone))
          if (player.chat == "stop")
            temp.yescount++;
        with (findplayerbycommunityname(this.playertwo))
          if (player.chat == "stop")
            temp.yescount++;

        if (temp.yescount == 2){
          this.started = false;

          with (findplayerbycommunityname(this.playerone))
            player.chat = "(Spar stopped!)";
          with (findplayerbycommunityname(this.playertwo))
            player.chat = "(Spar stopped!)";
        }
    }
  }
}

function displayQueue(){
  if (this.queue.size() > 0) {
    temp.signlist = "Spar Queue:#b";
    temp.heads = new[this.queue.size()];
    for (this.i = 0; this.i < players.size(); this.i++){
      temp.lindex = this.queue.index(players[this.i].communityname);
      if (temp.lindex >= 0)
        temp.heads[temp.lindex] = players[this.i].headimg;
    }

    for (this.i = 0; this.i < temp.heads.size(); this.i++)
      if (temp.heads[this.i] == 0)
        temp.heads[this.i] = "head0.png";

    for (this.i = 0; this.i < this.queue.size(); this.i++){
      temp.signlist @= this.i+1 @ ". #i(" @ temp.heads[this.i] @ ",0,64,32,32) " @ this.queue[this.i] @ "#b";
    }
  }
  else
    temp.signlist = "The queue is empty.#bType 'join spar' to join!";
  say2(temp.signlist);
}

function addSparPlayer(temp.accName){
  temp.success = false;

  with (findplayerbycommunityname(temp.accName)){
    if (player.level == this.level){
      player.x = 30;
      player.y = 30;
      healPlayer(player.communityname);
      temp.success = true;
    }
  }
  return temp.success;
}

function addNewPlayers(){
  if (this.playerone.length() == 0 || this.playertwo.length() == 0){
    if (this.adddelay == -1)
      this.adddelay = 3;
    if (this.adddelay >= 0)
      this.adddelay--;
    if (this.adddelay == 0) {
      while (this.queue.size() > 0 && this.playerone.length() == 0) {
        this.playerone = this.queue[0];
        this.queue.delete(0);
        if (addSparPlayer(this.playerone) == false)
          this.playerone = "";
        else if (this.playertwo.length() != 0)
          with (findplayerbycommunityname(this.playerone))
            client.exoduskick = this.kicktime;
          with (findplayerbycommunityname(this.playertwo))
            client.exoduskick = this.kicktime + 1;
      }

      while (this.queue.size() > 0 && this.playertwo.length() == 0) {
        this.playertwo = this.queue[0];
        this.queue.delete(0);
        if (addSparPlayer(this.playertwo) == false)
          this.playertwo = "";
        else if (this.playerone.length() != 0){
          with (findplayerbycommunityname(this.playertwo))
            client.exoduskick = this.kicktime;
          with (findplayerbycommunityname(this.playerone))
            client.exoduskick = this.kicktime + 10;
        }
      }
    }
  }
}

function healPlayer(temp.acc) {
  with (temp.acc) {
    player.fullheal2();
    player.chat = "(Healed)";
  }
}
function onTimeout(){
  temp.found = {false, false};

  if (this.playerone.length() == 0)
    temp.found[0] = true;
  if (this.playertwo.length() == 0)
    temp.found[1] = true;

  for (p: players){
    if (!(p.x in |18.5,42.5|) || !(p.y in |19,35|)){
      if (p.communityname == this.playerone)
        this.playerone = "";
      else if (p.communityname == this.playertwo)
        this.playertwo = "";
    }

    else if (p.communityname == this.playerone){
      if (!p.isobserver)
        temp.found[0] = true;
    }
    else if (p.communityname == this.playertwo){
      if (!p.isobserver)
        temp.found[1] = true;
    }
    else {
      p.x = 30.5;
      p.y = 44;
    }
  }

  if (temp.found[0] == false)
    this.playerone = "";
  if (temp.found[1] == false)
    this.playertwo = "";

  if (this.playerone.length() == 0 || this.playertwo.length() == 0){
    this.started = false;
  }

  if (this.playerone.length() > 0 && this.playertwo.length() > 0)
    temp.chatmsg = this.playerone @ " vs. " @ this.playertwo;

  else if (this.playerone.length() > 0)
    temp.chatmsg = this.playerone @ " wants to fight!";

  else if (this.playertwo.length() > 0)
    temp.chatmsg = this.playertwo @ " wants to fight!";
  else
    temp.chatmsg = "Welcome to Exodus' Spar Area!";

  this.attr[2] = temp.chatmsg;

  if (this.streaker.length() == 0)
    this.attr[1] = "Noone is on a streak!";
  else
    this.attr[1] = this.streaker @ "'s streak:" SPC this.streak SPC "spar(s)";

  addNewPlayers();

  if (!this.started){
    if (this.playerone.length() > 0) {
      with (findplayerbycommunityname(this.playerone))
        client._handlesword = 1.1;
    }
    if (this.playertwo.length() > 0) {
      with (findplayerbycommunityname(this.playertwo))
        client._handlesword = 1.1;
    }
  }
  if (players.size() > 0)
    setTimer(1);
}
