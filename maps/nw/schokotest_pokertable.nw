  this.h   = 4;
  this.doorcolor_init  = 1;
  this.doorcolor_loss  = 0.1;
  this.doorcolor_min   = 0.1;
  this.speed_open  = .1;
  this.speed_close = .3;
  this.close_pause = 1;
  this.open_dir    = 1;

  finished_opening = false;

  setshape(1,this.w*16,this.h*16);
  this.init_x      = x;
  this.init_y      = y;
