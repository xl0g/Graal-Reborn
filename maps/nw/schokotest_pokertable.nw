  chat = "Roll, roll, roll in the hay!";

  if (random(0,1000) <1)
    roll_dir = 0 - roll_dir;

  walk_angle = walk_angle + roll_dir * .39;
  x = centerx + cos(walk_angle);
  y = centery + sin(walk_angle);
  dir = getdir(cos(walk_angle), sin(walk_angle));

}
