  changeimgvis(200,0);
}

function onPlayerTouchsMe() {

  if (client.schokomagickey == 1) {

    if (this.opening == 0) {
      this.show_x   = this.init_x;
      this.show_y   = this.init_y;
      this.show_ptx = this.ptx;
      this.show_pty = this.pty;
      this.show_w   = this.w;
      this.show_h   = this.h;
      this.show_doorcolor = this.doorcolor_init;
