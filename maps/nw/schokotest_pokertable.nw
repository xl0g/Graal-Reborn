function onTimeOut() {
  if (this.opening == 1) {

    player.y -= .1;
    finished_opening = false;

    if (this.show_doorcolor > this.doorcolor_min) {
      this.show_doorcolor -= this.doorcolor_loss * this.speed_open * 10;
    } else {
      this.show_doorcolor = this.doorcolor_min;
    }
    this.show_x   += this.speed_open * abs(vecx(this.open_dir)) * (this.open_dir-1)/2;
    this.show_y   += this.speed_open * abs(vecy(this.open_dir)) * (this.open_dir)/2;
    this.show_ptx += this.speed_open * abs(vecx(this.open_dir)) * (3-this.open_dir)/2 * 16;
    this.show_pty += this.speed_open * abs(vecy(this.open_dir)) * (2-this.open_dir)/2 * 16;
    this.show_w   -= this.speed_open * abs(vecx(this.open_dir));
    this.show_h   -= this.speed_open * abs(vecy(this.open_dir));
    x = this.show_x;
    y = this.show_y;
    setshape(1,this.show_w*16,this.show_h*16);
    if (this.show_w > 0 && this.show_h > 0) {
      showimg(200,this.img,this.show_x,this.show_y);
      changeimgpart(200,this.show_ptx,this.show_pty,this.show_w*16,this.show_h*16);
      changeimgcolors(200,this.show_doorcolor,this.show_doorcolor,this.show_doorcolor,1);
      changeimgvis(200,0);
      setTimer(0.05);
    } else {
      hideimg(200);
      this.show_x   -= this.speed_open * abs(vecx(this.open_dir)) * (this.open_dir-1)/2;
      this.show_y   -= this.speed_open * abs(vecy(this.open_dir)) * (this.open_dir)/2;
      this.show_ptx -= this.speed_open * abs(vecx(this.open_dir)) * (3-this.open_dir)/2 * 16;
      this.show_pty -= this.speed_open * abs(vecy(this.open_dir)) * (2-this.open_dir)/2 * 16;
      this.show_w   += this.speed_open * abs(vecx(this.open_dir));
      this.show_h   += this.speed_open * abs(vecy(this.open_dir));
      this.opening = 2;
      setTimer(this.close_pause);
    }
  } else {

    if (finished_opening == false) {
      finished_opening = true;
      triggeraction(this.init_x+1,this.init_y+1,"WarpPlayer",null);
    }

    if (this.show_doorcolor < this.doorcolor_init) {
