    this.show_pty -= this.speed_close * abs(vecy(this.open_dir)) * (2-this.open_dir)/2 * 16;
    this.show_w   += this.speed_close * abs(vecx(this.open_dir));
    this.show_h   += this.speed_close * abs(vecy(this.open_dir));
    x = this.show_x;
    y = this.show_y;
    setshape(1,this.show_w*16,this.show_h*16);
    if (this.show_w < this.w || this.show_h < this.h) {
      showimg(200,this.img,this.show_x,this.show_y);
      changeimgpart(200,this.show_ptx,this.show_pty,this.show_w*16,this.show_h*16);
      changeimgcolors(200,this.show_doorcolor,this.show_doorcolor,this.show_doorcolor,1);
