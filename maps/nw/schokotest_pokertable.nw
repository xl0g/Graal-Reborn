function onCreated() {

  change_counter = 10;

  phases = {"follow","play","bounceplay","bounce","roll","sit","dead"};
  phase = 0;

  walk_angle = 0;

  nick = "Pet Rock   ";
  ap = 100;

  color_changed = 0;
  color = 1;

  waveyz = 0;

  onTimeout();
}

function onTimeout() {
  setTimer(0.05);

  if (player.chat.starts("Rock") || player.chat.starts("Pet rock") || player.chat.starts("rock") || player.chat.starts("Pet Rock")) {

    if (phase != 5 && player.chat.ends("sit")) {
      phase = 5;
      change_counter = random(3,5);
    }
    if (phase != 6 && player.chat.ends("play dead")) {
      phase = 6;
      change_counter = random(3,5);
    }
    if (phase != 0 && player.chat.ends("come") || player.chat.ends("follow") || player.chat.ends("follow me")) {
      phase = 0;
      change_counter = random(5,7);
    }
    if (phase != 1 && player.chat.ends("go play")) {
      phase = 1;
      change_counter = random(10,12);
    }
    if (phase != 3 && player.chat.ends("bounce") || player.chat.ends("jump")) {
      phase = 3;
      change_counter = random(3,5);
    }
    if (phase != 4 && player.chat.ends("roll") || player.chat.ends("roll over")) {
      phase = 4;
      centerx = x-1;
      centery = y;
      walk_angle = 0;
      i = 0;
      change_counter = random(5,7);
    }
    if (phase != 2 && player.chat.ends("bounce around")) {
      phase = 2;
      change_counter = random(7,12);
    }
    if (color_changed != 1 && (player.chat.ends("change color") || player.chat.ends("dress up") || player.chat.ends("color change"))) {
      color = 3 - color;
      setimg("classic_rock_" @ color @ ".png");
      color_changed = 1;
    }
  }
  if (color_changed == 1 && !(player.chat.ends("change color") || player.chat.ends("dress up") || player.chat.ends("color change"))) {
      color_changed = 0;
  }
  if (change_counter == 0) {
    change_counter = int(random(3,10));

    z = 0;

    phase = int(random(0,4));
  }

  this.("" @ phases[phase])();

  change_counter -= 0.05;

}

// Follow player
function follow() {

  chat = "Following master!";


  if (abs(player.x - x) + abs(player.y - y) > 5) {

    temp.angle = -getangle(player.x - x, player.y - y);
    dx = random(.3,.8) * cos(temp.angle);
    dy = random(.3,.8) * sin(temp.angle);
    dir = getdir(player.x - x, player.y - y);

    moveXY(dx,dy,this);
  }

}

function play() {

  chat = "La, la, la!";

  if (random(1,10) > 8) {
    walk_angle = random(-6.28,6.28);
  }
  else {
    walk_angle = random(walk_angle-.39,walk_angle+.39);
  }

  dx = random(.3,.8) * cos(walk_angle);
  dy = random(.3,.8) * sin(walk_angle);
  dir = getdir(cos(walk_angle),sin(walk_angle));

  moveXY(dx,dy,this);
}

function sit() {
  chat = "Sit, sit, sit.";
}

function dead() {
  chat = "oh, oh, I'm shot!";
}

function bounce() {
  chat = "Boingy boingy!";
  waveyz += .5;
  z = 1 + sin(waveyz);
  if (waveyz = 6.28) {
    waveyz = -6.28;
  }
}

