function onPlayerChats(){

  tokens = player.chat.tokenize();
  if (tokens[0] == "/rent") {
    if (tokens[1] in |1,4|) {

      if (serverr.("redlampinn_"@tokens[1]) == 0) {

        if(player.clientr.dcinntime > timevar2){
          say2("You have already rented a room!");
        }
        else{

          if (player.clientr.stat_gelat >= 50) {
            player.clientr.stat_gelat -= 50;
            player.clientr.dcinntime = timevar2+600;
            serverr.("redlampinn_"@tokens[1]) = {player.account,timevar2+600};
            say2("Enjoy your stay!");
          }

          else {
            say2("Sorry, you don't have enough gelat.");
          }
        }

      }

      else{
        say2("Sorry, that room is taken.");
      }

    }
  }
}

