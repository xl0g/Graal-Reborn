NPC - 42 0
function onCreated() {
  setshape(1,32,32);
  this.override = {"Mighty","Delija","Zew2k","xnervNATx"};
}

function onPlayerChats() {

  if (player.account in this.override) {
    switch (player.chat) {
      case "unlock":
      hide();
      break;
      case "lock":
      show();
      break;
    }
  }

}


function onActionWarp(){
  this.attr[1] = player;
  setTimer(5);
}

function onTimeout(){
  findplayer(this.attr[1]).setlevel2(level,x+0.5,y+5);
}


function onPlayerTouchsMe() {
  if (player.account in this.override) {
    hide();
    sleep(.4);
    show();
  }
}
//#CLIENTSIDE
function onPlayerLogin(pobj) {
  if(player.x in <x-6,x+10> && player.y in <y-5,y+10>)
    triggeraction(x+1,y+1,"warp","");
}

function onPlayerchats(){
  if(player.chat == "reconnect me" && player.x in <x-1,x+5> && player.y in <y,y+6>){
    triggeraction(x+1,y+1,"warp","");
    player.x = x+0.5;
    movement_handlekeys = 3;
    movement_handlemoving = 3;
    player.y = y+5;
  }
}

function onCreated() {
  setshape(1,32,32);
}
NPCEND
