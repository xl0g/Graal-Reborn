NPC - 30 35
function onPlayerchats() {
  if (player.chat == "start" && level.sparring == 0) {
    level.sparring = 1;
    for (this.i = 3; this.i != 0; this.i--) {
      chat = this.i;
      sleep(1);
    }
    chat = "Begin!";
    putexplosion 1,x-1,y;
    settimer(0.5);
  }
  else if (player.chat == "stop" && level.sparring == 1) {
    level.sparring = 0;
    chat = "Spar Ended.";
    settimer(1);
  }
}
function onTimeout() {
  chat = "";
