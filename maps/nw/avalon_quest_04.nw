// NPC made by Schoko Raven (LAT)
//#CLIENTSIDE
function onPlayerEnters() {

  if (player.y == 0) {
    if (player.x == 42) {
      newcoords[0] = 42.5;
      newcoords[1] = 32;
    }
    if (player.x == 20) {
      newcoords = getCoords();
    }

    player.chat = "" @ newcoords[0] @ "," @ newcoords[1];

    player.dir = 2;
    setani("carrystill",null);
    player.x = newcoords[0];
    moving = true;

    onTimeout();

  }

}

function onTimeout() {

  setTimer(0.05);

  if (moving == true) {
    if (player.y < newcoords[1]) {
      player.y += .8;
    }
    else {
      moving = false;
    }
  }
}

function getCoords() {

  temp.coords = new[8];

  temp.coords[0] = {22,44};
  temp.coords[1] = {18,31};
  temp.coords[2] = {44,24};
  temp.coords[3] = {49,44};
  temp.coords[4] = {24,42};
  temp.coords[5] = {29,38};
  temp.coords[6] = {17,29};
  temp.coords[7] = {27,35};

  return temp.coords[int(random(0,8))];
}
