  this.allowed = {"ffcmike","fa12","Kill","xnervNATx","HyperTails","darkhunter1312","Relapse2007","Crystal","Crystal111","Suruku","Jacknick","1death","Evilchaseofdoom","Graal687389","CCZCOOL","Zeeek","ShockwaveISTHEBEST"};
