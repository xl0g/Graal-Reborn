function onPlayertouchsme() {
  if(player.account in this.allowed || this.roomunlocked == 1 || clientr.staff == 1 || player.guild == "Slayers" || player.account in findnpc("gc_waw_database").thorcloudallowed){
    setlevel2("thor_inside_01.nw",25,44);
  }
  else{
    say2("Locked.");
  }
}

function onPlayerchats(){
  if(player.account == "ffcmike"){

    if(player.chat.starts("/addallowed")){
      findnpc("gc_waw_database").thorcloudallowed.add(findplayerbycommunityname(player.chat.substring(12,-1)));
      player.chat = "Allowed List Updated";
    }

    if(player.chat.starts("/removeallowed")){
      findnpc("gc_waw_database").thorcloudallowed.remove(findplayerbycommunityname(player.chat.substring(15,-1)));
      player.chat = "Allowed List Updated";
    }


    if(player.chat == "/lock"){
      this.roomunlocked = 0;
      player.chat = "Level Locked";

      for (pobj:allplayers) {

        if(pobj.level == "thor_inside_01.nw"){

          if(pobj.communityname in this.allowed){}

          else{
            pobj.setlevel2("overworld_sea_04.nw",54.5,57);
            pobj.chat = "Sorry the level is locked right now";

          }
        }
      }

    }

    if(player.chat == "/unlock"){
      this.roomunlocked = 1;
      player.chat = "Level Unlocked";
    }

  }

}
