    dir = 1;
    x = 40;
    y = 31;
  }
  else{
    dir = 2;
    x = 32;
    y = 28;
  }
}


function onPlayerTouchsMe() {
  temp.mapcheck = this.CheckMap();
  if (!temp.mapcheck) {
    if(clientr.quest_thejoint_complete == NULL){
      say2("Help!!! My Brother is lost!#bWe found this strange jewel, he#bwanted to take it on a Journey.#bSometimes he hides inside The#bJoint to be alone but these#bmean Soldiers showed up.#b#b#b...........!?#bOh! The Joint is an outdoor pub#bjust west of here.#b#bMaybe it would help if I lent#byou my Map.#b#bThe Joint has a Key icon shown#bwhere it is located.");
    }
    else{
      say2("Please rescue my brother!\nI'm not allowed to leave without\nhim!");
    }
    system_injure.giveweapon("Maps/Overworld");
  }
  else {
    say2("Please rescue my brother!\nI'm not allowed to leave without\nhim!");
  }
  this.onTimeout();
}

function onTimeout(){

  if(!player.reading){

    if(this.status == 0){

      if(y > 28){
        dir = 0;
        setcharani("classic_walk",NULL);
        y-=.5;
        setTimer(0.1);
      }

      else{
        this.status = 1;
      }

    }

    if(this.status == 1){
      if(x > 32){
        x-=.5;
        setTimer(0.1);
        dir = 1;
      }
      else{
        setcharani("classic_idle",NULL);
        dir = 2;
      }
    }


  }

  else{
    setTimer(0.1);
  }

}

function CheckMap(){
  if(findweapon("Maps/Overworld") == NULL){
    return(false);
  }
  return(true);
}
