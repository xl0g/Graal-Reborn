  this.locindex = 2;
  onActivate();
}

function onTouched() {
  this.jewel_reading = true;
  say2("Hmm, what's this? I think#bI'll take it with me.");
}

function onPlayerEndsReading() {
  if (this.jewel_reading) {
    this.jewel_reading = false;
    setTimer(0.15);
  }
}

function onTimeout() {
  onPickup();
}
NPCEND
