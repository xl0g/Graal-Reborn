//#CLIENTSIDE
function onCreated(){
  showcharacter();
  this.head = "head1.png";
  this.colors[0] = "orange";
  this.colors[1] = "blue";
  this.colors[2] = "black";
  this.colors[3] = "red";
  this.colors[4] = "red";
  this.shield = "no-shield.png";
  this.nick = "*Galen";
  this.ap=100;
  this.dir = 2;
  x+=0.5;
  setcharani("classic_sit",NULL);
  onPlayerenters();
}

function onPlayerenters(){
  if(clientr.quest_dungeon == NULL){
    hide();
  }
  else{
    if(clientr.quest_knight_complete == NULL){
      show();
      if(findweapon("*Lantern") == NULL){
        message("Need some advice?");
        setTimer(5);
      }
    }
    else{
      hide();
    }
  }
}

function onTimeout(){
  message("");
}

function onPlayertouchsme(){

  if(findweapon("*Lantern") == NULL){
    say2("I strongly suggest you go back#bto the joint and find a Lantern#bbefore continueing this castle.");
    return(NULL);
  }
  if (!clientr.quest_dungeon_complete){
    say2("I wouldn't go up any #bstairs right now.");
  }

}
