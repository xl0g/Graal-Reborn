}
if (timeout) {
  message;
}
if (playerenters && strequals(#g,Game Coordinator)) say2 Say 'Commands' for commands;
if (actionfullheal) {
  if (save[0] in |1,2|) {
    setstring clientr.stat_hp,#s(clientr.stat_maxhp);
  }
}
