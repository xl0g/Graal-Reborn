if (playerchats) {
  if (strequals(#g,Game Coordinator) || control == 1)  {
    if (strequals(#e(0,5,#c),start)) {
      if (strequals(#e(6,4,#c),NPCs)) save[0] = 2;
      elseif (strequals(#e(6,2,#c),PK)) save[0] = 3;
      elseif (strequals(#e(6,9,#c),noweapons)) save[0] = 4;
      elseif (strequals(#e(7,1,#c),)) save[0] = 1;
      else break;
      message Start!;
      timeout = 2;
    } elseif (strequals(#c,stop)) {
      save[0] = 0;
      level.nodamage = 1;
      message Stop, HAMMERTIME!;
      timeout = 2;
    }
    if (save[0] == 3) level.nodamage = 0;
    else level.nodamage = 1;
  }
