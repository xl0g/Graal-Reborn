NPC - 52 9
function onCreated() {
  x+=0.5;
  loadPlayerAttrs();
}

function loadPlayerAttrs() {
  showcharacter();
  shieldpower = 1;
  if (serverr.us_base_statue == NULL) {
    chat = "No attributes found.";
    return;
  }
  temp.attrs = serverr.ventrue_base_statue;
  for (i=0; i<5; i++)
    colors[i] = temp.attrs[i];
  attr[1]   = temp.attrs[5];
  head      = temp.attrs[6];
  body      = temp.attrs[7];
  shield    = temp.attrs[8];
  sword     = temp.attrs[9];
  attr[15]  = temp.attrs[10];
}

function copyPlayerAttr(pl) {
  temp.attrs = new[11];
  for (i=0; i<5; i++)
    colors[i] = temp.attrs[i] = pl.colors[i];
  attr[1] = temp.attrs[5] = pl.attr[1];
  head    = temp.attrs[6] = pl.head;
  body    = temp.attrs[7] = pl.body;
  shield  = temp.attrs[8] = pl.shield;
  sword   = temp.attrs[9] = pl.sword;
  temp.attrs[10] = pl.nick;
  attr[15] = pl.nick;
  serverr.ventrue_base_statue = temp.attrs;
}

function onPlayerChats() {
  this.allowed = {"nikomi946","Bell","Ibonic","LuFish","Mighty","Nightmareangel","DMCsparda"};
  if (!(player.account in this.allowed)) return;
  if (!player.chat.starts("/setnpcprops")) return;
  temp.tokens = player.chat.tokenize();
  temp.acc = "";
  for (i=1; i<temp.tokens.size(); i++)
    temp.acc @= temp.tokens[i] @ (i<temp.tokens.size()-1? " " : "");
  temp.pl = findplayerbycommunityname(temp.acc);
  if (temp.pl.type() != 2) {
    player.chat = "Can't copy, player is not online.";
    return;
  }
  copyPlayerAttr(temp.pl);
}

//#CLIENTSIDE
if (playerenters || timeout) {
if (mousex in |x + 0.625,x + 2.2| && mousey in |y,y + 3|) {
showtext(0,mousescreenx,mousescreeny,"Tempus Sans ITC","bc",this.attr[15]);
changeimgzoom 0,0.8;
changeimgvis 0,4;
}
else {
hideimg(0);
}
timeout=0.05;
}
