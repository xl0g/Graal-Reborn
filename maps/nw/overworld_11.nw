  if (player.account in {"nikomi946","Bell","Ibonic","LuFish","Mighty","Nightmareangel","DMCsparda"} && player.chat.starts("/setmonth")){
    serverr.ventrue_base_statue_month=player.chat.tokenize()[1];}
}

function onPlayerTouchsMe()
  {
  if (player.dir != 0) return;

  temp.text = "\n Ventrue " @ serverr.ventrue_base_statue_month @ " Spar Champion ~";
  if (player.account in {"nikomi946","Bell","Ibonic","LuFish","Mighty","Nightmareangel","DMCsparda"})
    {
    temp.text @= "\n #bCommands:" @
      "\n /setmonth [month]#b(Sets the sign month)" @
