NPC - 0 0
//Gravity script
//#CLIENTSIDE
if (playerenters) {
  this.shield = strtofloat(#s(clientr.stat_shield));
}
if (playerenters || timeout) {
  if (playery < 52 && !strequals(#m,classic_dead)) {
    if (this.lastpd in {0,2}) this.lastpd = 3;
    if (keydown(0)) {
      if (movement_handlekeys == 0) {
        if (this.des == -1 || (this.jumpn < 2 && this.key == 0)) {
          this.uvel = 0.7;
          this.unum = 0;
          this.des = 1;
          this.dvel = 0;
          this.jumpn++;
          this.key = 1;
        }
        else {
          if (this.shield != 3) playery += 0.5;
          else playery += 0.615;
        }
      }
    }
    else this.key = 0;
    if (this.des == 1) {
      this.unum++;
      if (!onwall(playerx + 0.8125,playery - 0.0625) && !onwall(playerx + 1.4375,playery - 0.0625) && !onwall(playerx + 2.125,playery - 0.0625)) playery -= this.uvel;
      else this.uvel = 0.1;
      if (this.unum >= 5) {
        this.uvel -= 0.1;
        if (this.uvel == 0) {
          this.unum = 0;
          this.des = 0;
        }
      }
    }
    for (this.a = 0;this.a <= this.dvel;this.a += 0.0625) {
      if (onwall(playerx + 0.8125,playery + 3.0625 + this.a) || onwall(playerx + 1.4375,playery + 3.0625 + this.a) || onwall(playerx + 2.125,playery + 3.0625 + this.a) && this.des == 0) {
        playery += this.a;
        this.onwall = 1;
        this.dvel = 0;
        this.des = -1;
        this.jumpn = 0;
        break;
      }
    }
    if (this.des < 1 && this.onwall == 0) {
      this.des = 0;
      playery += this.dvel;
      this.dvel += 0.125;
    }
    this.onwall = 0;

    if (movement_handlekeys == 0) {
      if (playerdir == 0) playerdir = this.lastpd;
      if (playerdir == 2) playerdir = this.lastpd;
      this.lastpd = playerdir;
    }
  }
  timeout = 0.05;
}
NPCEND
NPC - 3 0
function onCreated() {
  setshape(1,32,32);
}
function onPlayerChats() {
  if (player.guild == "Game Coordinator") {
    if (player.chat == "reset deaths") {
      player.chat = "Deaths Reset!";
      this.accounts = "";
      this.deaths = "";
      for (i=0;i < players.size();i++) {
        this.accounts.add(players[i].account);
        this.deaths.add("0");
      }
      setAttributes();
    }
    elseif (player.chat == "start noheal") {
      player.chat == "Weapons Enabled!";
      save[0] = 1;
    }
    elseif (player.chat == "start heal" || player.chat == "start") {
      player.chat = "Weapons Enabled!";
      save[0] = 2;
    }
    elseif (player.chat == "stop") {
      player.chat = "Weapons Disabled!";
      save[0] = 0;
    }
    if (player.chat.starts("deaths")) {
      tokens = player.chat.tokenize();
      if (tokens[0] == "deaths") {
        this.deathscount = tokens[1];
        player.chat = this.deathscount @ " deaths!";
      }
    }
  }
}
function onPlayerEnters() {
  if (this.accounts.index(player.account) == -1) {
    this.accounts.add(player.account);
    this.deaths.add("0");
    setAttributes();
  }
}
function onActionFellintopit() {
  if (save[0] == 2) player.ModifyHP(0,0,clientr.stat_maxhp);
  increaseDeaths();
  checkElimination();
}
function onActionPlayerdied() {
  increaseDeaths();
  checkElimination();
}
function increaseDeaths() {
  if (save[0] != 0) {
    index = this.accounts.index(player.account);
    deaths = this.deaths[index];
    this.deaths.replace(index,deaths+1);
    setAttributes();
  }
}
function checkElimination() {
  if (save[0] != 0) {
    index = this.accounts.index(player.account);
    deaths = this.deaths[index];
    // check if eliminated
    if (deaths >= this.deathscount && this.deathscount != 0) {
      player.x = 30.5;
      player.y = 56;
      player.dir = 2;
      setani("classic_idle","");
      player.chat = "Eliminated!";
    }
  }
}
function setAttributes() {
  attr[1] = this.accounts;
  attr[2] = this.deaths;
}
//#CLIENTSIDE
if (playerenters || timeout)  {

  if (this.slp > 0 && playery >= 51) {
    this.slp = 0;
  }
  if (this.dead == 1 && playery >= 51) {
    this.dead = 0;
  }

  // you fell into the pit
  if (movement_handlekeys == 0 && !strequals(#g,Game Coordinator) && this.slp == 0 && this.dead == 0 && (playery in |44,47| || playery in |3,4|)) {
    setani classic_hurt,;
    triggeraction x,y,fellintopit,;
    movement_handleganis = 0.45;
    movement_handlekeys = 0.45;
    movement_handlesword = 0.45;
    movement_handleitems = 0.45;
    this.slp = 0.05;
  }
  if (this.slp > 0) {
    this.slp += 0.05;
    if (this.slp == 0.55) {
      this.slp = 0;
      setani classic_idle,;
      playerx = int(random(3,58));
      playery = 5;
    }
  }

  // you died
  if (strequals(#m,classic_dead) && this.slp == 0 && this.dead == 0 && playery < 51) {
    this.dead = 1;
    triggeraction x,y,playerdied,;
  }
  if (this.dead == 1 && !strequals(#m,classic_dead)) {
    this.dead = 0;
    setani classic_idle,;
    playerx = int(random(3,58));
    playery = 5;
  }

  // display deaths for GCs
  if (strequals(#g,Game Coordinator)) {
    for (i = 1;i < playerscount;i++) {
      if (mousex in |players[i].x,players[i].x + 3| && mousey in |players[i].y,players[i].y + 3|) {
        this.accounts,#P1(-1);
        this.deaths,#P2(-1);
        index = lindexof(#a(i),this.accounts);
        if (index > -1) {
            showtext 1,screenwidth / 2,screenheight - 20,,bc,#a(i): #I(this.deaths,index);
            changeimgzoom 1,0.8;
            changeimgvis 1,4;
            break;
        }
      }
    }
  }

  // show your own deaths
  if (playery < 51) {
    setstring this.accounts,#P1(-1);
    setstring this.deaths,#P2(-1);
    index = lindexof(#a,this.accounts);
    if (index > -1) {
      showtext 0,14,7,,b,Deaths: #I(this.deaths,index);
      changeimgzoom 0,0.7;
      changeimgvis 0,4;
    }
    else hideimg 0;
  }
  else hideimg 0;

  if (!strequals(#g,Game Coordinator)) {
  movement_handlepause = 0.1;
  // enable and disable weapons
  if (playery < 51) {
    if (save[0] == 0) {
      movement_handlesword = 0.1;
      movement_handleitems = 0.1;
    }
  }  else {
    movement_handlesword = 0.1;
    movement_handleitems = 0.1;
  }
  }

  timeout = 0.05;
}
NPCEND
