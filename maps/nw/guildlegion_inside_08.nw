if (created) {

  dontblock;
}
if (playerenters) {
  setcoloreffect 1,0.6,0,0.5;
  drawaslight;
  this.zoom = 1;
  timeout = 0.05;
}
if (timeout) {
if (this.zoom<=1) {
this.ds=1;
}
else if (this.zoom>=1.1) {
this.ds=0;
}
if (this.ds==1) {
this.zoom += 0.02;
setzoomeffect this.zoom;
}
else if (this.ds==0) {
this.zoom -= 0.03;
setzoomeffect this.zoom;
}
timeout = 0.05;
}
NPCEND
