//#CLIENTSIDE
function onCreated() {
  if(player.client.tuleprogress == NULL || findweapon("Maps/Tule Village") == NULL || findweapon("Maps/Tutorial") == NULL){
    x += 0.5;
}
  else {
    x += 2;
    y += 2;
  }

  showcharacter();
  head = "head19.png";
  colors[0] = "orange";
  colors[1] = "gray";
  colors[2] = "darkblue";
  colors[3] = "brown";
  colors[4] = "black";
  shield = "shield150.png";
  body = "body2.png";
  dir = 2;
}

function onPlayerTouchsMe() {
if(client.midisoff == 0){
play("stef9.mid");
client.midi = "stef9.mid";
}

if (x % 64 < 33 && y % 64 < 6) {
client.tuleprogress = new[16];
this.stefan = 1;
setTimer(0.25);
}

  say2("Welcome to Graal Classic!
To cancel this sign and
unpause your character, scroll
down to the end, or press M!
The icon by A is your glove
power.  Since you don't have any
gloves, you don't have an icon!
The icon by S is your sword image.
You have "@ player.sword @" as
your sword now,but you'll get new
images later. The icon by D is your
weapon.  Press Q to call up the
list of weapons and select a
different one.  The two weapons
you start with are Bombs
and Arrows. The numbers
below the green icon
at the top of your screen
shows your gelat count.
Gelats are the currency of
Graal, and are sometimes
called Rupees or Gralats.
The number below the blue
icon is your current Bombs
count. The same is true of
the yellow icon, that shows
your Arrows count. Right of
that is your hearts,
shown as #4s.
Picking up small #4s refills
your health, you will find
Quests where you can
increase your maximum
health.");
}

function onTimeout(){
  if(this.stefan == 1){
    if(player.reading){
      setTimer(0.25);
    }
    else{
      if(this.status == 0) {
        say2("Wow, you deserve something#bfor sitting through all that...#bIf you're going to be travelling#bthe least I can do is give#byou these maps.#bBe sure to take a look at them.#bThey are stored within the Maps#bfolder inside Inventory,#bbut if you've opened one or#byou're on a map you just press M.");
        this.status = 1;
        setTimer(0.05);
        return;
      }
      if(this.status == 1) {
        if(!this.givenmaps){
          GiveMaps();
        }
        if(y % 64 < 6){
          setcharani("classic_walk",NULL);
          y+=.5;
        }
        else {
          this.status = 2;
        }
      }
      else {
        if (this.status == 2) {
          if (x % 64 < 33) {
            x+=.5;
            dir = 3;
          }
          else {
            setcharani("classic_idle",NULL);
            dir = 2;
            this.status = 3;
          }
        }
      }
      if(this.status != 3){
        setTimer(0.1);
      }
    }
  }
}

function GiveMaps(){
  system_injure.giveweapon("Maps/Tutorial");
  system_injure.giveweapon("Maps/Tule Village");
  this.givenmaps = true;
}
