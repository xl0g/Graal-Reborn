function onCreated(){
  setshape(1,64,32);
  setimg("door1.png");
}


function onPlayertouchsme(){
  if(clientr.info_playertrial == "yes"){
    say2("Trials cannot enter the Fort.");
    return;
  }

  if(timevar2 < (serverr.guildfortDestiny_stats[4]+300)){
    if(!(serverr.guildfortDestiny_stats[3] in {player.communityname,player.guild})){
      temp.time = int((serverr.guildfortDestiny_stats[4]+300-timevar2)/60);
      if(temp.time > 0){
        say2("The Fort has been won.#bWait "@temp.time@" minutes.");
      }
      else{
        say2("The Fort has been won.#bWait 30 Seconds");
      }
      return;
    }
  }

  setlevel2("destiny_fort_inside_01.nw",30.5,47.5);

}
NPCEND
