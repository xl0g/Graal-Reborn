function onPlayertouchsme() {
  client._handleall  = .8;
  client._handlekeys = .8;
  if (this.dealt == 0) player.injure(1);
  this.dealt = 1;
  setani("classic_drown","");
  damaged = findplayer(player.account);
  timeout = .8;
}
function onTimeout() {
  this.dealt = 0;
  damaged.x = 50.5;
  damaged.y = 48;
}
//#CLIENTSIDE
if (created) setshape 1,32,32;
