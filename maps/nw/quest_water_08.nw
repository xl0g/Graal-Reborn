if (created) {
  timeout = .05;
}
if (timeout) {
  if (playerx in |6.5,42| && playery in |41,44|) {
    playerx += .5;
  } elseif (playerx in <42,53| && playery in |41,42|) {
    playerx += .5;
  } elseif (playery < 40.75) {
    playerx = int(playerx) + .5;
    if (onwater(playerx + 1.5, playery + 2)) playery += .5;
  }
  timeout = .05;
}
