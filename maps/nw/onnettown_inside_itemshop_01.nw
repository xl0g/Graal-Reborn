function onActionPurchase() {
  if (clientr.stat_gelat >= this.price) {
    if (findweapon(this.itemname) != this.itemname) {
      addweapon(this.itemname);
      clientr.stat_gelat -= this.price;
      say2("Come Again!");
    } else {
      say2("You already have this!?");
    }
  } else {
    say2("Not enough gelat.");
  }
}
