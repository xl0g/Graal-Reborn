function onPlayerchats() {
  if (player.guild == "Game Coordinator") {
    if (serverr.gc_scavengerhunt[0] == 1) {
      if (player.chat.starts("addhunt ")) {
        if(!contains(serverr.gc_scavengerhunt,player.chat.substring(8,-1))) {
          serverr.gc_scavengerhunt.add(player.chat.substring(8,-1));
          serverr.gc_scavengerhunt.add(0);
        }
      } else if (player.chat == "Start Hunt") {
        serverr.gc_scavengerhunt[0] = 2;
      }
    } else if (player.chat == "End Hunt") {
      serverr.gc_scavengerhunt[0] = 1;
    }
    if (player.chat == "Reset") {
      while (serverr.gc_scavengerhunt.length() > 2) serverr.gc_scavengerhunt.delete(1);
      serverr.gc_scavengerhunt[0] = 1;
      serverr.gc_scavengerhunt[1] = "";
    }
  }
  if (player.chat == "score") {
    player.chat = serverr.gc_scavengerhunt;
  }
}
//#CLIENTSIDE
if (playertouchsme) {
  if (strequals(#g,Game Coordinator)) {
    say2 Scavenger Hunt Control#b#b#baddhunt account (case sensitive)#bstart hunt (makes items visible)#bend hunt (makes items invisible)#breset (resets all info);
  }
}
