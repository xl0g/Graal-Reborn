      former = sacrifice;
      if (former.level == level) {
        former.x   = 32.5;
        former.y   = 39;
        former.dir = 2;
        former.client._handleall   = "null";
        former.client._handlekeys  = "null";
        former.client._handlesword = "null";
      }
      sacrifice     = findplayer(tokens[1]);
      sacrifice.x   = 32.5;
      sacrifice.y   = 34;
      sacrifice.client._handleall   = -1;
      sacrifice.client._handlekeys  = -1;
      sacrifice.client._handlesword = -1;
    }
  }
}

