//#CLIENTSIDE
function onActionLeftMouse() {
  this.imgnames = {
    "classic_bigkey.png",
    "classic_unknown1.png",
    "classic_unknown.png",
    "classic_key2.png",
    "classic_sign1.png",
    "classic_goldtop.png",
      "wateranismall.gif"}; //Change this array to add images and such
  createwindow();
}
function createwindow() {
  client.imgnames = this.imgnames;
  imgwin.destroy();
  new GuiWindowCtrl("imgwin") {
    visible = true;
    canclose = true;
    canresize = false;
    canmove = true;
    closequery = true;
    canmaximize = true;
    canminimize = false;
    new GuiShowImgCtrl("imgdisp") {
      this.imgnum = 0;
      image = client.imgnames[0];
      width = getimgwidth( client.imgnames[0] );
      height = getimgheight( client.imgnames[0] );
    }
    width = 112;
    height = 112;
    x = screenwidth/2-width/2;
    y = screenheight/2-height/2;
    new GuiShowImgCtrl("imgleft") {
      text = "<";
      style = "b";
      x = 8;
      y = 32;
    }
    new GuiShowImgCtrl("imgright") {
      text = ">";
      style = "b";
      x = imgwin.width-24;
      y = 32;
    }
    imgdisp.x = 24;
    imgdisp.y = 28;
  }
}
function imgleft.onmousedown() {
  imgdisp.imgnum --;
  if (imgdisp.imgnum < 0)
    imgdisp.imgnum = this.imgnames.size()-1;
  // updateimgwin();
