// NPC made by Schoko Raven (LAT)
join("motion_functions");
join("m2_damage");
//#CLIENTSIDE
function onCreated() {
  makecharacter();
  seteffect(0,0,0,0);

  bubble.phases = {"Countdown","InitShoot","UpdateShoot","EndShoot","InitExplosion","UpdateExplosion","EndExplosion","InitCountdown","Dive"};
  bubble.counters = {1,0,1,0,0,0,0,0,1.5};
  bubble.phase = 0;
  bubble.counter = bubble.counters[phase];

  dive.phases = {"Countdown","Begin","Submerged","BeginEmerge","End"};
  dive.counters = {5,0,1,.5,.5};
  dive.newx = 0;
  dive.newy = 0;
  dive.phase = 0;
  dive.counter = dive.counters[phase];
  dive.underwater = false;

  trident.counter = .1;

  chat = "";
  initMovement();

  onTimeout();
}

function initMovement() {
  z = 0;
  this.waveyz = 4.71;  // so 1+sin(waveyz) = 0

}

function onTimeout() {
  setTimer(.05);

  if (bubble.counter > 0)
    bubble.counter -= 0.05;

  bubble.initialphase = 99;
  while(bubble.initialphase != bubble.phase) {
    bubble.initialphase = bubble.phase;
    this.("bubble" @ bubble.phases[bubble.phase])();
    if(bubble.counter <= 0) {
      bubble.phase++;
      if(bubble.phase >= bubble.phases.size())
        bubble.phase = 0;
      bubble.counter = bubble.counters[bubble.phase];
    }
  }

  if (dive.counter > 0)
    dive.counter -= 0.05;

  dive.initialphase = 99;
  while(dive.initialphase != dive.phase) {
    dive.initialphase = dive.phase;
    this.("dive" @ dive.phases[dive.phase])();
    if (dive.counter <= 0) {
      dive.phase++;
      if (dive.phase >= dive.phases.size()) {
        dive.phase = 0;
        putleaps(5,x+.5,y+1.5);
      }
      dive.counter = dive.counters[dive.phase];
    }
  }

  trident.counter -= .05;

  // Movement stuff only if not submerging
  if (dive.phase == 0 && !(bubble.phase in |1,2|)) {
    // Hover on water
    if (dive.counter > .5) {
      this.waveyz+=.2;
      z = 1 + sin(this.waveyz);
      if (this.waveyz > 6.28) {
        this.waveyz = -6.28;
      }
    }

    // Follow player
    temp.angle = getangle(player.x - x, player.y - y);
    dx = .4 * cos(temp.angle);
    dy = .4 * -sin(temp.angle);
    dir = getdir(player.x - x, player.y - y);

    if (abs(player.x - x) + abs(player.y - y) > 20) {
      moveXY(dx,dy,this);
    }
    if (abs(player.x - x) + abs(player.y - y) < 5)  {
      moveXY(-dx/2,-dy/2,this);
      if (trident.counter <= 0) {
        setcharani("classic_trident",null);
        trident.counter = .35;
      }
    }
  }
}

function bubbleCountdown() {
  //do nothing
  //chat = "Counting down to shoot time!!!1111";
}

function bubbleInitShoot() {
  //chat = "Preparing to fire!";
  //initialze the shoot

  bubble.initx = x;
  bubble.inity = y;
  bubble.radius = 2;
  bubble.angle = -getangle(player.x - x, player.y - y);

  bubble.image = showimg(210,"classic_bubblebomb2.gif",bubble.initx*bubble.radius,bubble.inity*bubble.radius);

  setcharani("grab",null);

}

function bubbleUpdateShoot() {
  //chat = "Shooting now!";
  //move the bubble
  bubble.radius += 1.2;

  bubble.wavez += .5;
  bubble.image.z = 1 + sin(bubble.wavez);
  if (bubble.wavez > 6.28) {
    bubble.wavez = -6.28;
  }

  bubble.image.x = bubble.initx + cos(bubble.angle)*bubble.radius;
  bubble.image.y = bubble.inity + sin(bubble.angle)*bubble.radius;

  if (bubble.counter > .75)
    setcharani("grab",null);
  else
    setcharani("idle",null);
}

function bubbleEndShoot() {
  //chat = "Ok, all done shooting.";
  //end shoot
  hideimg(210);
}

function bubbleInitExplosion() {
  // initialize the explosion
}

function bubbleUpdateExplosion() {
  // do explosion updates and hurting and stuffs
}

function bubbleEndExplosion() {
  //do stuff to finialize explosion
}

function bubbleInitCountdown() {
  //chat = "Begin the countdown!";
}


function diveBegin() {
  dive.newx = int(random(20,43));
  dive.newy = int(random(20,43));

  dive.underwater = true;

  bubble.phase = 8;

  // hide bubble
  hideimg(210);
  hide();
}

function diveCountdown() {

//  chat = "Counting down to dive!";

  if (dive.counter < .5) {
    z = 0;
    setcharani("swim",null);
  }

}

function diveSubmerged() {
//  chat = "Submerged!";
  x = dive.newx;
  y = dive.newy;
  initMovement();
  setcharani("classic_carrystill",null);
}

function diveBeginEmerge() {
//  chat = "Gonna come out now...";
  if ((dive.counter*100)%25 == 0) {
    putleaps(5,dive.newx+0.5,dive.newy+1.5);
  }

}

function diveEnd() {
//  chat = "I'm back!";

  show();

  setcharani("classic_carrystill",null);

  if (dive.counter > .25)
    z += 10/(.25/.05);
  if (dive.counter < .25)
    z -= 10/(.25/.05);

  if ((dive.counter*100)%10 == 0) {
    dir = (dir+1)%4;
  }
}

function makecharacter() {
  showcharacter();
  head = "head508.png";
  sword = "kittaymagic-sword.png";
  shield = "faqx-staff-shield.mng";
  body = "body15.png";
  colors[0] = 2;
  colors[1] = 11;
  colors[2] = 10;
  colors[3] = 11;
  colors[4] = 11;
}
