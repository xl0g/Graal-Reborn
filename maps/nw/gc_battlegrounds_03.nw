function onCreated(){
  y=30.25;
  this.dhearts=900;
  chat="HP: " @ int((this.dhearts/900)*100) @ "%";
  serverr.gc_bg_stats[3] = int((this.dhearts/900)*100) @ "%";
  setTimer(1);
}
function onPlayerChats(){
  if (player.guild == "Game Coordinator")
    if (player.chat == "/reset"){
    this.dhearts=900;
    chat="HP: " @ int((this.dhearts/900)*100) @ "%";
    serverr.gc_bg_stats[3] = int((this.dhearts/900)*100) @ "%";
    show();
  }
}
function onSlash(){
  if(this.dhearts > 0 && player.guild == "Babord Infantry"){
    this.dhearts -= 1;
    chat="HP: " @ int((this.dhearts/900)*100) @ "%";
    serverr.gc_bg_stats[3] = int((this.dhearts/900)*100) @ "%";
    setTimer(1.5);
  }
  if(this.dhearts == 0){
    setimg("gate2.png");
    clink=findNPC("gc_rankings");
    (clink.("gc_" @ player.account @ "_bg_gates"))++;
    serverr.gc_bg_stats[3] = int((this.dhearts/900)*100) @ "%";
    setTimer(1.5);
  }
}
function onTimeOut(){
  if(this.dhearts<900 && this.dhearts != 0 && serverr.gc_bgbalanced = "true"){

    this.dhearts ++;
    chat="HP: " @ int((this.dhearts/900)*100) @ "%";
    serverr.gc_bg_stats[3] = int((this.dhearts/900)*100) @ "%";
  }
  setTimer(.02);
}
