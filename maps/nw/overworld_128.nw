function onPlayertouchsme(){
  if(clientr.info_playertrial == "yes"){
    say2("Trials cannot enter the Fort.");
    return;
  }

  if(timevar2 < (serverr.guildfortBabord_stats[4]+300)){
    if(!(serverr.guildfortBabord_stats[3] in {player.communityname,player.guild})){
      temp.time = int((serverr.guildfortBabord_stats[4]+300-timevar2)/60);
      if(temp.time > 0){
        say2("The Fort has been won.#bWait "@temp.time@" minutes.");
      }
      else{
        say2("The Fort has been won.#bWait 30 Seconds");
      }
      return;
    }
  }

  setlevel2("babord_fort_inside_01.nw",29.5,51);

}
NPCEND
