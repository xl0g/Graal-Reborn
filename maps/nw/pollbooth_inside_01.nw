NPC - 27 22
// NPC made by James (Andy0687)
function onCreated() {
  setshape(1, 32, 32);
}
function onActionvote() {
  if (player.trial) {
    player.chat = "Trial's cannot vote!";
    return;
  }
  if((player.onlinetime/3600) < 50){
    player.chat = "100 Hours are required to vote!";
    return;
  }

  if(FindNPC("POLL").question != ""){
    g = FindNPC("POLL").voted.index(player.account);
    if (g == -1) {
      if(player.clientr.ip != NULL && player.clientr.ip in FindNPC("POLL").ips){
        player.chat = "You have already voted on another account!";
        return;
      }
      FindNPC("POLL").voted.add(player.account);
      if(player.clientr.ip != NULL){
        FindNPC("POLL").ips.add(player.clientr.ip);
      }
      player.chat = "Voted "@ params[1] @"!";
      FindNPC("POLL").(""@ params[1]) += 1;
      redrawtexts();
    }else{
      player.chat = "You have already voted";
    }
  }
}
function onPlayerenters() {
  showimg(3,"whiteorb.png",x,y);
  showimg(4,"whiteorb.png",x,y+3);
  showimg(5,"whiteorb.png",x,y+4);
  redrawtexts();
}
function redrawtexts() {
  this.question = FindNPC("POLL").question;
  this.yes = FindNPC("POLL").yes;
  this.no = FindNPC("POLL").no;
  this.q = this.question.substring(0,40);
  this.q2 = this.question.substring(40,this.question.length());
  if(this.question != ""){
    showtext(16+o, x+1, y+(o*.7), "Times New Roman", null,this.q);
    if(this.q2 != "") {showtext(17+o, x+.5, y+(o*.7)+1, "Times New Roman", null,this.q2);}
    showtext(7, x+1, y+3, "Times New Roman", null, "Yes Votes: "@ this.yes);
    showtext(8, x+1, y+4, "Times New Roman", null, "No Votes: "@ this.no);
    changeimgzoom(16+o,.6);
    changeimgzoom(17+o,.6);
    changeimgzoom(7,.6);
    changeimgzoom(8,.6);
  }
}
function onPlayerchats() {
  if (player.account in FindNPC("POLL").allowed) {
    if (player.chat.starts("/setq1")) {
      FindNPC("POLL").question = player.chat.substring(7,-1);
      player.chat = "Question 1 set";
      FindNPC("POLL").lastupdated = player.account;
      redrawtexts();
    }
    if (player.chat == "/reset1") {
      FindNPC("POLL").question = 0;
      FindNPC("POLL").yes = 0;
      FindNPC("POLL").voted = "";
      FindNPC("POLL").no = 0;
      FindNPC("POLL").ips = "";
      hideimg(16);
      hideimg(17);
      hideimg(7);
      hideimg(8);
      player.chat = "Poll reset";
    }
  }
}

//#CLIENTSIDE
function onplayerenters() {
  noplayerkilling();
}
function onmousedown() {
  if (!playertrial) {
    if (params[0] == "left") {
      if (mousex in |27,27.8|) {
        if (mousey in |25,25.8|) {
          triggeraction(this.x, this.y, "vote", player.account, "yes");
        }
        else if (mousey in |26,26.8|) {
          triggeraction(this.x, this.y, "vote", player.account, "no");
        }
      }
    }
  }else{
    player.chat = "Please login to a P2P Account to vote!";
  }
}
NPCEND
