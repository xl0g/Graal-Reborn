enum {
 NOT_IN_AREA,
 RED_TEAM_AREA,
 BLUE_TEAM_AREA
}
function hasTag(plr){
 return (plr.guild == "Team Alpha" || plr.guild == "Team Beta");
}
function getArea(plr){
 if (!(plr.y in |22,37|) || plr.guild == "Game Coordinator") return NOT_IN_AREA;
  else if (plr.x in |17,23|) return RED_TEAM_AREA;
  else if (plr.x in |29,35|) return BLUE_TEAM_AREA;
}
function shouldWarp(plr){
 return (hasTag(plr) && (getArea(plr) != NOT_IN_AREA || plr.guild == "Game Coordinator"));
}
function onCreated(){
 this.x = 25.5;
 setshape(1,32,32);
 setTimer(1);
}
function onPlayerEnters(){
 setTimer(1);
}
function onTimeout(){
 this.chat = "Hey, GC! Left-click here when you're ready, or right-click here if auto tagging has broken!";
 this.psize = players.size();
 for (i=0;i<this.psize;i++){
  this.targ = players[i];
  this.area = getArea(this.targ);
  if (this.area == NOT_IN_AREA){
   if (hasTag(this.targ)) this.targ.guild = "";
  }else if (this.area == RED_TEAM_AREA){
   this.targ.guild = "Team Alpha";
  }else if (this.area == BLUE_TEAM_AREA){
   this.targ.guild = "Team Beta";
  }
 }
 // hey let's do latency minimising k
 if (this.psize > 0) setTimer(1);
}
function onActionLeftMouse(){
 chat = "Starting round!";
 this.psize = players.size();
 for (i=0;i<this.psize;i++){
  if (shouldWarp(players[i])){
   players[i].clientr.e_lasertag_lives = 5;
   this.area = getArea(players[i]);
   if (this.area == RED_TEAM_AREA) players[i].setlevel2("gc_lasertag_01.nw",3.6,57);
    else if (this.area == BLUE_TEAM_AREA) players[i].setlevel2("gc_lasertag_02.nw",57.5,57);
    else if (player.guild == "Game Coordinator") setlevel2("gc_lasertag_01.nw",62,35);
  }
 }
}
function onActionRightMouse(){
 chat = "Refreshing timeout loop!";
 setTimer(1);
}
//#CLIENTSIDE
if (created){
 x = 25.5;
 showpoly 200,{x,y,x+2,y,x+2,y+2,x,y+2};
 changeimgcolors 200,0,1,0,1;
}
