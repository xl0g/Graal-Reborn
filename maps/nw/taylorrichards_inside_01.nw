function drawHeads(){
 n = 0;
 for (i=0;i<6;i+=2){
  for (j=0;j<8;j+=2){
   showimg 1001+i+(10*j),head#v(this.heads+n).png,33+j,13+i;
   changeimgpart 1001+i+(10*j),0,64,32,32;
   n++;
  }
 }
 showpoly 997,{33,20,35,19,35,21,33,20};
 showpoly 998,{39,19,41,20,39,21,39,19};
}
if (created) setshape 1,32,32;
if (playertouchsme){
 this.heads = 0;
 this.on = 1;
 movement_handlemoving = -1;
 movement_handleaction = -1;
 setani classic_sit,;
 drawHeads();
 timeout = 0.05;
}
if (mousedown && this.on == 1){
 m = {mousex,mousey};
 if (m[0] in |33,35| && m[1] in |19,21| && this.heads != 0){
  this.heads -= 12;
 }else if (m[0] in |39,41| && m[1] in |19,21|){
  this.heads += 12;
 }else if (m[0] in |33,41| && m[1] in |13,19|){
  this.mx = int((int(m[0])-33) / 2);
  this.my = int((int(m[1])-13) / 2);
  this.head = this.heads + this.mx + (4 * this.my);
  setplayerprop #3,head#v(this.head).png;
 }
 drawHeads();
}
if (timeout && this.on == 1){
 showtext 996,37,20,Courier New,bc,#v(this.heads)-#v(this.heads+11);
 changeimgzoom 996,0.7;
 if (keydown(2)){
  this.on = 0;
  movement_handlemoving = 0;
  movement_handleaction = 0;
  hideimgs 996,1100;
 }
 timeout = 0.05;
}
