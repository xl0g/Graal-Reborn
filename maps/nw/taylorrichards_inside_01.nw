function onPlayerchats(){
  if(player.chat == "buy permaclothes"){
    if(player.clientr.stat_gelat >= 500){
      if(findweapon("PermaClothes") == NULL){
        player.takegelat(500);
        addweapon("PermaClothes");
        say2("Nice doing business with you.");
      }
      else{
        say2("You already have this item.");
      }
    }
    else{
      say2("You do not have enough Gralat.");
    }
  }
}

