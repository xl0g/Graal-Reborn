NPC light4.png 44 20
//#CLIENTSIDE
if (created) {

  dontblock;
}
if (playerenters) {
  setcoloreffect 0.8,0,0,0.3;
  drawaslight;
  this.zoom = 1.7;
  timeout = 0.08;
}
if (timeout) {
if (this.zoom<=1.7) {
this.ds=1;
}
else if (this.zoom>=1.8) {
this.ds=0;
}
if (this.ds==1) {
this.zoom += 0.02;
setzoomeffect this.zoom;
}
else if (this.ds==0) {
this.zoom -= 0.03;
setzoomeffect this.zoom;
}
timeout = 0.08;
}
NPCEND
