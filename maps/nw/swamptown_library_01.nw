//#CLIENTSIDE
function onCreated(){
  this.x += 0.05;
  this.showcharacter();
  this.head = "classichead-cell.png";
  this.body = "classicbody-cell.png";
  this.shield = "classicshield-cell.png";
  this.colors[0] = "black";
  this.colors[1] = "white";
  this.colors[2] = "black";
  this.colors[3] = "black";
  this.colors[4] = "black";
  this.nick = "Cell (Chill)";
  this.ap = 99;
  this.setcharani("classic_idle","");
  this.attr[1] = "hat46.png";
}

function onPlayerenters(){
  onTimeout();
}

function onPlayertouchsme(){
  if(!this.spoke){
    say2("Don't i know you?");
    this.spoke = true;
  }
}

function onTimeout(){
  this.dir = getdir(player.x - this.x, player.y - this.y);
  setTimer(0.05);
}
NPCEND
