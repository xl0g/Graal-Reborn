NPC - 32 38
// NPC made by MASTER STORM OK NOT REV TENJIN
//#CLIENTSIDE
if (playerenters) {drawaslight;
  this.flames_maximumx = -5;              //Maximum horizontal movement
  this.flames_minimumx = 5;             //Minimum horizontal movement
  this.flames_maximumy = -17;              //Maximum vertical movement
  this.flames_minimumy = -22;             //Minimum vertical movement
  this.flames_gravityx = 0;              //Horizontal gravity pull per refresh
  this.flames_gravityy = 0.075;              //Vertical gravity pull per refresh
  this.flames_maincolor_red = 0.0;         //Main colour red amount
  this.flames_maincolor_green = 0.2;       //Main colour green amount
  this.flames_maincolor_blue = 1;        //Main colour blue amount
  this.flames_tintcolor_red = 0.2;         //Tint colour red amount
  this.flames_tintcolor_green = 0.2;     //Tint colour green amount
  this.flames_tintcolor_blue = 1;        //Tint colour blue amount
  this.flames_glowcolor_red = 0;         //NPC glow red amount
  this.flames_glowcolor_green = 0;     //NPC glow green amount
  this.flames_glowcolor_blue = 0;        //NPC glow blue amount
  this.flames_zoom = 0.17;                //Particle Density
  this.flames_alpha = 0.5;               //Particle Opacity
  this.flames_multiplyer = 185;            //Particle Complexity (Use only whole numbers)
  this.flames_recycletime = 20;           //Refreshes before a particle is recycled (Use only whole numbers)
  setarray this.flames_randomx,this.flames_multiplyer;
  setarray this.flames_randomy,this.flames_multiplyer;
  setarray this.flames_changevar,this.flames_multiplyer;
  this.flames_setupvar = 0;
  for (this.flames_setup = 0;this.flames_setup < this.flames_multiplyer;this.flames_setup ++){
    this.flames_randomx[this.flames_setup] = random(this.flames_minimumx,this.flames_maximumx);
    this.flames_randomy[this.flames_setup] = random(this.flames_minimumy,this.flames_maximumy);
    this.flames_changevar[this.flames_setup] = this.flames_setupvar;
    this.flames_setupvar ++;
    if (this.flames_setupvar > this.flames_recycletime){
      this.flames_setupvar = 0;
    }
  }
  showimg 205,light2.png,x - 4,y - 4;
  changeimgcolors 205,this.flames_glowcolor_red,this.flames_glowcolor_green,this.flames_glowcolor_blue,0.99;
  changeimgvis 205,3;
  timeout = 0.05;
}
if (timeout){
  this.flames_colourswitch = 0;
  for (this.flames_drawtime = 0;this.flames_drawtime < this.flames_multiplyer;this.flames_drawtime ++){
    showimg 210 + this.flames_drawtime,light2.png,x - 4 + (this.flames_randomx[this.flames_drawtime] / this.flames_recycletime)*this.flames_changevar[this.flames_drawtime] + ((this.flames_changevar[this.flames_drawtime]^2)/2 + this.flames_changevar[this.flames_drawtime]/2)*this.flames_gravityx,y - 4 + (this.flames_randomy[this.flames_drawtime] / this.flames_recycletime)*this.flames_changevar[this.flames_drawtime] + ((this.flames_changevar[this.flames_drawtime]^2)/2 + this.flames_changevar[this.flames_drawtime]/2)*this.flames_gravityy;
    if (this.flames_colourswitch > 1){
      changeimgcolors 210 + this.flames_drawtime,this.flames_tintcolor_red,this.flames_tintcolor_green,this.flames_tintcolor_blue,this.flames_alpha;
      this.flames_colourswitch = 0;
    }
    else {
      changeimgcolors 210 + this.flames_drawtime,this.flames_maincolor_red,this.flames_maincolor_green,this.flames_maincolor_blue,this.flames_alpha;
      this.flames_colourswitch ++;
    }
    changeimgvis 210 + this.flames_drawtime,3;
    changeimgzoom 210 + this.flames_drawtime,this.flames_zoom;
    this.flames_changevar[this.flames_drawtime] ++;
    if (this.flames_changevar[this.flames_drawtime] > this.flames_recycletime){
      this.flames_changevar[this.flames_drawtime] = 0;
      this.flames_randomx[this.flames_drawtime] = random(this.flames_minimumx,this.flames_maximumx);
      this.flames_randomy[this.flames_drawtime] = random(this.flames_minimumy,this.flames_maximumy);
    }
  }
  timeout = 0.05;
}
