function onPlayerchats() {
  if (player.chat == "start" && level.sparring == 0) {
    level.sparring = 1;
    scheduleEvent(1,"Countdown",3);
  }
  if (player.chat == "stop" && level.sparring == 1) {
    level.sparring = 0;
    chat = "Spar Stopped.";
    setTimer(1);
  }
}

function onCountdown(num) {
  if (!level.sparring) return;
  if (num > 0) {
    chat = num;
    num--;
    if (num >= 0)
      scheduleEvent(1,"Countdown",num);
  }
  else {
    chat = "Begin!";
    putexplosion(1,x-1,y);
    setTimer(0.5);
  }
}

function onTimeout() {
  chat = "";
}
