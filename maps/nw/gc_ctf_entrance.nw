function onMouseDown(button) {
  if (!(mousex in <this.x,this.x+11>
     && mousey in <this.y,this.y+2>))
    return;
  if (player.guild != "Game Coordinator")
    return;
  if (button == "left") {
    triggeraction(this.x+0.5,this.y+0.5,"ChangeType","");
  }
  if (button == "right") {
    triggeraction(this.x+0.5,this.y+0.5,"Randomize","");
  }
}

function onPlayerChats() {
  if (player.guild == "Game Coordinator") {
    if (player.chat == "/gametype random") {
      triggeraction(this.x+0.5,this.y+0.5,"Randomize","");
    }
  }
}

function getTextColor(mode) {
  temp.colors = {"large",0.95,0.48,0.41,
                 "small",0.95,0.76,0.35,
                 "indoor",0.96,0.91,0.43,
                 "gravity",0.56,0.83,0.42,
                 "ice",0.25,0.78,0.82,
                 "sumo",0.05,0.58,0.77,
                 "future",0.44,0.41,0.72,
                 "lol",0.60,0.60,0.60};
  if (!(mode in temp.colors))
    return {1,1,1};
  temp.idx = temp.colors.index(mode);
  return {temp.colors[temp.idx+1],temp.colors[temp.idx+2],temp.colors[temp.idx+3]};
}

function showGameText(text) {
  temp.txt   = text;
  temp.font  = "Tempus Sans ITC";
  temp.style = "b";
  temp.zoom  = 1;
  temp.show_txt  = showtext(300,21.5,19.9,temp.font,temp.style,temp.txt);
//  if (serverr.gc_ctf_type_randomizing)
    changeimgcolors(300,1,1,1,1);
//  else {
//    temp.colors = getTextColor(serverr.gc_ctf_type);
//    changeimgcolors(300,temp.colors[0],temp.colors[1],temp.colors[2],1);
//  }
  changeimgvis(300,0);
  temp.txt_width = getTextWidth(temp.zoom,temp.font,temp.style,temp.txt) / 16;
  with (temp.show_txt) {
    x    = ((64 - temp.txt_width) / 2) - 4.5;
    zoom = temp.zoom;
  }
  temp.show_txt  = showtext(301,21.5,19.9,temp.font,temp.style,temp.txt);
  changeimgcolors(301,0,0,0,1);
  changeimgvis(301,0);
  temp.txt_width = getTextWidth(temp.zoom,temp.font,temp.style,temp.txt) / 16;
  with (temp.show_txt) {
    x    = (((64 - temp.txt_width) / 2)) - 4.5 - 0.05;
    y    -= 0.05;
    zoom = temp.zoom;
  }
}
