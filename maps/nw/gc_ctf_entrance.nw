function onCreated() {
  setshape(1,32,112);
  dontblock();
  serverr.gc_ctf_type_randomizing = false;
}

function onActionChangeType() {
  if (serverr.gc_ctf_type_randomizing || serverr.gc_ctf_gameinprogress)
    return;
  temp.gametypes = serverr.gc_ctf_gametypes;
  temp.gametype = temp.gametypes.index(serverr.gc_ctf_type);
  if (temp.gametype == temp.gametypes.size() - 1)
    serverr.gc_ctf_type = temp.gametypes[0];
  else
    serverr.gc_ctf_type = temp.gametypes[temp.gametype+1];
  serverr.gc_ctf_type_text = serverr.gc_ctf_type;
  for (temp.pl: players) {
    temp.pl.client.gc_ctf_random_sound = 1;
  }
}

function onActionRandomize() {
  if (serverr.gc_ctf_type_randomizing || serverr.gc_ctf_gameinprogress)
    return;
  serverr.gc_ctf_type_randomizing = true;
  temp.gametypes = serverr.gc_ctf_gametypes;
  temp.gametype = int(random(0,temp.gametypes.size()-1));
  temp.position = (temp.gametype == temp.gametypes.size() - 1? 0 : temp.gametype + 1);
  temp.sleep_time = 0.05;
  temp.count = 0;
  temp.sound_time = 0;

  for (temp.i = 0; temp.i < temp.gametypes.size() * 8; temp.i++) {
    serverr.gc_ctf_type_text = temp.gametypes[temp.position];
    sleep(temp.sleep_time);
    if (timevar2 - temp.sound_time >= 0.15
     && !(temp.i == temp.gametypes.size() * 8 - 1)) {
      temp.sound_time = timevar2;
      for (temp.pl: players) {
        temp.pl.client.gc_ctf_random_sound = 1;
      }
    }
    if (temp.position == temp.gametypes.size() - 1)
      temp.position = 0;
    else
      temp.position++;
    if (temp.count == temp.gametypes.size() - 1) {
      temp.count = 0;
      temp.sleep_time += 0.05;
    }
    else
      temp.count++;
  }
  serverr.gc_ctf_type      = temp.gametypes[temp.gametype];
  serverr.gc_ctf_type_text = temp.gametypes[temp.gametype];
  sleep(temp.sleep_time);
  for (temp.pl: players) {
    temp.pl.client.gc_ctf_random_sound = 2;
  }
  for (temp.i = 0; temp.i < 3; temp.i++) {
    serverr.gc_ctf_type_text = "";
    sleep(0.15);
    serverr.gc_ctf_type_text = temp.gametypes[temp.gametype];
    sleep(0.15);
  }
  serverr.gc_ctf_type_randomizing = false;
}

