NPC - 25 26
join level_nopk;
function onCreated() {
  this.pieces = new [42];

  changeTurn();
}
function onPlayerChats() {
  if (player.chat.starts("red") && player.account == attr[2] && this.turn == 0) {
    tokens = player.chat.tokenize();
    column = tokens[1]-1;
    player.chat = column+1;
    if (column in |0,6|) {
      ok = 0;
      for (i=0;i<6;i++) {
        index = (5-i)*7+column;
        if (!this.pieces[index]) {
          this.pieces[index] = 1;
          ok = 1;
          break;
        }
      }
      if (ok == 1) {
        changeTurn();
        win = checkWin();
        if (win == 1) {
          message("Red wins!");
          this.turn = -1;
       }
        attr[1] = this.pieces;
      }
    }
  }
  if (player.chat.starts("black") && player.account == attr[3] && this.turn == 1) {
    tokens = player.chat.tokenize();
    column = tokens[1]-1;
    player.chat = column+1;
    if (column in |0,6|) {
      ok = 0;
      for (i=0;i<6;i++) {
        index = (5-i)*7+column;
        if (!this.pieces[index]) {
          this.pieces[index] = 2;
          ok = 1;
          break;
        }
      }
      if (ok == 1) {
        changeTurn();
        win = checkWin();
        if (win == 2) {
          message("Black wins!");
          this.turn = -1;
        }
        attr[1] = this.pieces;
      }
    }
  }
  if (player.guild == "Game Coordinator" || clientr.secretstaff || clientr.c4control) {
    if (player.chat.starts("/red")) {
      tokens = player.chat.tokenize();
      attr[2] = tokens[1];
    }
    if (player.chat.starts("/black")) {
      tokens = player.chat.tokenize();
      attr[3] = tokens[1];
    }
    if (player.chat == "/reset") {
      this.pieces = new [42];
      changeTurn();
      attr[1] = this.pieces;
    }
    if (player.chat == "/next") {
      changeTurn();
    }
    if (player.chat == "commands") {
      say2(
"Commands:
/red account
/black account
/reset
/next");
    }
  }
}
function changeTurn() {
  if (this.turn == 1) {
    this.turn = 0;
    message("Red's Turn!");
  }
  else {
    this.turn = 1;
    message("Black's Turn!");
  }
}
function checkWin() {
  // check horiz
  for (i=0;i<=3;i++) { // horiz
    for (j=0;j<=6;j++) { // vert
      index = j*7+i;
      if (this.pieces[index] == 1 && this.pieces[index+1] == 1 && this.pieces[index+2] == 1 && this.pieces[index+3] == 1) {
        this.pieces[index] = 3;
        this.pieces[index+1] = 3;
        this.pieces[index+2] = 3;
        this.pieces[index+3] = 3;
        return(1);
      }
      if (this.pieces[index] == 2 && this.pieces[index+1] == 2 && this.pieces[index+2] == 2 && this.pieces[index+3] == 2) {
        this.pieces[index] = 3;
        this.pieces[index+1] = 3;
        this.pieces[index+2] = 3;
        this.pieces[index+3] = 3;
        return(2);
      }
    }
  }
  // check vert
  for (i=0;i<=2;i++) { // vert
    for (j=0;j<=6;j++) { // horiz
      //index = i*7+j;
      if (this.pieces[i*7+j] == 1 && this.pieces[(i+1)*7+j] == 1 && this.pieces[(i+2)*7+j] == 1 && this.pieces[(i+3)*7+j] == 1) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+j] = 3;
        this.pieces[(i+2)*7+j] = 3;
        this.pieces[(i+3)*7+j] = 3;
        return(1);
      }
      if (this.pieces[i*7+j] == 2 && this.pieces[(i+1)*7+j] == 2 && this.pieces[(i+2)*7+j] == 2 && this.pieces[(i+3)*7+j] == 2) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+j] = 3;
        this.pieces[(i+2)*7+j] = 3;
        this.pieces[(i+3)*7+j] = 3;
        return(2);
      }
    }
  }
  // check diag forward
  for (i=0;i<=2;i++) { // vert
    for (j=3;j<=6;j++) { // horiz
      //index = i*7+j;
      if (this.pieces[i*7+j] == 1 && this.pieces[(i+1)*7+(j-1)] == 1 && this.pieces[(i+2)*7+(j-2)] == 1 && this.pieces[(i+3)*7+(j-3)] == 1) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+(j-1)] = 3;
        this.pieces[(i+2)*7+(j-2)] = 3;
        this.pieces[(i+3)*7+(j-3)] = 3;
        return(1);
      }
      if (this.pieces[i*7+j] == 2 && this.pieces[(i+1)*7+(j-1)] == 2 && this.pieces[(i+2)*7+(j-2)] == 2 && this.pieces[(i+3)*7+(j-3)] == 2) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+(j-1)] = 3;
        this.pieces[(i+2)*7+(j-2)] = 3;
        this.pieces[(i+3)*7+(j-3)] = 3;
        return(2);
      }
    }
  }
  // check diag backwards
  for (i=0;i<=2;i++) { // vert
    for (j=0;j<=3;j++) { // horiz
      //index = i*7+j;
      if (this.pieces[i*7+j] == 1 && this.pieces[(i+1)*7+(j+1)] == 1 && this.pieces[(i+2)*7+(j+2)] == 1 && this.pieces[(i+3)*7+(j+3)] == 1) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+(j+1)] = 3;
        this.pieces[(i+2)*7+(j+2)] = 3;
        this.pieces[(i+3)*7+(j+3)] = 3;
        return(1);
      }
      if (this.pieces[i*7+j] == 2 && this.pieces[(i+1)*7+(j+1)] == 2 && this.pieces[(i+2)*7+(j+2)] == 2 && this.pieces[(i+3)*7+(j+3)] == 2) {
        this.pieces[i*7+j] = 3;
        this.pieces[(i+1)*7+(j+1)] = 3;
        this.pieces[(i+2)*7+(j+2)] = 3;
        this.pieces[(i+3)*7+(j+3)] = 3;
        return(2);
      }
    }
  }
  return(0);
}
