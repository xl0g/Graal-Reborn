function DoInit() {
  this.drawingmode = 0; //0: Polygon Only, 1: Wireframe, 2: Both (buggy)
  this.lightingmode = 2; //1: Dispersed Curvature, 2: Intelligent
  this.polycount = 200;
  setarray this.obj_x,800;
  setarray this.obj_y,800;
  setarray this.obj_z,800;
  setarray this.obj_col,600;
  setarray this.obj_normals,600;
  for(this.i = 0;this.i < 20;this.i ++){
    for(this.j = 0;this.j < 10;this.j ++){
      this.obj_x[40*this.i+4*this.j+0] = cos((this.i + 0)*pi/10) * sin((this.j + 0)*pi/10);
      this.obj_x[40*this.i+4*this.j+1] = cos((this.i + 0)*pi/10) * sin((this.j + 1)*pi/10);
      this.obj_x[40*this.i+4*this.j+2] = cos((this.i + 1)*pi/10) * sin((this.j + 1)*pi/10);
      this.obj_x[40*this.i+4*this.j+3] = cos((this.i + 1)*pi/10) * sin((this.j + 0)*pi/10);

      this.obj_y[40*this.i+4*this.j+0] = sin((this.i + 0)*pi/10) * sin((this.j + 0)*pi/10);
      this.obj_y[40*this.i+4*this.j+1] = sin((this.i + 0)*pi/10) * sin((this.j + 1)*pi/10);
      this.obj_y[40*this.i+4*this.j+2] = sin((this.i + 1)*pi/10) * sin((this.j + 1)*pi/10);
      this.obj_y[40*this.i+4*this.j+3] = sin((this.i + 1)*pi/10) * sin((this.j + 0)*pi/10);

      this.obj_z[40*this.i+4*this.j+0] = 2*cos((this.j + 0)*pi/20) - 1;
      this.obj_z[40*this.i+4*this.j+1] = 2*cos((this.j + 1)*pi/20) - 1;
      this.obj_z[40*this.i+4*this.j+2] = 2*cos((this.j + 1)*pi/20) - 1;
      this.obj_z[40*this.i+4*this.j+3] = 2*cos((this.j + 0)*pi/20) - 1;

      this.obj_normals[30*this.i+3*this.j+0] = cos((this.i + 0.5)*pi/10) * sin((this.j + 0.5)*pi/10);
      this.obj_normals[30*this.i+3*this.j+1] = sin((this.i + 0.5)*pi/10) * sin((this.j + 0.5)*pi/10);
      this.obj_normals[30*this.i+3*this.j+2] = 2*cos((this.j + 0.5)*pi/20) - 1;

      this.obj_col[30*this.i+3*this.j+0] = abs(0.5 * cos((this.j + 20/3)*pi/11)) + abs(0.5 * cos((this.i + 00/3)*pi/11));
      this.obj_col[30*this.i+3*this.j+1] = abs(0.5 * cos((this.j + 20/3)*pi/11)) + abs(0.5 * cos((this.i + 10/3)*pi/11));
      this.obj_col[30*this.i+3*this.j+2] = abs(0.5 * cos((this.j + 20/3)*pi/11)) + abs(0.5 * cos((this.i + 20/3)*pi/11));
    }
  }
}

function DoDrawing() {
  if (this.drawingmode % 2 == 0) {
    for(this.i = 0;this.i < this.polycount;this.i ++) {
      showpoly2 200 + this.i,{this.dp_x + (this.obj_x[4*this.i + 0]*this.tensor_x[0] + this.obj_y[4*this.i + 0]*this.tensor_y[0] + this.obj_z[4*this.i + 0]*this.tensor_z[0]) * this.dp_multi,
                              this.dp_y + (this.obj_x[4*this.i + 0]*this.tensor_x[1] + this.obj_y[4*this.i + 0]*this.tensor_y[1] + this.obj_z[4*this.i + 0]*this.tensor_z[1]) * this.dp_multi,
                              this.dp_z + (this.obj_x[4*this.i + 0]*this.tensor_x[2] + this.obj_y[4*this.i + 0]*this.tensor_y[2] + this.obj_z[4*this.i + 0]*this.tensor_z[2]) * this.dp_multi,

                              this.dp_x + (this.obj_x[4*this.i + 1]*this.tensor_x[0] + this.obj_y[4*this.i + 1]*this.tensor_y[0] + this.obj_z[4*this.i + 1]*this.tensor_z[0]) * this.dp_multi,
                              this.dp_y + (this.obj_x[4*this.i + 1]*this.tensor_x[1] + this.obj_y[4*this.i + 1]*this.tensor_y[1] + this.obj_z[4*this.i + 1]*this.tensor_z[1]) * this.dp_multi,
                              this.dp_z + (this.obj_x[4*this.i + 1]*this.tensor_x[2] + this.obj_y[4*this.i + 1]*this.tensor_y[2] + this.obj_z[4*this.i + 1]*this.tensor_z[2]) * this.dp_multi,

                              this.dp_x + (this.obj_x[4*this.i + 2]*this.tensor_x[0] + this.obj_y[4*this.i + 2]*this.tensor_y[0] + this.obj_z[4*this.i + 2]*this.tensor_z[0]) * this.dp_multi,
                              this.dp_y + (this.obj_x[4*this.i + 2]*this.tensor_x[1] + this.obj_y[4*this.i + 2]*this.tensor_y[1] + this.obj_z[4*this.i + 2]*this.tensor_z[1]) * this.dp_multi,
                              this.dp_z + (this.obj_x[4*this.i + 2]*this.tensor_x[2] + this.obj_y[4*this.i + 2]*this.tensor_y[2] + this.obj_z[4*this.i + 2]*this.tensor_z[2]) * this.dp_multi,

                              this.dp_x + (this.obj_x[4*this.i + 3]*this.tensor_x[0] + this.obj_y[4*this.i + 3]*this.tensor_y[0] + this.obj_z[4*this.i + 3]*this.tensor_z[0]) * this.dp_multi,
                              this.dp_y + (this.obj_x[4*this.i + 3]*this.tensor_x[1] + this.obj_y[4*this.i + 3]*this.tensor_y[1] + this.obj_z[4*this.i + 3]*this.tensor_z[1]) * this.dp_multi,
                              this.dp_z + (this.obj_x[4*this.i + 3]*this.tensor_x[2] + this.obj_y[4*this.i + 3]*this.tensor_y[2] + this.obj_z[4*this.i + 3]*this.tensor_z[2]) * this.dp_multi
                             };
      setarray this.l_nor,3;
      this.l_nor[0] = (this.obj_normals[this.i*3 + 0]*this.tensor_x[0] + this.obj_normals[this.i*3 + 1]*this.tensor_y[0] + this.obj_normals[this.i*3 + 2]*this.tensor_z[0]);
      this.l_nor[1] = (this.obj_normals[this.i*3 + 0]*this.tensor_x[1] + this.obj_normals[this.i*3 + 1]*this.tensor_y[1] + this.obj_normals[this.i*3 + 2]*this.tensor_z[1]);
      this.l_nor[2] = (this.obj_normals[this.i*3 + 0]*this.tensor_x[2] + this.obj_normals[this.i*3 + 1]*this.tensor_y[2] + this.obj_normals[this.i*3 + 2]*this.tensor_z[2]);
      this.numer= (this.l_dir[0]*this.l_nor[0] + this.l_dir[1]*this.l_nor[1] + this.l_dir[2]*this.l_nor[2]);
      this.denumer = ((this.l_dir[0]^2 + this.l_dir[1]^2 + this.l_dir[2]^2)^0.5) * ((this.l_nor[0]^2 + this.l_nor[1]^2 + this.l_nor[2]^2)^0.5);
      if (this.lightingmode == 1) {
        this.intensity = 0.5 + 0.5*(this.numer/this.denumer);
      }
      if (this.lightingmode == 2) {
        this.intensity = 0.3 + 0.7*this.numer/this.denumer;
        if (this.intensity < 0.05) {
          this.intensity = 0.05;
        }
      }
      changeimgcolors 200 + this.i,this.obj_col[3*this.i + 0] * this.intensity,this.obj_col[3*this.i + 1] * this.intensity,this.obj_col[3*this.i + 2] * this.intensity,1;
      changeimgvis 200 + this.i,4;
    }
  }

  if (this.drawingmode > 0) {
    for(this.i = 0;this.i < this.polycount*4;this.i += 4) {
      for(this.j = 0;this.j < 4;this.j ++) {
        showpoly2 200 + this.polycount + this.i + this.j,{this.dp_x + (this.obj_x[this.i + (this.j + 0)%4]*this.tensor_x[0] + this.obj_y[this.i + (this.j + 0)%4]*this.tensor_y[0] + this.obj_z[this.i + (this.j + 0)%4]*this.tensor_z[0]) * this.dp_multi,
                                                          this.dp_y + (this.obj_x[this.i + (this.j + 0)%4]*this.tensor_x[1] + this.obj_y[this.i + (this.j + 0)%4]*this.tensor_y[1] + this.obj_z[this.i + (this.j + 0)%4]*this.tensor_z[1]) * this.dp_multi,
                                                          this.dp_z + (this.obj_x[this.i + (this.j + 0)%4]*this.tensor_x[2] + this.obj_y[this.i + (this.j + 0)%4]*this.tensor_y[2] + this.obj_z[this.i + (this.j + 0)%4]*this.tensor_z[2]) * this.dp_multi,

                                                          this.dp_x + (this.obj_x[this.i + (this.j + 1)%4]*this.tensor_x[0] + this.obj_y[this.i + (this.j + 1)%4]*this.tensor_y[0] + this.obj_z[this.i + (this.j + 1)%4]*this.tensor_z[0]) * this.dp_multi,
                                                          this.dp_y + (this.obj_x[this.i + (this.j + 1)%4]*this.tensor_x[1] + this.obj_y[this.i + (this.j + 1)%4]*this.tensor_y[1] + this.obj_z[this.i + (this.j + 1)%4]*this.tensor_z[1]) * this.dp_multi,
                                                          this.dp_z + (this.obj_x[this.i + (this.j + 1)%4]*this.tensor_x[2] + this.obj_y[this.i + (this.j + 1)%4]*this.tensor_y[2] + this.obj_z[this.i + (this.j + 1)%4]*this.tensor_z[2]) * this.dp_multi
                                                         };
        changeimgvis 200 + this.polycount + this.i + this.j,4;
        changeimgcolors 200 + this.polycount + this.i + this.j,0,1,0,0;
      }
    }
  }

}

function DoReset() {
  this.tensor_x = {1,0,0}; //unit x -> x,y,z
  this.tensor_y = {0,1,0}; //unit y -> x,y,z
  this.tensor_z = {0,0,1}; //unit z -> x,y,z
}

function DoXSpin() {
  this.c = cos(this.angle);
  this.s = sin(this.angle);
  this.setx = {this.tensor_x[0],this.c*this.tensor_x[1] + this.s*this.tensor_x[2],this.c*this.tensor_x[2] - this.s*this.tensor_x[1]};
  this.sety = {this.tensor_y[0],this.c*this.tensor_y[1] + this.s*this.tensor_y[2],this.c*this.tensor_y[2] - this.s*this.tensor_y[1]};
  this.setz = {this.tensor_z[0],this.c*this.tensor_z[1] + this.s*this.tensor_z[2],this.c*this.tensor_z[2] - this.s*this.tensor_z[1]};
  this.tensor_x = {this.setx[0],this.setx[1],this.setx[2]};
  this.tensor_y = {this.sety[0],this.sety[1],this.sety[2]};
  this.tensor_z = {this.setz[0],this.setz[1],this.setz[2]};
}

function DoYSpin() {
  this.c = cos(this.angle);
  this.s = sin(this.angle);
  this.setx = {this.c*this.tensor_x[0] + this.s*this.tensor_x[2],this.tensor_x[1],this.c*this.tensor_x[2] - this.s*this.tensor_x[0]};
  this.sety = {this.c*this.tensor_y[0] + this.s*this.tensor_y[2],this.tensor_y[1],this.c*this.tensor_y[2] - this.s*this.tensor_y[0]};
  this.setz = {this.c*this.tensor_z[0] + this.s*this.tensor_z[2],this.tensor_z[1],this.c*this.tensor_z[2] - this.s*this.tensor_z[0]};
  this.tensor_x = {this.setx[0],this.setx[1],this.setx[2]};
  this.tensor_y = {this.sety[0],this.sety[1],this.sety[2]};
  this.tensor_z = {this.setz[0],this.setz[1],this.setz[2]};
}

function DoZSpin() {
  this.c = cos(this.angle);
  this.s = sin(this.angle);
  this.setx = {this.c*this.tensor_x[0] + this.s*this.tensor_x[1],this.c*this.tensor_x[1] - this.s*this.tensor_x[0],this.tensor_x[2]};
  this.sety = {this.c*this.tensor_y[0] + this.s*this.tensor_y[1],this.c*this.tensor_y[1] - this.s*this.tensor_y[0],this.tensor_y[2]};
  this.setz = {this.c*this.tensor_z[0] + this.s*this.tensor_z[1],this.c*this.tensor_z[1] - this.s*this.tensor_z[0],this.tensor_z[2]};
  this.tensor_x = {this.setx[0],this.setx[1],this.setx[2]};
  this.tensor_y = {this.sety[0],this.sety[1],this.sety[2]};
  this.tensor_z = {this.setz[0],this.setz[1],this.setz[2]};
}













