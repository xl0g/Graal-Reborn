function onCreated(){
  this.dhearts=1500;
  chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
  serverr.gc_swat_stats.replace(1,int((this.dhearts/1500)*100) @ "%");
  setTimer(1);

}
function onPlayerChats(){
  if (player.guild == "Game Coordinator")
    if (player.chat == "/reset"){
    this.dhearts=1500;
    chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
    serverr.gc_swat_stats.replace(1,int((this.dhearts/1500)*100) @ "%");
    show();
  }
}
function onSlash(){
  if(serverr.gc_swatbalanced="true"){
    if(player.guild="Terrorist"){
      if(this.dhearts > 0){
        this.dhearts -= 1;
        chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
        serverr.gc_swat_stats.replace(1,int((this.dhearts/1500)*100) @ "%");
        setTimer(1.5);
      }
      if(this.dhearts == 0){
        hide();
        setTimer(1.5);
      }
    }
    else if(player.guild="SWAT" && this.dhearts < 1500){
      this.dhearts += .5;
      chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
      serverr.gc_swat_stats.replace(1,int((this.dhearts/1500)*100) @ "%");
    }
  }
}
  function onTimeOut(){
    if(this.dhearts<1500){
      setTimer(.02);
      if(serverr.gc_swatbalanced="true"){
        this.dhearts ++;
        chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
        serverr.gc_swat_stats.replace(1,int((this.dhearts/1500)*100) @ "%");
      }
    }
  }
