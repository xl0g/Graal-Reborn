function onPlayertouchsme(){
  if(clientr.quest_knight_complete == 1){
    say2("Oh, it's you.#bYou may pass.");
    hide();
  }
  else{
    if(player.dir == 0){
      say2("Only the Kings soldiers may enter#bor leave Graal City.");
    }
    else{
      if(player.y < y){
        say2("Eh, you didn't come past me,#bit's not my problem.");
      }
    }
  }
}
