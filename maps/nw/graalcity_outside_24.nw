  if(clientr.quest_knight_complete == 1 || player.clientr.info_playertrial == "No"){
    hide();
  }
  else{
    showcharacter();
    head = "head16.png";
    colors[0] = "orange";
    colors[1] = "gray";
    colors[2] = "darkblue";
    colors[3] = "darkblue";
    colors[4] = "darkblue";
    shield = "shield1.png";
    body = "body.png";
    dir = 2;
