NPC - 42 23
// NPC made by Com013 (LAT)
function onPlayerChats(){
if(player.chat == "buy game"){
  if (clientr.stat_gelat<1000) {
    say2 #bSorry, you need more rupees!;
  } else {
    clientr.stat_gelat-=1000;
    player.addweapon("Minigames System");
    player.addweapon("-game-Graalian Invaders");
  }
}
if(player.chat == "buy blocks"){
  if (clientr.stat_gelat<500) {
    say2 #bSorry, you need more rupees!;
  } else {
    clientr.stat_gelat-=500;
    player.addweapon("-game-Falling Blocks");
  }
}
if(player.chat == "buy map"){
  if (clientr.stat_gelat<150) {
    say2 #bSorry, you need more rupees!;
  } else {
if(player.clientr.nimdamap==0){
    clientr.stat_gelat-=150;
    player.clientr.nimdamap=1;
    say2 I just bought a map!#bI should go to Nimda Forest#bto investigate these markings!;
  }
else say2 I already have a map!#bI should go to Nimda Forest#bto investigate these markings!;
}
}
}
NPCEND
