    clientr.quest_boss_hp = this.full_hp;
  }
}

function onActionprojectile() {
  if (params[5] == "stone" && params[6] == getangle(0, 1)){
    clientr.quest_boss_hp--;
    if (clientr.quest_boss_hp <= 0) {
      clientr.quest_dungeon_complete = true;
    }
    else {
      chat = "OW!!!";
      sleep(1);
      chat = "";
    }
  }
}

function onActionSetDamage() {
  temp.damage = putnpc2(31,20,"join control_damage;");
  temp.damage.attacker = this;
  temp.damage.target   = player;
  temp.damage.scheduleEvent(0.5,"SetDamageField",31,20,2,2,32,0,10,-2,1);
}

//#CLIENTSIDE
function onCreated() {
  this.full_hp=5;
  initialize();
}

function onPlayerEnters() {
  this.modeYA = "sleep";
  initialize();
}

function initialize() {
  setshape(1,96,128);
  showani(200,x+1.5,y+4,2,"classic_dungeon_boss-sleep",NULL);
  changeimgvis(200,0);
}

function onActionprojectile() {
  if (clientr.quest_boss_hp > 0) {
    if (params[5] == "stone" && params[6] == getangle(0, 1)){
      showani(200,x+1.5,y+4,2,"classic_dungeon_boss-hurt",NULL);
      play("bosshurt.wav");
      changeimgvis(200,0);
      if (clientr.quest_boss_hp == 1) {
        this.modeYA = "death";
        play("bossdead.wav");
        showani(200,x+1.5,y+4,2,"classic_dungeon_boss-death",NULL);
        changeimgvis(200,0);
      }
      setTimer(0.05);
    }
  }
}

function onSlash() {
  switch (this.modeYA) {
    case "sleep":
    showani(200,x+1.5,y+4,2,"classic_dungeon_boss-wake",NULL);
    changeimgvis(200,0);
    say2("Who dares to awaken me?");
    stopmidi();
    sleep 1;
    client.midi = "classic_nw-bosstheme.mid";
    playlooped("classic_nw-bosstheme.mid");
    showani(200,x+1.5,y+4,2,"classic_dungeon_boss-idle",NULL);
    changeimgvis(200,0);
    this.modeYA = "idle";
    break;
  }
}

function onPlayertouchsme() {
  switch (this.modeYA) {
    case "idle":
    showani(200,x+1.5,y+4,2,"classic_dungeon_boss-raise",NULL);
    changeimgvis(200,0);
    player.y = int(player.y);
    player.dir = 2;
    this.modeYA = "lift";
    triggeraction(x+1,y+1,"setdamage",null);
    onTimeout();
    break;
  }
}

function onTimeout() {
  movement_handlemoving = .1;
  switch (this.modeYA) {
    case "lift":
    if (player.y > y-1) {
      setTimer(0.05);
      if (player.y >= y+2) {
        player.y -= 1/(player.y-(y+2));
      }
      else {
        player.y--;
      }
    }
    else {
      showani(200,x+1.5,y+4,2,"classic_dungeon_boss-throw",NULL);
      changeimgvis(200,0);
      setTimer(0.2);
      movement_handlemoving = timeout;
      this.modeYA = "throw";
    }
    break;
    case "throw":
    setani("throw");
    if (onwall(player.x+1.5,player.y-3)) {
      player.y++;
      setTimer(0.05);
    }
    else {
      this.ouch = 0;
      setTimer(0.4);
      this.modeYA = "idle";
    }
    break;
    case "idle":
    showani(200,x+1.5,y+4,2,"classic_dungeon_boss-idle",NULL);
    changeimgvis(200,0);
    break;
    case "death":
    if (player.y<19) {
      player.y+=.25;
      setTimer(0.05);
    }
    else{
      client.midi = "";
      stopmidi();
      play("classic_woohoo.wav");
    }
    break;
  }
}
NPCEND
