function onPlayerenters() {
  for (temp.i = 0; temp.i < npcs.size(); temp.i ++) {
    if (npcs[temp.i].owner == player || !(npcs[temp.i].owner in players)) {
      if ("quest_dungeon_boss_statue" in npcs[temp.i].joinedclasses) {
        npcs[temp.i].destroy();
      }
    }
  }
  this.IDs = "abcdefghijkl";
  this.origx = {42,20,42,20,42,20,42,20,42,20,42,20};
  this.origy = {40,40,46,46,40,40,46,46,40,40,46,46};
  this.distx = {-9,9,-9,9,-9,9,-9,9,-11,11,-11,11};
  this.disty = {-11,-11,-15,-15,-7,-7,-11,-11,-13,-11,-15,-13};
  for (temp.i = 0; temp.i<this.IDs.length(); temp.i ++) {
    this.scheduleevent(2*temp.i,"RequestStatue",
                       this.origx[temp.i],
                       this.origy[temp.i],
                       this.distx[temp.i],
                       this.disty[temp.i],
                       this.IDs.charat(temp.i));
  }
}

function onRequestStatue(x0, y0, dx, dy, myID) {
  temp.statue       = putnpc2(x0, y0, "join quest_dungeon_boss_statue;");
  temp.statue.owner = player;
  temp.statue.trigger("Activate", myID, dx, dy);
}
