function onCreated(){
  this.items = {"Portable Chair","Jellybeans","Sword Dance","Skull Storm","Dice","Fake Dagger","Coin","Angel","Jump Rope","Fireworks","Poly Trail","Sword Thrower","Stone Form","Studios Pass","Neo Poly Trail","Entertainer","Aura","Freak","Self Destruct","Shack on Demand","3rd Degree Burn","Time Distort","Astral Projection","12-Pack","Skull Summon","RPS"};
  this.itemv = {20,15,20,25,25,30,20,20,10,25,25,30,25,10,25,15,25,20,20,30,20,20,30,1,25,25};

  x = 31.5;
}
function onPlayerChats(){
  if (player.chat.starts("buy") && player.chat != "buy 12-Pack"){
    temp.product = player.chat.substring(3).trim();
    temp.productpos = this.items.index(temp.product);
    if (temp.productpos => 0){
      if (player.clientr.stat_gctickets => this.itemv[temp.productpos]){
        player.addweapon("GC/"@temp.product);
        player.clientr.stat_gctickets -= this.itemv[temp.productpos];
        player.clientr.("stat_gcitemct_" @ temp.product)++;
        player.chat = "You got " @ temp.product @ "!";
        player.setani("classic_holdup",findweapon("GC/"@temp.product).image);
      }
      else {
        player.chat = "You don't have enough GC Tickets!";
      }
    }
    else {
      player.chat = "That item's not valid!";
    }
  }
}
