function onPlayerenters(){
  onTimeout();
}

function onTimeout(){
  for(this.i2=0;this.i2<6.283;this.i2+=0.6283){
    this.x1=x+1.1;
    this.y1=y+1.1;
    for(this.i1=2;this.i1<9;this.i1++){
      dx = (cos(this.angle-(this.i1*this.angle)+this.i2)) * (sin(this.angle-(this.i1*this.angle)+this.i2));
      dx = dx * ((11-this.i1)/2);
      this.x1=this.x1 + dx;
      dy = sin(this.angle-(this.i1*this.angle)+this.i2);
      dy = dy * ((11-this.i1)/2);
      this.y1=this.y1+dy/3;
      if(int(random(0,2))==1) {
      showimg(((this.i2*10)+this.i1),"light4.png",this.x1,this.y1);
      changeimgzoom(((this.i2*10)+this.i1),0.2);
      changeimgcolors(((this.i2*10)+this.i1),1,0.5,0.5,0.4);
      }
      else {showimg(((this.i2*10)+this.i1),"light4.png",this.x1,this.y1);
            changeimgzoom(((this.i2*10)+this.i1),0.2);
      changeimgcolors(((this.i2*10)+this.i1),0.5,0.5,1,0.4);}

    }
  }
  this.angle=(this.angle-0.0314)%31.4159;
  setTimer(0.05);
}
