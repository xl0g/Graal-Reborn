function onActionPush(dir) {
  if (!this.pushed && dir==0) {
    move(5,0,1,0);
    this.pushed = true;
    setTimer(5);
  }
}
function onTimeOut(){
  this.pushed = false;
  move(-5,0,1,8);
}

//#CLIENTSIDE
function onCreated() {
  setshape(1,64,64);
  drawunderplayer();
  onTimeout();
}

function onTimeout() {
  if (player.x in <x-2,x+5>
    && player.y in <y-2,y+3.5>)
      this.d = 15;
  else {
    this.d = (((x+3)-(player.x+1.5))^2+((y+5)-(player.y+5.5))^2)^0.75;
    if (this.d > 15)
      this.d = 15;
  }
  seteffectmode(1);
  setcoloreffect(1,1,1,this.d/15);
  setTimer(0.05);
}
