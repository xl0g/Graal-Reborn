      if (dist < mindist){
        show;
        mindist = dist;
        x=playerx;
        if (playerdir == 0){
          dir = 2;
        }
        if (playerdir == 1){
          dir = 1;
        }
        if (playerdir == 2){
          dir = 0;
        }
        if (playerdir == 3){
          dir = 3;
        }
        if (!strequals(#m(-1),#m(i))){
          setcharani #m(i),;
        }
        setcharprop #3,#3(i);
        setcharprop #2,#2(i);
        setcharprop #P1,#P1(i);
        setcharprop #P3,#P3(i);
        setcharprop #P5,#P5(i);
        setcharprop #C0,#C0(i);
        setcharprop #C1,#C1(i);
        setcharprop #C2,#C2(i);
        setcharprop #C3,#C3(i);
        setcharprop #C4,#C4(i);
      }
    }
  }
  timeout = 0.05;
}
