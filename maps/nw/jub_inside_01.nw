  this.flames_colourswitch = 0;
  for (this.flames_drawtime = 0;this.flames_drawtime < this.flames_multiplyer;this.flames_drawtime ++){
    showimg 210 + this.flames_drawtime,light2.png,x - 4 + (this.flames_randomx[this.flames_drawtime] / this.flames_recycletime)*this.flames_changevar[this.flames_drawtime] + ((this.flames_changevar[this.flames_drawtime]^2)/2 + this.flames_changevar[this.flames_drawtime]/2)*this.flames_gravityx,y - 4 + (this.flames_randomy[this.flames_drawtime] / this.flames_recycletime)*this.flames_changevar[this.flames_drawtime] + ((this.flames_changevar[this.flames_drawtime]^2)/2 + this.flames_changevar[this.flames_drawtime]/2)*this.flames_gravityy;
    if (this.flames_colourswitch > 1){
      changeimgcolors 210 + this.flames_drawtime,this.flames_tintcolor_red,this.flames_tintcolor_green,this.flames_tintcolor_blue,this.flames_alpha;
      this.flames_colourswitch = 0;
    }
    else {
      changeimgcolors 210 + this.flames_drawtime,this.flames_maincolor_red,this.flames_maincolor_green,this.flames_maincolor_blue,this.flames_alpha;
      this.flames_colourswitch ++;
    }
    changeimgvis 210 + this.flames_drawtime,3;
    changeimgzoom 210 + this.flames_drawtime,this.flames_zoom;
    this.flames_changevar[this.flames_drawtime] ++;
    if (this.flames_changevar[this.flames_drawtime] > this.flames_recycletime){
      this.flames_changevar[this.flames_drawtime] = 0;
      this.flames_randomx[this.flames_drawtime] = random(this.flames_minimumx,this.flames_maximumx);
      this.flames_randomy[this.flames_drawtime] = random(this.flames_minimumy,this.flames_maximumy);
    }
  }
  timeout = 0.05;
}
NPCEND
