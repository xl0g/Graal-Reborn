function onPlayerenters(){
  setimg("block.png");
  setTimer(5);
  setshape(1,32,32);

  if(serverr.redlampinn_2[0] != 0){
    chat = serverr.redlampinn_2[0] @ "(" @ int((serverr.redlampinn_2[1]-timevar2)/60) @ " Minute(s))";
  }
  else {chat="Room available!";

  }
}

function onTimeout(){

  if(serverr.redlampinn_2[1] <= timevar2){
    serverr.redlampinn_2 = 0;
  }

  if(serverr.redlampinn_2[0] != 0){
    chat = serverr.redlampinn_2[0] @ "(" @ int((serverr.redlampinn_2[1]-timevar2)/60) @ " Minute(s))";
  }
  else {chat="Room available!";

  }

  setTimer(5);
}

//#CLIENTSIDE

function onCreated(){
  setimg("block.png");
  setshape(1,32,32);
}

function onPlayerenters(){
  onTimeout();
}

function onTimeout(){

  if(player.y >= 34 && player.x <= 30.5 && player.account != serverr.redlampinn_2[0]){

     player.y = 32.5;

  }

setTimer(2);
}

function onPlayertouchsme(){
  if(player.account == serverr.redlampinn_2[0]){
    if(player.y > 33){
      player.y = 32.5;
    }
    else if(player.y <= 33){
      player.y = 38;
    }
  }
}
NPCEND
