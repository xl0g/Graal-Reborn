function onCreated(){
  setshape(1,64,32);
}


function onPlayertouchsme(){
  if(clientr.info_playertrial == "yes"){
    say2("Trials cannot enter the Fort.");
    return;
  }

  if(timevar2 < (serverr.guildfortMoD_stats[4]+300)){
    if(!(serverr.guildfortMoD_stats[3] in {player.communityname,player.guild})){
      temp.time = int((serverr.guildfortMoD_stats[4]+300-timevar2)/60);
      if(temp.time > 0){
        say2("The Fort has been won.#bWait "@temp.time@" minutes.");
      }
      else{
        say2("The Fort has been won.#bWait 30 Seconds");
      }
      return;
    }
  }

  setlevel2("mod_fort_inside_01.nw",30.5,48);

}
