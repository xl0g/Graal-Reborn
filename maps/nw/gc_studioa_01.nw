  if (player.guild == "Game Coordinator" || player.id == level.gc_control) {
    if (player.chat in |1,6| && player.chat.length() == 1) {
      set_safe();
      this.poison = strtofloat(#c);
      while (this.poison != 0) {
        this.int = int(random(0,6));
        if (this.safe[this.int] == 0) continue;
        this.safe[this.int] = 0;
        save[this.int]      = 0;
        this.poison--;
      }
    }
  }
}

function onPlayertouchsme() {
  if (playerdir == 0) {
    for (this.i = 0; this.i < 6; this.i++) {
      if (playerx in |20 + 4 * this.i,21 + 4 * this.i|) {
        client.movement_drunk=45;
        if (player.guild != "Game Coordinator") {
          if (this.safe[this.i] == 0 && this.tangible[this.i] == 1) {
            player.chat = "Urgh, this beer is rancid!";
            setlevel2 gc_studioa_01.nw,30.5,51;
            setani classic_dead,;
            this.tangible[this.i] = 0;
          }
          save[this.i] = 0;
          hideimg this.i;
        }
      }
    }
  }
}

function set_safe() {
  this.safe     = {1,1,1,1,1,1};
  this.tangible = {1,1,1,1,1,1};
  for (this.i = 0; this.i < 6; this.i++) {
    save[this.i] = 1;
    showimg this.i,beer.png,x + this.i * 4,y;
    changeimgvis this.i,0;
  }
}

