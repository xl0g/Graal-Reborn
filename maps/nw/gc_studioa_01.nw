      if (save[this.i] == 0) {
        this.arrow = {21.5,37.625,22,38.25,22.5,37.625};
        for (this.j = 0; this.j < 3; this.j++) {
          this.arrow[2*this.j] += this.i * 4;
        }
        showpoly 200+this.i,this.arrow;
      }
    }
  }
}

if (playertouchsme) {
  if (playerdir == 0) {
