NPC classic_gc_gateleft.png 3 32
function onCreated(){
  this.dhearts=1500;
  this.chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
  serverr.gc_bg_stats[1] = int((this.dhearts/1500)*100) @ "%";
  setTimer(1);
  setshape(1,80,288);
}
function onPlayerChats(){
  if (player.guild == "Game Coordinator")
    if (player.chat == "/reset"){
    this.dhearts=1500;
    this.chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
    serverr.gc_bg_stats[1] = int((this.dhearts/1500)*100) @ "%";
    show();
  }
}
function onSlash(){
  if(this.dhearts > 0 && player.guild == "Destiny Knights"){
    this.dhearts -= 1;
    this.chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
    serverr.gc_bg_stats[1] = int((this.dhearts/1500)*100) @ "%";
    setTimer(1.5);
  }
  if(this.dhearts == 0){
    hide();
    clink=findNPC("gc_rankings");
    (clink.("gc_" @ player.account @ "_bg_gates"))++;
    serverr.gc_bg_stats[1] = int((this.dhearts/1500)*100) @ "%";
    setTimer(1.5);
  }
}
function onTimeOut(){
  if(this.dhearts<1500 && this.dhearts != 0 && serverr.gc_bgbalanced = "true"){

    this.dhearts ++;
    this.chat="HP: " @ int((this.dhearts/1500)*100) @ "%";
    serverr.gc_bg_stats[1] = int((this.dhearts/1500)*100) @ "%";
  }
  setTimer(.03);
}
//#CLIENTSIDE
if(strequals(#g,Babord Infantry)){
  dontblock;
}
NPCEND
